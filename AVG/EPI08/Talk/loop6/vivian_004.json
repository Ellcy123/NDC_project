    "cnSpeaker": "",
    "enSpeaker": "",
    "Location": "",
    "cnAction": "",
    "cnWords": "*[旁白/Zack 观察]*\n她低头看了看自己的手。\n手背上有一条淡淡的勒痕——那是铐子留下的。\n她就这么看了一会儿，没说话。",
    "enAction": "",
    "enWords": "",
    "next": "806004004",
    "script": "",
    "ParameterStr0": "",
    "ParameterStr1": "",
    "ParameterStr2": "",
    "ParameterInt0": 0,
