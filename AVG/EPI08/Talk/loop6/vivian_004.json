  },
  {
    "id": 806004008,
    "step": 8,
    "speakType": 4,
    "waitTime": 0,
    "IdSpeaker": "",
    "cnSpeaker": "",
    "enSpeaker": "",
    "Location": "",
    "cnAction": "",
    "cnWords": "\"走廊通风是件大事，Vivian。\n我来之前数了一下——关押区一共三扇窗，两扇钉死的，一扇上了锁，钥匙在值班警员那里。\n这是一座大城市里最公开的地方，能做到的隔离是这样的。\"",
    "enAction": "",
    "enWords": "",
    "next": "806004009",
    "script": "",
    "ParameterStr0": "",
    "ParameterStr1": "",
    "ParameterStr2": "",
    "ParameterInt0": 0,
    "ParameterInt1": 0,
    "ParameterInt2": 0,
    "videoEpisode": "EPI08",
    "videoLoop": "loop6",
    "videoId": "806004008",
    "videoScene": "vivian_004"
  },
  {
    "id": 806004009,
    "step": 9,
    "speakType": 4,
    "waitTime": 0,
    "IdSpeaker": "",
    "cnSpeaker": "",
    "enSpeaker": "",
    "Location": "",
    "cnAction": "",
    "cnWords": "\"……你要写进报道里？\"",
    "enAction": "",
    "enWords": "",
    "next": "806004010",
    "script": "",
    "ParameterStr0": "",
    "ParameterStr1": "",
    "ParameterStr2": "",
    "ParameterInt0": 0,
    "ParameterInt1": 0,
    "ParameterInt2": 0,
    "videoEpisode": "EPI08",
    "videoLoop": "loop6",
    "videoId": "806004009",
    "videoScene": "vivian_004"
  },
  {
