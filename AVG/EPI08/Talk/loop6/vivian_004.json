    "cnSpeaker": "",
    "enSpeaker": "",
    "Location": "",
    "cnAction": "",
    "cnWords": "*[旁白]*\n然后她抬起头，看到走廊里等着的 Zack 和 Emma。\n就这样。两个字。",
    "enAction": "",
    "enWords": "",
    "next": "806004005",
