    "waitTime": 0,
    "IdSpeaker": "",
    "cnSpeaker": "",
    "enSpeaker": "",
    "Location": "",
    "cnAction": "",
    "cnWords": "\"那天我们在一家咖啡馆。\n靠窗的位置，Webb 点了两杯拿铁，糖放在桌上，他说他不加糖，但每次都会顺手拿一块。\"",
    "enAction": "",
    "enWords": "",
    "next": "806005005",
    "script": "",
    "ParameterStr0": "",
    "ParameterStr1": "",
    "ParameterStr2": "",
    "ParameterInt0": 0,
    "ParameterInt1": 0,
    "ParameterInt2": 0,
    "videoEpisode": "EPI08",
