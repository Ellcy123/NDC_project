    "speakType": 4,
    "waitTime": 0,
    "IdSpeaker": "",
    "cnSpeaker": "",
    "enSpeaker": "",
    "Location": "",
    "cnAction": "",
    "cnWords": "\"关押条件、饮食、探视权。\n你这几天的处境，白纸黑字写清楚——\n让下一个 Vivian，少受一点这样的对待。\"",
    "enAction": "",
    "enWords": "",
    "next": "806004011",
    "script": "",
    "ParameterStr0": "",
    "ParameterStr1": "",
    "ParameterStr2": "",
    "ParameterInt0": 0,
    "ParameterInt1": 0,
    "ParameterInt2": 0,
    "videoEpisode": "EPI08",
