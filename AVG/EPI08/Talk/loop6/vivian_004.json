    "waitTime": 0,
    "IdSpeaker": "",
    "cnSpeaker": "",
    "enSpeaker": "",
    "Location": "",
    "cnAction": "",
    "cnWords": "\"谢谢你。\"",
    "enAction": "",
    "enWords": "",
    "next": "806004006",
    "script": "",
    "ParameterStr0": "",
