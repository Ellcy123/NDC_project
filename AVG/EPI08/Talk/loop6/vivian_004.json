    "cnSpeaker": "",
    "enSpeaker": "",
    "Location": "",
    "cnAction": "",
    "cnWords": "*[旁白/Zack]*\nZack 没打算说什么煽情的话。\n他只是把释放令叠好，塞进外套口袋。",
    "enAction": "",
    "enWords": "",
    "next": "806004007",
    "script": "",
    "ParameterStr0": "",
    "ParameterStr1": "",
    "ParameterStr2": "",
