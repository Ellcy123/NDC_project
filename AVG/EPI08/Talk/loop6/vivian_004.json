    "speakType": 4,
    "waitTime": 0,
    "IdSpeaker": "",
    "cnSpeaker": "",
    "enSpeaker": "",
    "Location": "",
    "cnAction": "",
    "cnWords": "\"他说，他要记住这个日期。\n我问为什么。他说，以后就知道了。\"",
    "enAction": "",
    "enWords": "",
    "next": "806005006",
    "script": "",
    "ParameterStr0": "",
