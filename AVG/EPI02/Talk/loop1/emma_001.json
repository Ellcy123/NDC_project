[
  {
    "id": 202001001,
    "cnWords": "我来晚了......",
    "cnSpeaker": "扎克·布伦南",
    "next": "202001002"
  },
  {
    "id": 202001002,
    "cnWords": "录音里说的——他们真的动手了。Zack，里面怎么样？",
    "cnSpeaker": "艾玛·奥马利",
    "next": "202001003"
  },
  {
    "id": 202001003,
    "cnWords": "里面有一个人......烧得完全认不出来。他们放的火——跟Webb一样，跟Jimmy一样。名单上的人......一个一个消失。",
    "cnSpeaker": "扎克·布伦南",
    "next": "202001004"
  },
  {
    "id": 202001004,
    "cnWords": "Zack......你有没有看到Margaret？",
    "cnSpeaker": "艾玛·奥马利",
    "next": "202001005"
  },
  {
    "id": 202001005,
    "cnWords": "就那一个人。烧得什么都看不出来......但是有什么不对——手上没有戒指，地上也没有......我说不上来。",
    "cnSpeaker": "扎克·布伦南",
    "next": "202001006"
  },
  {
    "id": 202001006,
    "cnWords": "Zack，听我说。如果录音是真的，他们能对你母亲动手——我们也不安全。我们现在必须冷静。",
    "cnSpeaker": "艾玛·奥马利",
    "next": "202001007"
  },
  {
    "id": 202001007,
    "cnWords": "你谁？这是警方封锁的现场——没有允许不准进去。你刚从里面出来的？",
    "cnSpeaker": "莫里森",
    "next": "202001008"
  },
  {
    "id": 202001008,
    "cnWords": "你是Morrison？蓝月亮酒吧那个Morrison警探？",
    "cnSpeaker": "扎克·布伦南",
    "next": "202001009"
  },
  {
    "id": 202001009,
    "cnWords": "Brennan......私家侦探。你怎么比我到得还早？这是你母亲的店？难怪你不要命往里冲。行了——里面的人大概率就是店主，我的人已经处理了。你可以走了。",
    "cnSpeaker": "莫里森",
    "next": "202001100"
  },
  {
    "id": 202001100,
    "cnWords": "Zack——",
    "cnSpeaker": "艾玛·奥马利",
    "script": "branches",
    "ParameterStr2": "真专业，警探。",
    "ParameterStr0": "你再说一遍。",
    "ParameterStr1": "'大概率'？",
    "ParameterInt2": 202001103,
    "ParameterInt0": 202001101,
    "ParameterInt1": 202001102
  },
  {
    "id": 202001101,
    "cnWords": "我母亲可能死在里面——你连验都没验就说'大概率'？你对着那具尸体再说一遍！",
    "cnSpeaker": "扎克·布伦南",
    "next": "202001011"
  },
  {
    "id": 202001102,
    "cnWords": "一具烧焦的尸体，你连身份都没确认就急着结案。蓝月亮那起案子你也是这么办的？",
    "cnSpeaker": "扎克·布伦南",
    "next": "202001011"
  },
  {
    "id": 202001103,
    "cnWords": "了不起——人还没认完，案子就结完了。难怪南区的案子一个也破不了。",
    "cnSpeaker": "扎克·布伦南",
    "next": "202001011"
  },
  {
    "id": 202001011,
    "cnWords": "店主登记是Margaret Brennan。尸体在一楼店面发现的，打烊时间。不是店主是谁？——Brennan，我理解你的心情，但这里是警方的管辖范围。回去等通知。",
    "cnSpeaker": "莫里森",
    "next": "202001012"
  },
  {
    "id": 202001012,
    "cnWords": "Zack，别跟他起冲突。你进去之前我跟他聊过——他就说了句'又是个倒霉的穷人家着火'，连正式的调查程序都没启动。这个人不会帮我们。",
    "cnSpeaker": "艾玛·奥马利",
    "next": "202001013"
  },
  {
    "id": 202001013,
    "cnWords": "还有——消防员初步判断起火点在一楼。但地下室的烧损反而没那么严重。如果是意外走火，不会是这个烧法。",
    "cnSpeaker": "艾玛·奥马利",
    "next": "202001014"
  },
  {
    "id": 202001014,
    "cnWords": "我已经联系了Foster来做尸检。我们需要的是事实——不是Morrison的一面之词，也不是我们的猜测。",
    "cnSpeaker": "艾玛·奥马利",
    "next": "202001015"
  },
  {
    "id": 202001015,
    "cnWords": "你说得对。不管里面那个人是谁——这件事我查到底。",
    "cnSpeaker": "扎克·布伦南",
    "script": "end"
  }
]