[
  {
    "id": 204001001,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "扎克，Foster那边有消息了。",
    "next": "204001002"
  },
  {
    "id": 204001002,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "怎么说？",
    "next": "204001003"
  },
  {
    "id": 204001003,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "……先说一件事。尸体烧得非常严重，Foster说光看外观，连性别都分辨不了。Morrison那套\"凭直觉判断\"的说辞，根本站不住脚。",
    "next": "204001004"
  },
  {
    "id": 204001004,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "",
    "next": "204001101/204001201",
    "script": "branches",
    "ParameterStr0": "死者到底是不是她？",
    "ParameterInt0": 204001101,
    "ParameterStr1": "火灾是怎么回事？是意外还是纵火？",
    "ParameterInt1": 204001201
  },
  {
    "id": 204001101,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "Foster做了初步的骨骼分析。他说……骨骼结构不像女性。",
    "next": "204001102"
  },
  {
    "id": 204001102,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……什么意思？",
    "next": "204001103"
  },
  {
    "id": 204001103,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "他的原话是\"可能是男性\"。但他也强调了，只是初步分析，正式的尸检报告最快明天才能完成。现在没有任何正式结论。",
    "next": "204001104"
  },
  {
    "id": 204001104,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……可能是男性？那就是说……那个人可能不是——",
    "next": "204001105"
  },
  {
    "id": 204001105,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "扎克，我知道你在想什么。但Foster说得很清楚——这只是初步分析，不是定论。在报告出来之前，我们不能下任何结论。",
    "next": "204001106",
    "script": "get",
    "ParameterInt0": 2021001
  },
  {
    "id": 204001106,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……我明白。但如果连性别都可能搞错，那Morrison凭什么一口咬定死者就是我母亲？",
    "next": "204001107"
  },
  {
    "id": 204001107,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "这就是问题所在。他要么根本没查过就下了结论，要么他知道些什么却不说。无论哪种，他的话都不能信。",
    "next": "204001300"
  },
  {
    "id": 204001201,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "Foster在电话里也提到了起火点的情况。他判断起火点在一楼店面中央。",
    "next": "204001202"
  },
  {
    "id": 204001202,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "一楼店面中央？Morrison说的是\"电线老化\"。",
    "next": "204001203"
  },
  {
    "id": 204001203,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "电线老化的话，起火点通常在墙面线路附近，不会在房间正中央。Morrison那个说法完全对不上。",
    "next": "204001204"
  },
  {
    "id": 204001204,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "那地下室呢？",
    "next": "204001205"
  },
  {
    "id": 204001205,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "Foster说地下室的烧损程度比一楼轻很多。火是从上面往下烧的，地下室不是起火点。",
    "next": "204001206",
    "script": "get",
    "ParameterInt0": 2021002
  },
  {
    "id": 204001206,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "所以火是在一楼中间烧起来的，不是电线短路，地下室反而烧得不严重……",
    "next": "204001207"
  },
  {
    "id": 204001207,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "至少可以确定一件事——Morrison的\"电线老化意外起火\"，连基本现场都没看过就下了结论。",
    "next": "204001300"
  },
  {
    "id": 204001300,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "扎克，Foster明天才能出完整报告。但现在我们手上已经有足够的理由去质疑Morrison了——他的每一句话都经不起推敲。",
    "next": "204001301"
  },
  {
    "id": 204001301,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……他到底在隐瞒什么。",
    "next": "204001302"
  },
  {
    "id": 204001302,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "不管他在隐瞒什么，我们去问他。带上你搜到的东西——他拿不出证据来支持自己的说法，我们就逼他拿出来。",
    "script": "end"
  }
]