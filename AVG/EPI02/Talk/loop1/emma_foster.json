[
  {
    "id": 202101001,
    "cnWords": "Emma，Foster那边有什么消息吗？",
    "cnSpeaker": "扎克·布伦南",
    "next": "202101002"
  },
  {
    "id": 202101002,
    "cnWords": "Foster刚打来电话。消息不太好——也不太坏。",
    "cnSpeaker": "艾玛·奥马利",
    "next": "202101003"
  },
  {
    "id": 202101003,
    "cnWords": "别卖关子了，说。",
    "cnSpeaker": "扎克·布伦南",
    "next": "202101004"
  },
  {
    "id": 202101004,
    "cnWords": "完整的尸检报告需要明天才能出来。尸体烧损太严重，目前连性别都无法确定。",
    "cnSpeaker": "艾玛·奥马利",
    "next": "202101005"
  },
  {
    "id": 202101005,
    "cnWords": "Foster原话：'别急着下结论，这具尸体藏着不少秘密。'",
    "cnSpeaker": "艾玛·奥马利",
    "script": "get",
    "next": "202101006",
    "ParameterInt0": 2021001
  },
  {
    "id": 202101006,
    "cnWords": "连性别都确认不了？那Morrison说死者是我母亲，根本就是信口开河。",
    "cnSpeaker": "扎克·布伦南",
    "next": "202101007"
  },
  {
    "id": 202101007,
    "cnWords": "还有一件事——Foster说从骨骼结构初步判断，死者更像是一位年长的男性。",
    "cnSpeaker": "艾玛·奥马利",
    "next": "202101008"
  },
  {
    "id": 202101008,
    "cnWords": "男性？......那就不是我母亲。但——那个人是谁？我母亲又在哪？",
    "cnSpeaker": "扎克·布伦南",
    "next": "202101009"
  },
  {
    "id": 202101009,
    "cnWords": "至少我们知道了一件事——Morrison在撒谎，或者他根本没认真查过。",
    "cnSpeaker": "艾玛·奥马利",
    "next": "202101010"
  },
  {
    "id": 202101010,
    "cnWords": "Foster还发现了什么？",
    "cnSpeaker": "扎克·布伦南",
    "script": "branches",
    "ParameterStr2": "Foster还说了什么",
    "ParameterStr0": "还有什么发现",
    "ParameterStr1": "起火原因呢",
    "ParameterInt2": 202101300,
    "ParameterInt0": 202101100,
    "ParameterInt1": 202101200
  },
  {
    "id": 202101100,
    "cnWords": "除了性别判断，尸体上还有什么发现？",
    "cnSpeaker": "扎克·布伦南",
    "next": "202101101"
  },
  {
    "id": 202101101,
    "cnWords": "头骨后部有钝器击打的痕迹。Foster认为死者在火灾发生之前就已经遭到了袭击。",
    "cnSpeaker": "艾玛·奥马利",
    "next": "202101102"
  },
  {
    "id": 202101102,
    "cnWords": "先杀人，再放火。这根本不是什么意外火灾——是谋杀。",
    "cnSpeaker": "扎克·布伦南",
    "next": "202101103"
  },
  {
    "id": 202101103,
    "cnWords": "Foster也是这么想的。而Morrison连现场勘察都没做完就想结案——这不正常。",
    "cnSpeaker": "艾玛·奥马利",
    "next": "202101400"
  },
  {
    "id": 202101200,
    "cnWords": "起火原因查清了吗？意外还是人为？",
    "cnSpeaker": "扎克·布伦南",
    "next": "202101201"
  },
  {
    "id": 202101201,
    "cnWords": "Foster说起火点在一楼店面，地下室反而烧损较轻——呈现典型的人为纵火特征。",
    "cnSpeaker": "艾玛·奥马利",
    "next": "202101202"
  },
  {
    "id": 202101202,
    "cnWords": "如果是普通火灾，火势会自下而上蔓延。但这次明显是从一楼向外扩散，地下室被刻意避开了。",
    "cnSpeaker": "艾玛·奥马利",
    "script": "get",
    "next": "202101203",
    "ParameterInt0": 2021002
  },
  {
    "id": 202101203,
    "cnWords": "纵火，谋杀，嫁祸。有人精心策划了一切。",
    "cnSpeaker": "扎克·布伦南",
    "next": "202101400"
  },
  {
    "id": 202101300,
    "cnWords": "Foster这个人靠得住吗？他为什么愿意帮我们？",
    "cnSpeaker": "扎克·布伦南",
    "next": "202101301"
  },
  {
    "id": 202101301,
    "cnWords": "Foster是芝加哥最好的法医之一。他父亲1912年在港口事故中丧生——那些资本家一分钱赔偿都没给过。",
    "cnSpeaker": "艾玛·奥马利",
    "next": "202101302"
  },
  {
    "id": 202101302,
    "cnWords": "他说过一句话——那些资本家到现在还在用同样的手段欺压穷人。所以但凡涉及权贵作恶的案子，他都不会袖手旁观。",
    "cnSpeaker": "艾玛·奥马利",
    "script": "get",
    "next": "202101303",
    "ParameterInt0": 2021003
  },
  {
    "id": 202101303,
    "cnWords": "......和权贵作对的人，在这座城市活不长。但至少他有原则。",
    "cnSpeaker": "扎克·布伦南",
    "next": "202101400"
  },
  {
    "id": 202101400,
    "cnWords": "总结一下：Morrison要么在撒谎，要么草率到连基本核实都没做。死者身份成疑，你母亲可能还活着。",
    "cnSpeaker": "艾玛·奥马利",
    "next": "202101401"
  },
  {
    "id": 202101401,
    "cnWords": "我们已经有足够的筹码去跟Morrison摊牌了。",
    "cnSpeaker": "扎克·布伦南",
    "next": "202101402"
  },
  {
    "id": 202101402,
    "cnWords": "小心点，Zack。Morrison不只是个懒警察——上次在蓝月亮，他差点毁了你。",
    "cnSpeaker": "艾玛·奥马利",
    "next": "202101403"
  },
  {
    "id": 202101403,
    "cnWords": "上次是他算计我。这次——轮到我了。",
    "cnSpeaker": "扎克·布伦南",
    "script": "end"
  }
]