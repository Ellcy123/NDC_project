[
  {
    "id": 210002001,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "扎克！怎么样了？",
    "next": "210002002"
  },
  {
    "id": 210002002,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……",
    "next": "210002003"
  },
  {
    "id": 210002003,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "扎克，你在发抖。发生什么了？",
    "next": "210002004"
  },
  {
    "id": 210002004,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Morrison承认了。他故意误导我，让我以为我母亲死了。",
    "next": "210002005"
  },
  {
    "id": 210002005,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "什么？！他——那个混蛋怎么能——",
    "next": "210002006"
  },
  {
    "id": 210002006,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "死者不是我母亲。是一个叫Frank Kowalski的退休工人，73岁。Morrison一早就查了钱包，知道身份，但故意瞒着我。",
    "next": "210002007"
  },
  {
    "id": 210002007,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "……他为什么要这么做？",
    "next": "210002008"
  },
  {
    "id": 210002008,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "蓝月亮的事。我揭发了他栽赃陷害的把戏，他一直记恨。这次碰上了，正好报复。",
    "next": "210002009"
  },
  {
    "id": 210002009,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "因为私怨就拿一条人命和你母亲的安危做筹码……",
    "next": "210002010"
  },
  {
    "id": 210002010,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "还有一件事。Morrison说火灾当天早上，他收到了匿名电话——有人警告他\"不要多管Margaret Brennan的事\"。",
    "next": "210002011"
  },
  {
    "id": 210002011,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "……有人在针对你母亲。",
    "next": "210002012"
  },
  {
    "id": 210002012,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Morrison乐得配合。匿名电话让他不想管，私怨让他想报复——两件事撞到一起，他就编了个\"死者是Margaret\"来草率结案。",
    "next": "210002013"
  },
  {
    "id": 210002013,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "那Morrison会帮忙找你母亲吗？",
    "next": "210002014"
  },
  {
    "id": 210002014,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "他提了一个\"交易\"。让我查清Frank的死因，给他一个能写进结案报告的答案——意外火灾、失足跌倒，什么都行。他不在意真相。",
    "next": "210002015"
  },
  {
    "id": 210002015,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "他要你帮他编造结案理由？",
    "next": "210002016"
  },
  {
    "id": 210002016,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "他说如果我不配合，他就拖着命案不结，不去找我母亲。",
    "next": "210002017"
  },
  {
    "id": 210002017,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "扎克，你打算怎么办？",
    "next": "210002018"
  },
  {
    "id": 210002018,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "我会查Frank Kowalski的案子。",
    "next": "210002019"
  },
  {
    "id": 210002019,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "……是为了Morrison的交易？",
    "next": "210002020"
  },
  {
    "id": 210002020,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "不。Frank Kowalski，73岁，退休工人——他死在我母亲的鞋坊里，这不是巧合。如果我想找到母亲，就得先弄清楚Frank为什么死在那里。",
    "next": "210002021"
  },
  {
    "id": 210002021,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "而且……他值得真相。一个七十三岁的老人不该被随便编个理由草草结案。Morrison想要什么\"方便的答案\"，那是他的事。我查的是真相。",
    "next": "210002022"
  },
  {
    "id": 210002022,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "好。那我们从哪里开始？",
    "next": "210002023"
  },
  {
    "id": 210002023,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Frank的生前情况。他是谁，住在哪，为什么会出现在我母亲的鞋坊。邻居、家人、任何认识他的人——我需要从头了解这个人。",
    "next": "210002024"
  },
  {
    "id": 210002024,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "我去打听。退休工人，南区，73岁——应该有不少邻居认识他。",
    "next": "210002025"
  },
  {
    "id": 210002025,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "谢谢你，Emma。",
    "next": "210002026"
  },
  {
    "id": 210002026,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "我们会找到你母亲的，扎克。也会给Frank一个公正的结局。",
    "script": "end"
  }
]