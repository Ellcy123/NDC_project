    "cnSpeaker": "扎克·布伦南",
    "enSpeaker": "Zack Brennan",
    "Location": "",
    "cnAction": "",
    "cnWords": "他在银行那边的事——你平时了解多少？",
    "enAction": "",
    "enWords": "",
    "next": "214006031",
    "script": "",
    "ParameterStr0": "",
