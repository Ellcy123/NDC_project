    "IdSpeaker": "NPC214",
    "cnSpeaker": "伊迪丝",
    "enSpeaker": "Edith Ross",
    "Location": "",
    "cnAction": "轻哼了一声，回答得理直气壮，甚至带着点炫耀",
    "cnWords": "既然您非要问……那天晚上，我要去听歌剧。",
    "enAction": "",
    "enWords": "",
    "next": "214006029",
    "script": "",
    "ParameterStr0": "",
    "ParameterStr1": "",
    "ParameterStr2": "",
    "ParameterInt0": 0,
    "ParameterInt1": 0,
