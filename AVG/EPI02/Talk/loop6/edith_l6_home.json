    "cnSpeaker": "扎克·布伦南",
    "enSpeaker": "Zack Brennan",
    "Location": "",
    "cnAction": "",
    "cnWords": "Frank Kowalski——你知道这个人吗？",
    "enAction": "",
    "enWords": "",
    "next": "214006034",
    "script": "",
    "ParameterStr0": "",
    "ParameterStr1": "",
