    "cnWords": "",
    "next": "201005101/201005201",
    "script": "branches",
    "ParameterStr0": "Frank出门前有没有说什么",
    "ParameterInt0": 201005101,
    "ParameterStr1": "那天晚上还有别的异常吗",
    "ParameterInt1": 201005201
  },
  {
    "id": 201005101,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "他说……\"今天做完这件事，我们就可以离开了。\"",
    "next": "201005102"
  },
  {
    "id": 201005102,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "他让我在地下室等他。说最多两个小时就回来。",
    "next": "201005300"
  },
  {
    "id": 201005201,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "八点之前一切正常。八点左右，楼上突然有声音——像是有人在争吵。我没上去。Frank叮嘱过我不要出来。",
    "next": "201005300"
  },
  {
    "id": 201005300,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "他做到了。十二个受害者的证据……他为了他们所有人。",
    "next": "201005301"
  },
  {
    "id": 201005301,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……他是个勇敢的人。",
