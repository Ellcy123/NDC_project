[
  {
    "id": 217001001,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "Zack，医院打来电话——你母亲醒了。",
    "next": "217001002"
  },
  {
    "id": 217001002,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……什么？",
    "next": "217001003"
  },
  {
    "id": 217001003,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "医生说她恢复得不错，可以交谈了。走吧。",
    "next": "217001004"
  },
  {
    "id": 217001004,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "妈……",
    "next": "217001005"
  },
  {
    "id": 217001005,
    "cnSpeaker": "玛格丽特",
    "cnWords": "Zack……我的孩子……",
    "next": "217001006"
  },
  {
    "id": 217001006,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你安全了，妈。一切都结束了。",
    "next": "217001007"
  },
  {
    "id": 217001007,
    "cnSpeaker": "玛格丽特",
    "cnWords": "没有结束……那天晚上……我必须告诉你。",
    "next": "217001008"
  },
  {
    "id": 217001008,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "11月6号？",
    "next": "217001009"
  },
  {
    "id": 217001009,
    "cnSpeaker": "玛格丽特",
    "cnWords": "我大概八点出去买东西……八点二十左右回来。走到街角的时候，看到一个男人从鞋坊方向匆匆走出来。",
    "next": "217001010"
  },
  {
    "id": 217001010,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "什么样的人？",
    "next": "217001011"
  },
  {
    "id": 217001011,
    "cnSpeaker": "玛格丽特",
    "cnWords": "戴眼镜……穿西装……走路踉踉跄跄的，像看不清路。",
    "next": "217001012"
  },
  {
    "id": 217001012,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "然后呢？",
    "next": "217001013"
  },
  {
    "id": 217001013,
    "cnSpeaker": "玛格丽特",
    "cnWords": "我进了门……Frank倒在店铺区地上，头上流了好多血……",
    "next": "217001014"
  },
  {
    "id": 217001014,
    "cnSpeaker": "玛格丽特",
    "cnWords": "我想检查他的伤……然后……有人从背后打晕了我。之后就什么都不记得了。",
    "next": "217001015"
  },
  {
    "id": 217001015,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……",
    "next": "217001016"
  },
  {
    "id": 217001016,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "Zack……回来。",
    "next": "217001017"
  },
  {
    "id": 217001017,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "我没事。——妈，好好休息。我会找到那个人的。",
    "next": "217001018"
  },
  {
    "id": 217001018,
    "cnSpeaker": "玛格丽特",
    "cnWords": "小心，Zack。",
    "next": "217001019"
  },
  {
    "id": 217001019,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "戴眼镜，穿西装，走路踉跄——像是眼镜摔坏了看不清路。",
    "next": "217001020"
  },
  {
    "id": 217001020,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Leonard。",
    "next": "217001021"
  },
  {
    "id": 217001021,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "如果能在鞋坊废墟找到物证，加上Margaret的证词，就够申请搜查令了。",
    "next": "217001022"
  },
  {
    "id": 217001022,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "先去鞋坊。",
    "script": "end"
  }
]