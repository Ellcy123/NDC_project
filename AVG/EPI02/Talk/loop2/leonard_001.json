  },
  {
    "id": 209001300,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "",
    "next": "209001401/209001501",
    "script": "branches",
    "ParameterStr0": "Frank是个什么样的人？",
    "ParameterInt0": 209001401,
    "ParameterStr1": "有个叫Vinnie Moretti的人，你认识吗？",
    "ParameterInt1": 209001501
  },
  {
    "id": 209001401,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "Frank是个可怜的老人。退休工人，腿不太好。来借钱的时候，说是赌博输了——很多老人晚年都有这个问题。",
    "next": "209001402"
  },
  {
    "id": 209001402,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你就信了？",
    "next": "209001403"
  },
  {
    "id": 209001403,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "银行不是法官，Brennan先生。客户说什么用途，我们就记什么用途。他签了字，合同生效。",
    "next": "209001404"
  },
  {
    "id": 209001404,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "换个问题——有个叫Vinnie Moretti的人。你认识吗？",
    "next": "209001501"
  },
  {
    "id": 209001501,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "Vinnie Moretti？",
    "next": "209001502"
  },
  {
    "id": 209001502,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "对。意大利壮汉。在Silver Moon酒吧混的。",
    "next": "209001503"
  },
  {
    "id": 209001503,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "抱歉，我不认识这个人。这个名字——Moretti？银行的客户名单里没有这个姓氏。",
    "next": "209001504",
    "script": "get",
    "ParameterInt0": 2041001
  },
  {
    "id": 209001504,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……好。那我就不打扰了。",
    "next": "209001505"
  },
  {
    "id": 209001505,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "如果需要查看Frank的贷款档案，请通过正式渠道——Moore先生那边可以安排。当然，需要法院令状。",
    "next": "209001506"
  },
  {
    "id": 209001506,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "法院令状。你们都这么说。",
    "next": "209001507"
  },
  {
    "id": 209001507,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "银行有银行的规矩，Brennan先生。祝你调查顺利。",
