[
  {
    "id": 209001001,
    "cnSpeaker": "旁白",
    "cnWords": "银行大厅。大理石地面，黄铜柜台栅栏。午后阳光从高窗照进来。一个金发年轻人站在柜台后面整理文件。",
    "next": "209001002"
  },
  {
    "id": 209001002,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Leonard Ross？",
    "next": "209001003"
  },
  {
    "id": 209001003,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "是的，有什么可以帮您？",
    "next": "209001004"
  },
  {
    "id": 209001004,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Zack Brennan，私家侦探。我在调查你经手的一个客户——Frank Kowalski。",
    "next": "209001005"
  },
  {
    "id": 209001005,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "Kowalski先生……是的，我知道这个名字。很遗憾听说他出了事。请问具体需要了解什么？",
    "next": "209001006"
  },
  {
    "id": 209001006,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Frank欠银行三千两百美元。你签的催款单。",
    "next": "209001007"
  },
  {
    "id": 209001007,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "这是银行的正常业务流程。Kowalski先生的贷款确实存在逾期。我们按规定发了催款通知。",
    "next": "209001008"
  },
  {
    "id": 209001008,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "他借了六百，怎么变成三千二？",
    "next": "209001009"
  },
  {
    "id": 209001009,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "利息、滞纳金、管理费。合同里都写得很清楚。Kowalski先生签字的时候，每一项都有向他解释过。",
    "next": "209001010"
  },
  {
    "id": 209001010,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你亲自向他解释的？",
    "next": "209001011"
  },
  {
    "id": 209001011,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "贷款业务都由我经手。这是我的工作职责。",
    "next": "209001012"
  },
  {
    "id": 209001012,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "Brennan先生，您说在调查Kowalski的事——他住在鞋坊附近对吧？那家鞋坊在哪条街来着？",
    "next": "209001013"
  },
  {
    "id": 209001013,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "",
    "next": "209001101/209001201/209001201",
    "script": "branches",
    "ParameterStr0": "南区33号。",
    "ParameterInt0": 209001101,
    "ParameterStr1": "南区15街。",
    "ParameterInt1": 209001201,
    "ParameterStr2": "湖边大道。",
    "ParameterInt2": 209001201
  },
  {
    "id": 209001101,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "没错。南区33号。",
    "next": "209001102"
  },
  {
    "id": 209001102,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "看来您确实在认真调查。",
    "next": "209001300"
  },
  {
    "id": 209001201,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……不太对。不过没关系。",
    "next": "209001202"
  },
  {
    "id": 209001202,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……",
