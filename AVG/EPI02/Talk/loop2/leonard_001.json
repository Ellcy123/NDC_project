[
  {
    "id": 204001001,
    "cnWords": "Leonard Ross？我叫Zack Brennan，私家侦探。想问你几个关于Frank Kowalski的问题。",
    "cnSpeaker": "扎克·布伦南",
    "next": "204001002"
  },
  {
    "id": 204001002,
    "cnWords": "私家侦探？请坐。Kowalski的事我听说了——那场火灾的消息传遍了整条街。非常不幸。有什么我能帮忙的？",
    "cnSpeaker": "莱昂纳德·罗斯",
    "next": "204001003"
  },
  {
    "id": 204001003,
    "cnWords": "Frank在你们银行有一笔贷款。你负责他的案子？",
    "cnSpeaker": "扎克·布伦南",
    "next": "204001004"
  },
  {
    "id": 204001004,
    "cnWords": "是的。最初是六百美元的个人贷款。遗憾的是，Kowalski先生在还款方面一直有困难。这种情况在南区并不少见。",
    "cnSpeaker": "莱昂纳德·罗斯",
    "next": "204001005"
  },
  {
    "id": 204001005,
    "cnWords": "你在这家银行工作多久了，Ross先生？",
    "cnSpeaker": "扎克·布伦南",
    "next": "204001006"
  },
  {
    "id": 204001006,
    "cnWords": "今年春天满十年。我负责南区的贷款催收业务——说起来不好听，但总得有人做这份工作。",
    "cnSpeaker": "莱昂纳德·罗斯",
    "script": "get",
    "next": "204001007",
    "ParameterInt0": 2041003
  },
  {
    "id": 204001007,
    "cnWords": "Ross先生，你认识一个叫Vinnie Moretti的人吗？",
    "cnSpeaker": "扎克·布伦南",
    "next": "204001008"
  },
  {
    "id": 204001008,
    "cnWords": "Vinnie Moretti？不认识。Kowalski先生的欠款跟赌博有关——他经常出入一些不太体面的场所。至于催收，我们完全按银行的标准流程办事。",
    "cnSpeaker": "莱昂纳德·罗斯",
    "script": "get",
    "next": "204001009",
    "ParameterInt0": 2041001
  },
  {
    "id": 204001009,
    "cnWords": "标准流程。没有恐吓，没有威胁？",
    "cnSpeaker": "扎克·布伦南",
    "next": "204001010"
  },
  {
    "id": 204001010,
    "cnWords": "Brennan先生，这是银行，不是后巷。我们发催款信，约客户面谈，协商还款计划。如果客户实在无力偿还，我们走法律途径。仅此而已。你还想知道什么？",
    "cnSpeaker": "莱昂纳德·罗斯",
    "script": "branches",
    "ParameterStr0": "查案：Frank的还款记录",
    "ParameterStr1": "查案：催收流程的细节",
    "ParameterInt0": 204001100,
    "ParameterInt1": 204001200
  },
  {
    "id": 204001100,
    "cnWords": "Frank的还款记录——他最后一次来银行是什么时候？",
    "cnSpeaker": "扎克·布伦南",
    "next": "204001101"
  },
  {
    "id": 204001101,
    "cnWords": "客户的具体财务信息属于银行机密。我能告诉你的是——他大约两周前来过一次，还了一小笔利息。至于更详细的......你需要法院令状。",
    "cnSpeaker": "莱昂纳德·罗斯",
    "next": "204001400"
  },
  {
    "id": 204001200,
    "cnWords": "如果客户长期不还款——比如好几个月——你们会怎么处理？",
    "cnSpeaker": "扎克·布伦南",
    "next": "204001201"
  },
  {
    "id": 204001201,
    "cnWords": "书面通知，面谈，协商还款计划。如果协商不成，我们走法律途径。一切都有据可查。",
    "cnSpeaker": "莱昂纳德·罗斯",
    "next": "204001202"
  },
  {
    "id": 204001202,
    "cnWords": "法律途径。有没有更......直接的手段？",
    "cnSpeaker": "扎克·布伦南",
    "next": "204001203"
  },
  {
    "id": 204001203,
    "cnWords": "Brennan先生。如果你在暗示什么，我建议你直说。含沙射影不是好习惯——尤其是对一个你没有任何证据的人。",
    "cnSpeaker": "莱昂纳德·罗斯",
    "next": "204001400"
  },
  {
    "id": 204001400,
    "cnWords": "谢谢你的时间，Ross先生。我可能还会再来。",
    "cnSpeaker": "扎克·布伦南",
    "next": "204001401"
  },
  {
    "id": 204001401,
    "cnWords": "随时欢迎。不过下次——请带上你的令状。",
    "cnSpeaker": "莱昂纳德·罗斯",
    "script": "end"
  }
]