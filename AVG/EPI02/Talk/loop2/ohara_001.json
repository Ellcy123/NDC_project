[
  {
    "id": 206001001,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "你找谁？",
    "next": "206001002"
  },
  {
    "id": 206001002,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Zack Brennan，私家侦探。我在调查你的邻居Frank Kowalski的事。",
    "next": "206001003"
  },
  {
    "id": 206001003,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "Frank……Frank已经不在了。你来迟了。",
    "next": "206001004"
  },
  {
    "id": 206001004,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "我知道。我想了解一下Frank生前的情况——你是他的邻居？",
    "next": "206001005"
  },
  {
    "id": 206001005,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "快十年的邻居了。但我不想惹麻烦，侦探先生。",
    "next": "206001006"
  },
  {
    "id": 206001006,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "我不会给你添麻烦。就聊两句。",
    "next": "206001007"
  },
  {
    "id": 206001007,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "",
    "next": "206001101/206001201",
    "script": "branches",
    "ParameterStr0": "Frank最近是不是遇到什么困难了？",
    "ParameterInt0": 206001101,
    "ParameterStr1": "门口这些东西是Frank的？",
    "ParameterInt1": 206001201
  },
  {
    "id": 206001101,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "困难？哪里只是困难。他欠了银行的钱，还不上。整天有人来要。",
    "next": "206001102"
  },
  {
    "id": 206001102,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "什么人来要钱？",
    "next": "206001103"
  },
  {
    "id": 206001103,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "你别问我这个。我不想跟那些人扯上关系。",
    "next": "206001104"
  },
  {
    "id": 206001104,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "理解。Frank人怎么样？",
    "next": "206001105"
  },
  {
    "id": 206001105,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "老实人。腿不好——很早以前在港口受的伤。但是个勤快人，从不欠邻居人情。",
    "next": "206001106"
  },
  {
    "id": 206001106,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "我只告诉你这些——Frank欠了银行的钱，被人催过债。那帮人不是善茬。你自己小心。",
    "next": "206001300",
    "script": "get",
    "ParameterInt0": 2091001
  },
  {
    "id": 206001201,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "这封信……湖滨信托银行的催款单。这是Frank的。",
    "next": "206001202"
  },
  {
    "id": 206001202,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "我帮他收着的。他都不在了，信还在来。",
    "next": "206001203"
  },
  {
    "id": 206001203,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Frank欠银行多少钱，你知道吗？",
    "next": "206001204"
  },
  {
    "id": 206001204,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "不清楚。只知道不少。他提过一嘴，说利息越来越高，还也还不完。",
    "next": "206001205"
  },
  {
    "id": 206001205,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "门口牛奶都没人收。Frank是一个人住？",
    "next": "206001206"
  },
  {
    "id": 206001206,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "一个人。他欠了银行钱，被人催过债。那帮人不好惹。你要是聪明，就别去招惹他们。",
    "next": "206001300",
