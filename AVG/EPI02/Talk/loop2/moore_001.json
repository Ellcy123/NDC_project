[
  {
    "id": 208001001,
    "cnSpeaker": "旁白",
    "cnWords": "Moore银行贵宾室。深色木质装潢，窗户半开，百叶窗投下条纹阴影。墙上挂着银行创始人油画。",
    "next": "208001002"
  },
  {
    "id": 208001002,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Moore先生？",
    "next": "208001003"
  },
  {
    "id": 208001003,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "你是？",
    "next": "208001004"
  },
  {
    "id": 208001004,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Zack Brennan，私家侦探。关于你的客户Frank Kowalski——",
    "next": "208001005"
  },
  {
    "id": 208001005,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "坐。Kowalski的事我知道一些。可怜的老人。但银行有银行的规矩。",
    "next": "208001006"
  },
  {
    "id": 208001006,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Frank欠你们多少钱？",
    "next": "208001007"
  },
  {
    "id": 208001007,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "Kowalski先生有一笔贷款。贷款用途写的是——偿还赌博债务。目前的欠款总额是三千二百美元。合同上白纸黑字。",
    "next": "208001008",
    "script": "get",
    "ParameterInt0": 2061001
  },
  {
    "id": 208001008,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "三千二……一个鞋匠欠银行三千二。原始贷款是多少？",
    "next": "208001009"
  },
  {
    "id": 208001009,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "贷款明细属于客户隐私。我能告诉你的是——利息按合同约定利率计算，逾期有滞纳金。一切在法律允许的范围内。",
    "next": "208001010"
  },
  {
    "id": 208001010,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "什么利率？",
    "next": "208001011"
  },
  {
    "id": 208001011,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "年化百分之七。州法规定的上限。我们的合同完全合规。",
    "next": "208001012"
  },
  {
    "id": 208001012,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "百分之七……就算复利算三年，也到不了三千二。这数字不对。",
    "next": "208001013"
  },
  {
    "id": 208001013,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "滞纳金、管理费、手续费。这些都在合同附件里。Kowalski先生签字的时候应该看过。",
    "next": "208001014"
  },
  {
    "id": 208001014,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "他不肯说原始金额，利率声称合规——但三千二的欠款怎么也说不通。这笔账有问题。",
    "next": "208001101/208001201",
    "script": "branches",
    "ParameterStr0": "Leonard Ross是你们银行的人？",
    "ParameterInt0": 208001101,
    "ParameterStr1": "Frank用什么做抵押？",
    "ParameterInt1": 208001201
  },
  {
    "id": 208001101,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "Leonard Ross。我们的贷款业务经理。工作能力很强，在我这儿干了快十年。",
    "next": "208001102"
  },
  {
    "id": 208001102,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Ross……这是他本名？",
    "next": "208001103"
  },
  {
    "id": 208001103,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "他入职的时候提交过合法改名文件。我记得——原来叫什么来着。",
    "next": "208001104"
  },
  {
    "id": 208001104,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "你倒是提醒我了。你是侦探——那你说说，你在调查中有没有听过Leonard的原名？",
    "next": "208001105"
  },
  {
    "id": 208001105,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "",
    "next": "208001301/208001401/208001401",
    "script": "branches",
    "ParameterStr0": "Russo。",
    "ParameterInt0": 208001301,
    "ParameterStr1": "Rossini。",
    "ParameterInt1": 208001401,
    "ParameterStr2": "Romano。",
    "ParameterInt2": 208001401
  },
  {
    "id": 208001301,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "没错。Leonard Russo。他来银行之前改了名。改名手续是合法的——法院有备案。",
    "next": "208001302"
  },
  {
    "id": 208001302,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Vinnie看到照片时脱口而出的那个名字——Russo。就是Leonard的原名。这两个人认识。",
    "next": "208001303"
  },
  {
    "id": 208001303,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "移民后代改名很常见。Russo、Ross——只是换了个拼法。不影响工作能力。",
    "next": "208001500",
    "script": "get",
    "ParameterInt0": 2061002
  },
  {
    "id": 208001401,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "不对。看来你还没查到这一步。",
    "next": "208001402"
  },
  {
    "id": 208001402,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……",
    "next": "208001500"
  },
  {
    "id": 208001201,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "他在南区有一栋房子。老房子了，不值多少钱。但作为抵押品……足够了。",
    "next": "208001202"
  },
  {
    "id": 208001202,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Frank还不上钱的话，你们要收他的房子？",
    "next": "208001203"
  },
  {
    "id": 208001203,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "这是合同条款。抵押贷款，天经地义。",
    "next": "208001204"
  },
  {
    "id": 208001204,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "催款单上签名的是Leonard Ross——你们的贷款经理。",
    "next": "208001205"
  },
  {
    "id": 208001205,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "Leonard Ross。工作能力很强，在这儿干了快十年了。",
    "next": "208001206"
  },
  {
    "id": 208001206,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Ross……这名字挺常见的。这是他本名？",
    "next": "208001207"
  },
  {
    "id": 208001207,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "他入职时提交过改名文件。原来叫——",
    "next": "208001208"
  },
  {
    "id": 208001208,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "等等。你是侦探——你在外面调查的时候，有没有听过Leonard的原名？",
    "next": "208001209"
  },
  {
    "id": 208001209,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "",
    "next": "208001301/208001401/208001401",
    "script": "branches",
    "ParameterStr0": "Russo。",
    "ParameterInt0": 208001301,
    "ParameterStr1": "Rossini。",
    "ParameterInt1": 208001401,
    "ParameterStr2": "Romano。",
    "ParameterInt2": 208001401
  },
  {
    "id": 208001500,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "Brennan先生，我已经尽力配合了。银行的内部文件——客户的贷款明细、利率结构、审批流程——这些受隐私法保护。",
    "next": "208001501"
  },
  {
    "id": 208001501,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "法律保护。明白。",
    "next": "208001502"
  },
  {
    "id": 208001502,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "如果你有法院令状，我们随时配合。没有令状的话——",
    "next": "208001503"
  },
  {
    "id": 208001503,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "我会再来的，Moore先生。带着令状。",
    "next": "208001504"
  },
  {
    "id": 208001504,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "我等着。",
