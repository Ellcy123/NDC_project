[
  {
    "id": 201004001,
    "cnSpeaker": "旁白",
    "cnWords": "Margaret鞋坊一楼。工作台上散落着鞋楦和线轴。一个黑人女性坐在Margaret的缝纫椅上，手里抱着一条旧围巾。",
    "next": "201004002"
  },
  {
    "id": 201004002,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Rose Martinez女士？",
    "next": "201004003"
  },
  {
    "id": 201004003,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "你是来问Frank的事的。",
    "next": "201004004"
  },
  {
    "id": 201004004,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Zack Brennan，私家侦探。我——",
    "next": "201004005"
  },
  {
    "id": 201004005,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "我知道你是谁。邻居说有个侦探在调查Frank的事。我一直在等你来。",
    "next": "201004006"
  },
  {
    "id": 201004006,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你和Frank是什么关系？",
    "next": "201004007"
  },
  {
    "id": 201004007,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "我和Frank相爱五年了。1920年春天，芝加哥县立医院——我是护士，他摔断了腿被送来。住了三个星期。",
    "next": "201004008",
    "script": "get",
    "ParameterInt0": 2081001
  },
  {
    "id": 201004008,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "五年。",
    "next": "201004009"
  },
  {
    "id": 201004009,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "五年。他73岁，波兰裔退休工人。我48岁，墨西哥裔护士。你猜猜这条街上的人怎么看我们。",
    "next": "201004010"
  },
  {
    "id": 201004010,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……",
    "next": "201004011"
  },
  {
    "id": 201004011,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "我们不敢在白天一起出现。邻居会说闲话，Frank怕连累我。所以Margaret把鞋坊地下室借给了我们。",
    "next": "201004012"
  },
  {
    "id": 201004012,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "地下室。",
    "next": "201004013"
  },
  {
    "id": 201004013,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "每周三晚上，每周六下午。五年没断过。Margaret把钥匙给我们，从来不收一分钱。她说——\"你们是我的朋友，我愿意给你们一个安静的地方。\"",
    "next": "201004014",
    "script": "get",
    "ParameterInt0": 2081002
  },
  {
    "id": 201004014,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Danny Kowalski说你是\"大半年前才出现的\"。",
    "next": "201004015"
  },
  {
    "id": 201004015,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "Danny知道我的存在。他搬来跟Frank住以后，有一次在门口看到我。从那以后他就叫我\"那个墨西哥女人\"。",
    "next": "201004016"
  },
  {
    "id": 201004016,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Danny搬来住是什么时候？",
    "next": "201004017"
  },
  {
    "id": 201004017,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "今年年初。他说被厂里裁了，找不到工作。Frank收留了他。",
    "next": "201004018"
  },
  {
    "id": 201004018,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Danny今年才搬来，Rose和Frank已经在一起五年。Danny\"大半年前\"——说的不是Rose出现的时间，是他自己知道Rose的时间。",
    "next": "201004101/201004201",
    "script": "branches",
    "ParameterStr0": "Frank为什么要贷款？",
    "ParameterInt0": 201004101,
    "ParameterStr1": "你知道Frank的遗嘱吗？",
    "ParameterInt1": 201004201
  },
  {
    "id": 201004101,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "他想把地下室修得好一点。地板裂了、窗户漏风、沙发弹簧都断了。",
    "next": "201004102"
  },
  {
    "id": 201004102,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "我说不用修。我说——Frank，我不需要新沙发，我们有彼此就够了。",
    "next": "201004103"
  },
  {
    "id": 201004103,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "我甚至说过：\"Frank，别去那家银行！\"我不信任Moore。但Frank坚持。他说——\"Rose，你值得更好的。\"",
    "next": "201004104",
    "script": "get",
    "ParameterInt0": 2081003
  },
  {
    "id": 201004104,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "六百块。全用在地下室修缮上了。",
    "next": "201004105"
  },
  {
    "id": 201004105,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "他就是那样的人。",
    "next": "201004300"
  },
  {
    "id": 201004201,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "他告诉过我。说把东西留给我。我当时就跟他说——Frank，我不要你的房子。我不要你的任何东西。我要的是你这个人。",
    "next": "201004202"
  },
  {
    "id": 201004202,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "如果有人说我是为了遗产——我现在就可以签一份放弃声明。",
    "next": "201004203"
  },
  {
    "id": 201004203,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……",
    "next": "201004300"
  },
  {
    "id": 201004300,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Rose，Frank——案发那天，11月6号。他有没有什么异常？",
    "next": "201004301"
  },
  {
    "id": 201004301,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "……他那天下午来找过我。说晚上要做一件事。",
    "next": "201004302"
  },
  {
    "id": 201004302,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "什么事？",
    "next": "201004303"
  },
  {
    "id": 201004303,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "他没说具体的。只说——\"很冒险，但必须做。\"",
    "next": "201004304"
  },
  {
    "id": 201004304,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "他看起来害怕吗？",
    "next": "201004305"
  },
  {
    "id": 201004305,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "不。他看起来……下定了决心。像是准备了很久。",
    "next": "201004306"
  },
  {
    "id": 201004306,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "谢谢你，Rose。",
    "script": "end"
  }
]