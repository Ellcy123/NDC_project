[
  {
    "id": 206002001,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "Brennan先生。我听说遗嘱的事了。你来问Rose的？",
    "next": "206002002"
  },
  {
    "id": 206002002,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你认识Rose Martinez？",
    "next": "206002003"
  },
  {
    "id": 206002003,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "认识。不止认识——我看着她跟Frank来来往往四五年了。",
    "next": "206002004"
  },
  {
    "id": 206002004,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "四五年。Danny说Rose是\"大半年前才出现的\"。",
    "next": "206002005"
  },
  {
    "id": 206002005,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "Danny搬来才几个月？他知道个什么。说到Danny——那孩子跟你说了什么？Rose什么时候出现在Frank身边的？",
    "next": "206002006"
  },
  {
    "id": 206002006,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "",
    "next": "206002101/206002201/206002201",
    "script": "branches",
    "ParameterStr0": "大半年前。",
    "ParameterInt0": 206002101,
    "ParameterStr1": "一两年前。",
    "ParameterInt1": 206002201,
    "ParameterStr2": "好几年了。",
    "ParameterInt2": 206002201
  },
  {
    "id": 206002101,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "Danny就是这么说的。\"大半年前\"。",
    "next": "206002102"
  },
  {
    "id": 206002102,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "我告诉你真的。Rose Martinez——我至少四五年前就开始看到她来这条街了。每周固定的日子，从来不张扬。她走路都低着头，怕邻居看到说闲话。",
    "next": "206002300",
    "script": "get",
    "ParameterInt0": 2091003
  },
  {
    "id": 206002201,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "不对。比这久多了。",
    "next": "206002300"
  },
  {
    "id": 206002300,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "邻居们怎么看他们？",
    "next": "206002301"
  },
  {
    "id": 206002301,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "Brennan先生，这条街上的人——你知道的。波兰人、爱尔兰人、一些意大利人。大家都说闲话。\"Frank那么大年纪了，跟一个黑人女人……\"。后来Rose就不再白天来了。只有晚上，走后门。",
    "next": "206002302",
    "script": "get",
    "ParameterInt0": 2091004
  },
  {
    "id": 206002302,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……",
    "next": "206002303"
  },
  {
    "id": 206002303,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "",
    "next": "206002401/206002501",
    "script": "branches",
    "ParameterStr0": "催收的事——上次你没说完",
    "ParameterInt0": 206002401,
    "ParameterStr1": "你怎么看Rose？",
    "ParameterInt1": 206002501
  },
  {
    "id": 206002401,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "上次我没敢说全。现在——Frank都不在了。我还怕什么。",
    "next": "206002402"
  },
  {
    "id": 206002402,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "每次催债都是一样的。先来一个人，客客气气的，穿得像银行职员。\"好心提醒\"你该还钱了。两三天之后——换一个人来。大块头。不敲门，直接拍门框。声音大得整条街都听得到。",
    "next": "206002403",
    "script": "get",
    "ParameterInt0": 2091005
  },
  {
    "id": 206002403,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "我家Sarah看到那个大块头就发抖。每次他来完，Sarah晚上都做噩梦。",
    "next": "206002600"
  },
  {
    "id": 206002501,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "Rose是好人。我当了十年邻居——从来没见Rose问Frank要过什么。每次来都带着食物，帮Frank收拾屋子。Frank笑得像个孩子似的。",
    "next": "206002502"
  },
  {
    "id": 206002502,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "Danny说Rose是骗子。可Danny自己呢？搬来之后从来没见他帮Frank做过一顿饭。",
    "next": "206002600"
  },
  {
    "id": 206002600,
    "cnSpeaker": "莎拉·奥哈拉",
    "cnWords": "Brennan先生。Frank和Rose——他们只是想安安静静地在一起。这有什么错？",
    "next": "206002601"
  },
  {
    "id": 206002601,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "没什么错。谢谢你，O'Hara太太。",
    "script": "end"
  }
]