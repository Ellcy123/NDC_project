[
  {
    "id": 212002001,
    "cnSpeaker": "旁白",
    "cnWords": "Frank家次卧。Danny的床没叠，衣服堆在椅子上。桌上散落着账单和文件。",
    "next": "212002002"
  },
  {
    "id": 212002002,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "你看到遗嘱了？你看到了吧？！",
    "next": "212002003"
  },
  {
    "id": 212002003,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "我看到了。",
    "next": "212002004"
  },
  {
    "id": 212002004,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "我是他唯一的亲人！他的侄子！我从小就叫他Frank叔叔！现在他把什么都给了一个——一个外人！",
    "next": "212002005"
  },
  {
    "id": 212002005,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Rose Martinez。你在L3说她是\"大半年前才出现的\"。",
    "next": "212002006"
  },
  {
    "id": 212002006,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "没错！就是大半年前！我搬来之后才看到她鬼鬼祟祟地出现在门口！",
    "next": "212002007"
  },
  {
    "id": 212002007,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你搬来是今年年初。",
    "next": "212002008"
  },
  {
    "id": 212002008,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "……那又怎么了？",
    "next": "212002009"
  },
  {
    "id": 212002009,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "说说你自己的情况。你什么时候失业的？",
    "next": "212002010"
  },
  {
    "id": 212002010,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "二月份。钢铁厂裁人。我找了好几个月的活——没人要。",
    "next": "212002011"
  },
  {
    "id": 212002011,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "所以你搬来跟叔叔住。",
    "next": "212002012"
  },
  {
    "id": 212002012,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "Frank叔叔让我来的！他说\"这房子反正大，你住着\"。我不是来占便宜的！",
    "next": "212002013"
  },
  {
    "id": 212002013,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "我是他唯一的家人！他的亲侄子！那个女人凭什么继承？她跟Frank又没结婚！遗嘱说\"如果结婚\"——但他们没结婚！所以那些东西应该留给家人——留给我！",
    "next": "212002014",
    "script": "get",
    "ParameterInt0": 2071004
  },
  {
    "id": 212002014,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Danny对遗产的执着比对Frank的死还强烈。",
    "next": "212002101/212002201",
    "script": "branches",
    "ParameterStr0": "你知不知道Frank为什么贷款？",
    "ParameterInt0": 212002101,
    "ParameterStr1": "这栋房子对你来说意味着什么？",
    "ParameterInt1": 212002201
  },
  {
    "id": 212002101,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "赌博！谁都知道Frank爱赌——不对，上次你们不是说不是赌博吗？那就是——那就是被Rose骗的！她肯定让Frank花钱给她买东西！",
    "next": "212002102"
  },
  {
    "id": 212002102,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……",
    "next": "212002300"
  },
  {
    "id": 212002201,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "意味什么？这是我叔叔的房子。我是他的家人。我住在这里天经地义。",
    "next": "212002202"
  },
  {
    "id": 212002202,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你知道南区这片的拆迁规划吗？",
    "next": "212002203"
  },
  {
    "id": 212002203,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "什么拆迁？我不知道什么拆迁。",
    "next": "212002300"
  },
  {
    "id": 212002300,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "Brennan先生，你帮帮我。那个遗嘱——Frank叔叔写那东西的时候一定是被骗了。她操控了他！一个73岁的老人——",
    "next": "212002301"
  },
  {
    "id": 212002301,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "我会查清楚的。",
    "script": "end"
  }
]