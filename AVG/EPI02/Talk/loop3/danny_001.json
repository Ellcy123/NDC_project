[
  {
    "id": 212001001,
    "cnSpeaker": "旁白",
    "cnWords": "Frank家次卧。一张行军床，地上散着几个啤酒瓶。墙角有一个廉价旅行箱，没有完全打开。一个三十多岁的男人坐在床边。",
    "next": "212001002"
  },
  {
    "id": 212001002,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "你是谁？Frank的债主？我跟你说——",
    "next": "212001003"
  },
  {
    "id": 212001003,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Zack Brennan，私家侦探。你是Danny Kowalski？",
    "next": "212001004"
  },
  {
    "id": 212001004,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "侦探……侦探好。你是来查叔叔的事的？",
    "next": "212001005"
  },
  {
    "id": 212001005,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你住在这里？",
    "next": "212001006"
  },
  {
    "id": 212001006,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "叔叔让我住的。我从乡下来芝加哥，一开始是叔叔帮我找的工作。后来工作丢了……就一直住这儿。",
    "next": "212001007"
  },
  {
    "id": 212001007,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "Danny Kowalski。Frank唯一的侄子。他弟弟的儿子。一直住在这儿帮他打理日常。",
    "next": "212001008",
    "script": "get",
    "ParameterInt0": 2071002
  },
  {
    "id": 212001008,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "",
    "next": "212001101/212001402",
    "script": "branches",
    "ParameterStr0": "Frank最近什么情况？",
    "ParameterInt0": 212001101,
    "ParameterStr1": "你认识Rose Martinez吗？",
    "ParameterInt1": 212001402
  },
  {
    "id": 212001101,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "什么情况？一团糟。叔叔不知道从哪借了一笔钱，利滚利翻了好几倍。天天有人来催。",
    "next": "212001102"
  },
  {
    "id": 212001102,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "其实叔叔人挺好的。我刚来的时候欠了点钱，他二话不说帮我垫上了。还总跑到赌场来找我——不是来赌，是拽着我往外走。",
    "next": "212001103"
  },
  {
    "id": 212001103,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "但他管得太多了！我一个成年人，用得着他天天盯着吗？",
    "next": "212001104"
  },
  {
    "id": 212001104,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "催收的人你见过？",
    "next": "212001105"
  },
  {
    "id": 212001105,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "见过见过。那帮人来的时候我都躲在屋里。你说——催收的人长什么样？你见过他们吗？",
    "next": "212001106"
  },
  {
    "id": 212001106,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "",
    "next": "212001301/212001401/212001401",
    "script": "branches",
    "ParameterStr0": "一个金发年轻人带着一个意大利壮汉。",
    "ParameterInt0": 212001301,
    "ParameterStr1": "两个穿制服的银行员工。",
    "ParameterInt1": 212001401,
    "ParameterStr2": "一个戴帽子的中年人，独自来的。",
    "ParameterInt2": 212001401
  },
  {
    "id": 212001301,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "……对。就是他们。金发的那个说话客客气气的，壮的那个站在后面不说话。我透过窗户看到的。",
    "next": "212001302"
  },
  {
    "id": 212001302,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "和O'Hara描述的一致——一个金发年轻人带着一个意大利壮汉。他们催收的模式是固定的。",
    "next": "212001303"
  },
  {
    "id": 212001303,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "那帮人……不会来找我吧？我又没欠银行的钱。",
    "next": "212001304"
  },
  {
    "id": 212001304,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "他们找你干什么？",
    "next": "212001305"
  },
  {
    "id": 212001305,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "没什么没什么。我就是怕。那壮汉看着就不好惹。",
    "next": "212001500"
  },
  {
    "id": 212001401,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "……不是吧。你确定？我记得不是这样的。",
    "next": "212001500"
  },
  {
    "id": 212001402,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "Rose Martinez？！你说那个女人？",
    "next": "212001403"
  },
  {
    "id": 212001403,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "别提她！那个女人就是个——就是个骗子！大半年前不知道从哪儿冒出来的，成天往叔叔那边凑！",
    "next": "212001404"
  },
  {
    "id": 212001404,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "我跟你说，Rose就是最近才勾引叔叔的。大半年前才来这条街上的。一个南区来的——你懂的吧？叔叔七十三了，一辈子老实人，被她迷得五迷三道。",
    "next": "212001405",
    "script": "get",
    "ParameterInt0": 2071001
  },
  {
    "id": 212001405,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你怎么知道是大半年前来的？",
    "next": "212001406"
  },
  {
    "id": 212001406,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "我住在这儿还能不知道？以前从来没见过她。后来突然就出现了，三天两头来。邻居都在说——",
    "next": "212001407"
  },
  {
    "id": 212001407,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "……反正就是不正常。",
    "next": "212001500"
  },
  {
    "id": 212001500,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "",
    "next": "212001601/212001701",
    "script": "branches",
    "ParameterStr0": "Frank有什么人来找过他？",
    "ParameterInt0": 212001601,
    "ParameterStr1": "你知道Frank的遗嘱吗？",
    "ParameterInt1": 212001701
  },
  {
    "id": 212001601,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "催收的人来过好几次。还有就是——Rose。她来的时候叔叔特别高兴。我看着就来气。",
    "next": "212001602"
  },
  {
    "id": 212001602,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "除了催收和Rose，还有别人吗？",
    "next": "212001603"
  },
  {
    "id": 212001603,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "叔叔没什么朋友。腿不好，出门不方便。就那几个人。",
    "next": "212001800"
  },
  {
    "id": 212001701,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "遗嘱？！别跟我提遗嘱！",
    "next": "212001702"
  },
  {
    "id": 212001702,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "我是Frank唯一的亲人！唯一的侄子！我从乡下来投奔他，帮他打理日常，结果遗嘱一改——他把我的名字删了！",
    "next": "212001703"
  },
  {
    "id": 212001703,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "改成谁了？",
    "next": "212001704"
  },
  {
    "id": 212001704,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "Rose。那个女人的名字在上面。七十三岁的老人改遗嘱，你说正常吗？这不是被人骗了是什么？",
    "next": "212001800"
  },
  {
    "id": 212001800,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "你要查叔叔的事，查那个女人。Rose Martinez。所有的问题都从她来了以后开始的。",
    "next": "212001801"
  },
  {
    "id": 212001801,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "谢谢你，Danny。",
    "script": "end"
  }
]