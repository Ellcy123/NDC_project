[
  {
    "id": 209002001,
    "cnWords": "O'Hara太太，又打扰您了。我想再跟您聊聊Frank的事。",
    "cnSpeaker": "扎克·布伦南",
    "next": "209002002"
  },
  {
    "id": 209002002,
    "cnWords": "Brennan先生。我刚从Frank家里出来......帮他整理了一些遗物。请进——或者就在门廊上聊也行。",
    "cnSpeaker": "莎拉·奥哈拉",
    "next": "209002003"
  },
  {
    "id": 209002003,
    "cnWords": "这里就好。我最近查到了一些跟Moore银行有关的东西，想跟您核实几件事。",
    "cnSpeaker": "扎克·布伦南",
    "next": "209002004"
  },
  {
    "id": 209002004,
    "cnWords": "Moore银行......我现在听到这三个字就心慌。您问吧。",
    "cnSpeaker": "莎拉·奥哈拉",
    "script": "branches",
    "ParameterStr2": "没有其他问题了",
    "ParameterStr0": "查案：Frank最近的情况",
    "ParameterStr1": "查案：催收的更多细节",
    "ParameterInt2": 209002010,
    "ParameterInt0": 209002100,
    "ParameterInt1": 209002200
  },
  {
    "id": 209002100,
    "cnWords": "O'Hara太太，Frank出事前那段时间，您注意到他有什么不同寻常的举动吗？",
    "cnSpeaker": "扎克·布伦南",
    "next": "209002101"
  },
  {
    "id": 209002101,
    "cnWords": "有......出事前大概一个星期，Frank突然变了一个人。他开始整理家里所有的东西——文件啊、信啊、账本什么的。他把自己锁在屋子里，连我去送饭都只开一条门缝。",
    "cnSpeaker": "莎拉·奥哈拉",
    "next": "209002102"
  },
  {
    "id": 209002102,
    "cnWords": "整理文件？他整理的是什么文件？跟银行有关吗？",
    "cnSpeaker": "扎克·布伦南",
    "next": "209002103"
  },
  {
    "id": 209002103,
    "cnWords": "我只透过门缝看到过一眼——桌上全是银行的东西。贷款合同、还款记录、利息单......他还拿着一支铅笔在上面一行一行地画。他跟我说了一句话——'他们骗了我，Sarah。我要让所有人知道。'",
    "cnSpeaker": "莎拉·奥哈拉",
    "next": "209002104"
  },
  {
    "id": 209002104,
    "cnWords": "'让所有人知道'——他要举报他们？",
    "cnSpeaker": "扎克·布伦南",
    "next": "209002105"
  },
  {
    "id": 209002105,
    "cnWords": "他说他算清楚了，银行从一开始就在骗他——利息比说好的高得多，还有些他根本不知道的费用。他要把这些文件整理好，交给报社或者警察......然后就出了那场火。",
    "cnSpeaker": "莎拉·奥哈拉",
    "script": "get",
    "next": "209002106",
    "ParameterInt0": 2091003
  },
  {
    "id": 209002106,
    "cnWords": "他整理文件准备举报......然后鞋坊就着火了。这个时间点可不是巧合。",
    "cnSpeaker": "扎克·布伦南",
    "next": "209002400"
  },
  {
    "id": 209002200,
    "cnWords": "上次您提到那个意大利人来催收。后来他还来过吗？有没有对Frank动过手？",
    "cnSpeaker": "扎克·布伦南",
    "next": "209002201"
  },
  {
    "id": 209002201,
    "cnWords": "来过......出事前两三天，那个人又出现了。但这次不一样——他没有站在门口，他直接把门踢开走了进去。",
    "cnSpeaker": "莎拉·奥哈拉",
    "next": "209002202"
  },
  {
    "id": 209002202,
    "cnWords": "踢开门？他在里面待了多久？您听到什么了吗？",
    "cnSpeaker": "扎克·布伦南",
    "next": "209002203"
  },
  {
    "id": 209002203,
    "cnWords": "大概十来分钟。我听到东西摔碎的声音，还有Frank的喊声——'你们不能这样！这些是我的东西！'然后那个人走出来的时候，手里抱着一摞文件。",
    "cnSpeaker": "莎拉·奥哈拉",
    "next": "209002204"
  },
  {
    "id": 209002204,
    "cnWords": "抢走了他整理的文件......所以火灾发生的时候，那些证据可能已经不在Frank手上了。",
    "cnSpeaker": "扎克·布伦南",
    "next": "209002205"
  },
  {
    "id": 209002205,
    "cnWords": "那个人走后我去看过Frank——他坐在地上，满脸是血，到处都是翻乱的东西。他跟我说：'Sarah，他们拿走了我的证据。但不是全部。我还留了一份。'",
    "cnSpeaker": "莎拉·奥哈拉",
    "next": "209002206"
  },
  {
    "id": 209002206,
    "cnWords": "他留了一份副本？他有没有说藏在哪里？",
    "cnSpeaker": "扎克·布伦南",
    "next": "209002207"
  },
  {
    "id": 209002207,
    "cnWords": "没有。他只是笑了笑，说：'他们找不到的。'......第二天晚上，鞋坊就着火了。",
    "cnSpeaker": "莎拉·奥哈拉",
    "next": "209002400"
  },
  {
    "id": 209002400,
    "cnWords": "还有别的想问的。",
    "cnSpeaker": "扎克·布伦南",
    "script": "branches",
    "ParameterStr2": "没有其他问题了",
    "ParameterStr0": "查案：Frank最近的情况",
    "ParameterStr1": "查案：催收的更多细节",
    "ParameterInt2": 209002010,
    "ParameterInt0": 209002100,
    "ParameterInt1": 209002200
  },
  {
    "id": 209002010,
    "cnWords": "O'Hara太太，谢谢您告诉我这些。Frank想做的事情——我会替他完成。",
    "cnSpeaker": "扎克·布伦南",
    "next": "209002011"
  },
  {
    "id": 209002011,
    "cnWords": "拜托了，Brennan先生。Frank是个好人——他不应该这样死去。小心那些银行的人。",
    "cnSpeaker": "莎拉·奥哈拉",
    "script": "end"
  }
]