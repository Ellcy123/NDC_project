[
  {
    "id": 211001001,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Rose。保险箱钥匙带了？",
    "next": "211001002"
  },
  {
    "id": 211001002,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "在这里。Frank给我的。他说如果出了什么事……让我打开它。",
    "next": "211001003"
  },
  {
    "id": 211001003,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……开了。",
    "next": "211001004"
  },
  {
    "id": 211001004,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "\"致艾斯弗德检察官办公室——我叫Frank Kowalski，举报湖滨信托银行和湖滨投资公司。银行有个叫Leonard的人，专找穷人下手……我收集了十二个受害者的证据。\"",
    "next": "211001005",
    "script": "get",
    "ParameterInt0": 2502
  },
  {
    "id": 211001005,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "十二个受害者。名单、合同副本、资金往来记录——全在这里。这不是投诉信，这是一整套举报材料。",
    "next": "211001006"
  },
  {
    "id": 211001006,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "他跟我说过他在收集证据……我没想到这么多。",
    "next": "211001007"
  },
  {
    "id": 211001007,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "11月5号写的。案发前一天。",
    "next": "211001008"
  },
  {
    "id": 211001008,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "那他就是因为要去举报——被杀的。",
    "next": "211001009"
  },
  {
    "id": 211001009,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "还有一本调查笔记。\"11月3日——去查Leonard的底细。11月4日——跟踪他下班，记下住址：北区湖滨大道88号。11月5日——明天去检察官那里。如果我出了什么事……Margaret，把这些东西交给警察。\"",
    "next": "211001010",
    "script": "get",
    "ParameterInt0": 2504
  },
  {
    "id": 211001010,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……他把后路留给了我妈。",
    "next": "211001011"
  },
  {
    "id": 211001011,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "Frank知道自己在做危险的事。他信任Margaret，提前留了后路。",
    "next": "211001012"
  },
  {
    "id": 211001012,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "还有一样东西。",
    "next": "211001013"
  },
  {
    "id": 211001013,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "这是……给我的。\"To Rose\"。",
    "next": "211001014",
    "script": "get",
    "ParameterInt0": 2503
  },
  {
    "id": 211001014,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "……他让我好好活着。不管发生什么，都要笑着。",
    "next": "211001015"
  },
  {
    "id": 211001015,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Frank不是赌鬼。他是一个七十三岁的老人，一个人收集了十二份证据，准备掀翻银行和黑手党。有人提前知道了。",
    "next": "211001016"
  },
  {
    "id": 211001016,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "谁先知道的——谁就有杀人动机。",
    "next": "211001017"
  },
  {
    "id": 211001017,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "北区湖滨大道88号——Frank查到了Leonard的住址。",
    "next": "211001101/211001201",
    "script": "branches",
    "ParameterStr0": "怎么查Leonard？",
    "ParameterInt0": 211001101,
    "ParameterStr1": "Rose，你那天晚上看到了什么？",
    "ParameterInt1": 211001201
  },
  {
    "id": 211001101,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "Leonard是银行职员，有身份有地位。不能直接闯——需要搜查令或者更多证据。",
    "next": "211001102"
  },
  {
    "id": 211001102,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "先去鞋坊废墟再搜一遍。Frank的笔记说Leonard那天晚上去过鞋坊——也许能找到什么痕迹。",
    "next": "211001300"
  },
  {
    "id": 211001201,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "那天晚上……我走到鞋坊附近的时候，看到有人出来。我害怕，就没敢靠近。",
    "next": "211001202"
  },
  {
    "id": 211001202,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "什么样的人？",
    "next": "211001203"
  },
  {
    "id": 211001203,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "天太黑了……看不太清。但有一个人块头很大。",
    "next": "211001204"
  },
  {
    "id": 211001204,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "Rose，我们需要你回忆更多细节——时间、方向、体格，任何你想得起来的。",
    "next": "211001300"
  },
  {
    "id": 211001300,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Frank留了路线图。再搜一遍鞋坊废墟，问Rose还原时间线——出发。",
    "script": "end"
  }
]