[
  {
    "id": 201003001,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Rose。",
    "next": "201003002"
  },
  {
    "id": 201003002,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "我每天都来看看……这里是Margaret的店。是我和Frank的地方。",
    "next": "201003003"
  },
  {
    "id": 201003003,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "11月6号那天晚上——我需要你从头到尾讲一遍。每一个细节。",
    "next": "201003004"
  },
  {
    "id": 201003004,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "那天下午五点左右，Frank来找我。他说——\"Rose，今晚我要做一件非常冒险的事。你晚上九点去鞋坊等我。如果十点我还没回来……你就走，别等了。\"",
    "next": "201003005",
    "script": "get",
    "ParameterInt0": 2081004
  },
  {
    "id": 201003005,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "他说去哪？",
    "next": "201003006"
  },
  {
    "id": 201003006,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "没有。他只说——\"做完这件事，我们就自由了。\" 然后亲了我额头就走了。",
    "next": "201003007"
  },
  {
    "id": 201003007,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你九点到了鞋坊？",
    "next": "201003008"
  },
  {
    "id": 201003008,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "我提前去了。不放心他……大概八点二十就到了附近。",
    "next": "201003009"
  },
  {
    "id": 201003009,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "我提前到了……大概八点二十。从后门进了地下室等着。等了没多久，楼上传来声音——像是有人在争吵。越来越大声。",
    "next": "201003010"
  },
  {
    "id": 201003010,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "",
    "next": "201003101/201003201",
    "script": "branches",
    "ParameterStr0": "后来呢？",
    "ParameterInt0": 201003101,
    "ParameterStr1": "争吵的声音——听清了什么？",
    "ParameterInt1": 201003201
  },
  {
    "id": 201003101,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "后来安静了。我不敢上去……Frank叮嘱过我不要出来。我就在地下室等。",
    "next": "201003102"
  },
  {
    "id": 201003102,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "大概九点多，听到上面有人走动，然后门响了。我从地下室的小窗看出去——一个人从鞋坊出来。块头很大，比一般人宽一圈。穿深色衣服，走得很急——像是赶着逃一样。",
    "next": "201003103",
    "script": "get",
    "ParameterInt0": 2081005
  },
  {
    "id": 201003103,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "九点多，一个大块头从鞋坊出来。然后呢？",
    "next": "201003104"
  },
  {
    "id": 201003104,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "那个人走了之后……我闻到了烟味。窗户开始冒烟。",
    "next": "201003300"
  },
  {
    "id": 201003201,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "听不清楚具体在说什么……但声音很大。有东西摔在地上的声音——像是打翻了什么。",
    "next": "201003202"
  },
  {
    "id": 201003202,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "有几个人的声音？",
    "next": "201003203"
  },
  {
    "id": 201003203,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "分不清。至少两个人在吵。……后来安静了。我以为没事了。",
    "next": "201003300"
  },
  {
    "id": 201003300,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "我当时应该冲进去……也许Frank还在里面。但我太害怕了……",
    "next": "201003301"
  },
  {
    "id": 201003301,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你活着，Frank才安心。他留下的每一条线索——我会追到底。",
    "script": "end"
  }
]