[
  {
    "id": 205001001,
    "cnWords": "Vinnie Moretti。我是私家侦探Zack Brennan。关于Frank Kowalski鞋坊纵火案，我有几个问题。",
    "cnSpeaker": "扎克·布伦南",
    "next": "205001002"
  },
  {
    "id": 205001002,
    "cnWords": "......",
    "cnSpeaker": "维尼·莫雷蒂",
    "next": "205001003"
  },
  {
    "id": 205001003,
    "cnWords": "不说话也行。但我得提醒你——你是在Frank鞋坊纵火案的现场附近被发现的。有目击者看到你案发当晚从鞋坊出来。沉默不会帮你。",
    "cnSpeaker": "扎克·布伦南",
    "next": "205001004"
  },
  {
    "id": 205001004,
    "cnWords": "随你怎么想。",
    "cnSpeaker": "维尼·莫雷蒂",
    "next": "205001005"
  },
  {
    "id": 205001005,
    "cnWords": "Vinnie，我有些问题想问你。你可以选择回答。",
    "cnSpeaker": "扎克·布伦南",
    "script": "branches",
    "ParameterStr2": "案发当晚行踪",
    "ParameterStr0": "Frank鞋坊的事",
    "ParameterStr1": "Leonard的照片",
    "ParameterInt2": 205001300,
    "ParameterInt0": 205001100,
    "ParameterInt1": 205001200
  },
  {
    "id": 205001100,
    "cnWords": "你认识Frank Kowalski吗？南区的修鞋匠，鞋坊被烧了——他死在里面。",
    "cnSpeaker": "扎克·布伦南",
    "next": "205001101"
  },
  {
    "id": 205001101,
    "cnWords": "不认识。",
    "cnSpeaker": "维尼·莫雷蒂",
    "next": "205001102"
  },
  {
    "id": 205001102,
    "cnWords": "不认识？但你去过他的鞋坊。不只一次。你和你的老板——Moore银行的人——每个月都去催债。",
    "cnSpeaker": "扎克·布伦南",
    "next": "205001103"
  },
  {
    "id": 205001103,
    "cnWords": "最近两三个月没去过。",
    "cnSpeaker": "维尼·莫雷蒂",
    "script": "get",
    "next": "205001104",
    "ParameterInt0": 2051001
  },
  {
    "id": 205001104,
    "cnWords": "两三个月？但目击者说11月6日晚上——就在鞋坊起火的时候——你从鞋坊的侧门出来。你怎么解释？",
    "cnSpeaker": "扎克·布伦南",
    "next": "205001105"
  },
  {
    "id": 205001105,
    "cnWords": "......不记得了。",
    "cnSpeaker": "维尼·莫雷蒂",
    "next": "205001400"
  },
  {
    "id": 205001200,
    "cnWords": "Vinnie，你看看这张照片。你认识这个人吗？",
    "cnSpeaker": "扎克·布伦南",
    "next": "205001201"
  },
  {
    "id": 205001201,
    "cnWords": "Rus......不，不认识。",
    "cnSpeaker": "维尼·莫雷蒂",
    "script": "get",
    "next": "205001202",
    "ParameterInt0": 2051002
  },
  {
    "id": 205001202,
    "cnWords": "等等——你刚才说什么？'Rus'什么？你是想说一个名字？",
    "cnSpeaker": "扎克·布伦南",
    "next": "205001203"
  },
  {
    "id": 205001203,
    "cnWords": "......我说了不认识。",
    "cnSpeaker": "维尼·莫雷蒂",
    "next": "205001204"
  },
  {
    "id": 205001204,
    "cnWords": "这个人叫Leonard Ross——Moore银行的信贷经理。你在银行门口站了好几年岗，你跟我说不认识他？",
    "cnSpeaker": "扎克·布伦南",
    "next": "205001205"
  },
  {
    "id": 205001205,
    "cnWords": "没有。",
    "cnSpeaker": "维尼·莫雷蒂",
    "next": "205001400"
  },
  {
    "id": 205001300,
    "cnWords": "Vinnie，11月6日晚上——纵火案那天——你在哪儿？你有不在场证明吗？",
    "cnSpeaker": "扎克·布伦南",
    "next": "205001301"
  },
  {
    "id": 205001301,
    "cnWords": "......",
    "cnSpeaker": "维尼·莫雷蒂",
    "next": "205001302"
  },
  {
    "id": 205001302,
    "cnWords": "让我帮你回忆一下。目击者说9点多看到你从鞋坊出来，手里拿着一个打火机。鞋坊已经开始冒烟了。你还想继续沉默吗？",
    "cnSpeaker": "扎克·布伦南",
    "next": "205001303"
  },
  {
    "id": 205001303,
    "cnWords": "......你问完了没有。",
    "cnSpeaker": "维尼·莫雷蒂",
    "next": "205001400"
  },
  {
    "id": 205001400,
    "cnWords": "Vinnie，你在保护谁我不知道。但我会查清楚的。你想清楚要不要继续沉默——下次见面之前。",
    "cnSpeaker": "扎克·布伦南",
    "next": "205001401"
  },
  {
    "id": 205001401,
    "cnWords": "......别去为难不该为难的人。",
    "cnSpeaker": "维尼·莫雷蒂",
    "script": "end"
  },
  {
    "id": 205001010,
    "cnWords": "今天先到这里，Vinnie。好好想想。",
    "cnSpeaker": "扎克·布伦南",
    "next": "205001011"
  },
  {
    "id": 205001011,
    "cnWords": "......",
    "cnSpeaker": "维尼·莫雷蒂",
    "script": "end"
  }
]