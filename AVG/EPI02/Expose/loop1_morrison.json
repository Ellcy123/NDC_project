[
  {
    "id": 210001001,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Morrison，我们需要谈谈。",
    "next": "210001002"
  },
  {
    "id": 210001002,
    "cnSpeaker": "莫里森",
    "cnWords": "哟，又来了。Brennan，我还以为你在给你母亲烧纸钱呢。有什么事快说，我还赶着收队。",
    "next": "210001003"
  },
  {
    "id": 210001003,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "关于死者的身份——你的判断有问题。",
    "next": "210001004"
  },
  {
    "id": 210001004,
    "cnSpeaker": "莫里森",
    "cnWords": "有什么问题？我是第一响应警官，我基于现场情况做出了合理判断。这是程序，不是猜谜游戏。",
    "next": "210001005"
  },
  {
    "id": 210001005,
    "cnSpeaker": "莫里森",
    "cnWords": "死者应该就是Margaret Brennan——她的鞋坊，她的工作台旁边，尸体就在那儿。我基于现场情况做出的判断。你有什么不满意的？",
    "next": "210001006",
    "script": "get",
    "ParameterInt0": 2031001
  },
  {
    "id": 210001006,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你确定吗，Morrison？那我给你看几样东西。",
    "next": "210001007"
  },
  {
    "id": 210001007,
    "cnSpeaker": "莫里森",
    "cnWords": "死者应该就是Margaret，我基于现场情况做出的判断。你有证据证明不是她？",
    "script": "Lie",
    "ParameterStr0": "2101,2102,2103",
    "ParameterInt0": 210001008,
    "ParameterInt1": 1
  },
  {
    "id": 210001008,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "【出示证据2101：尸体手指照片】看这张照片，Morrison。这是死者左手的特写。无名指上没有戒指，连佩戴痕迹都没有。",
    "next": "210001009"
  },
  {
    "id": 210001009,
    "cnSpeaker": "莫里森",
    "cnWords": "所以？火灾现场，戒指掉了也不奇怪。你就凭一张照片来质疑我？",
    "next": "210001010"
  },
  {
    "id": 210001010,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "【出示证据2102：Margaret的相册】这是我母亲的相册。三张照片，1893年新婚、1898年全家福、1924年鞋坊门前。三十年，每一张照片里她的左手无名指上都戴着同一枚婚戒。我父亲去世后二十年，她从未摘下过。",
    "next": "210001011"
  },
  {
    "id": 210001011,
    "cnSpeaker": "莫里森",
    "cnWords": "人总有心情不好的时候，也许她那天碰巧摘了——",
    "next": "210001012"
  },
  {
    "id": 210001012,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "【出示证据2103：空的首饰盒】这是她卧室的首饰盒。胡桃木的，左边的戒指凹槽是空的。如果她摘下了戒指，应该放在这里。",
    "next": "210001013"
  },
  {
    "id": 210001013,
    "cnSpeaker": "莫里森",
    "cnWords": "……那又怎么样？也许戒指在火灾中——",
    "next": "210001014"
  },
  {
    "id": 210001014,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "手上没有，首饰盒里也没有。一个从不摘下婚戒的女人，戒指去哪了，Morrison？",
    "next": "210001015"
  },
  {
    "id": 210001015,
    "cnSpeaker": "莫里森",
    "cnWords": "火灾很猛烈，戒指可能掉在了现场或被烧毁了。你去过那个现场——整个一楼都烧透了，什么东西都可能化成灰。",
    "next": "210001016"
  },
  {
    "id": 210001016,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "被烧毁了？",
    "next": "210001017"
  },
  {
    "id": 210001017,
    "cnSpeaker": "莫里森",
    "cnWords": "没错，火灾很猛烈，戒指可能掉在了现场或被烧毁了。你见过那种火势，Brennan——什么都不会剩下。",
    "script": "Lie",
    "ParameterStr0": "2104",
    "ParameterInt0": 210001018,
    "ParameterInt1": 1
  },
  {
    "id": 210001018,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "【出示证据2104：现场地面照片】Morrison，你该补补化学课了。这是尸体周围的地面特写——烧焦的木屑、碎玻璃，但没有任何金属残留。",
    "next": "210001019"
  },
  {
    "id": 210001019,
    "cnSpeaker": "莫里森",
    "cnWords": "……你想说什么？",
    "next": "210001020"
  },
  {
    "id": 210001020,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "黄金的熔点是1064度。普通建筑火灾？远远不及。真金不怕火炼——金戒指在那种温度下不会被烧毁，最多变形。我在尸体周围的地面仔细搜过了，没有任何金属残留物。",
    "next": "210001021"
  },
  {
    "id": 210001021,
    "cnSpeaker": "莫里森",
    "cnWords": "……",
    "next": "210001022"
  },
  {
    "id": 210001022,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "手上没有戒指。首饰盒是空的。现场地面也没有。一枚金戒指不可能凭空消失，Morrison。除非——那个人根本就不是我母亲。",
    "next": "210001023"
  },
  {
    "id": 210001023,
    "cnSpeaker": "莫里森",
    "cnWords": "够了，Brennan。你是警察还是我是警察？我理解你的痛苦，但你不能用几张照片和一个空盒子就推翻我的专业判断。",
    "next": "210001024"
  },
  {
    "id": 210001024,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "那你拿出专业判断的依据来。",
    "next": "210001025"
  },
  {
    "id": 210001025,
    "cnSpeaker": "莫里森",
    "cnWords": "我有尸检调查信息可以证明死者身份。死者的体征、位置、环境——所有证据都指向她就是你母亲。你觉得我会随便下结论吗？",
    "next": "210001026"
  },
  {
    "id": 210001026,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "尸检调查信息？Foster的尸检报告出来了？",
    "next": "210001027"
  },
  {
    "id": 210001027,
    "cnSpeaker": "莫里森",
    "cnWords": "我是第一响应警官，当然有初步的调查信息。Brennan，我知道你不想接受，但事实就是事实。",
    "next": "210001028"
  },
  {
    "id": 210001028,
    "cnSpeaker": "莫里森",
    "cnWords": "我有尸检调查信息可以证明死者身份。你一个私家侦探，拿着几张照片跑来质疑第一响应警官的判断？回去等我的结案报告吧。",
    "script": "Lie",
    "ParameterStr0": "2021001",
    "ParameterInt0": 210001029,
    "ParameterInt1": 1
  },
  {
    "id": 210001029,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "【出示证据2021001：Foster初步骨骼分析证词】Morrison，你说你有尸检调查信息？",
    "next": "210001030"
  },
  {
    "id": 210001030,
    "cnSpeaker": "莫里森",
    "cnWords": "我已经告诉你了——",
    "next": "210001031"
  },
  {
    "id": 210001031,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "我让Emma帮我问了Foster。她说，尸检报告最快明天才能完成。尸体烧得太严重，目前连性别都无法确定。初步骨骼分析的结论是——死者可能是男性。",
    "next": "210001032"
  },
  {
    "id": 210001032,
    "cnSpeaker": "莫里森",
    "cnWords": "……Foster她——",
    "next": "210001033"
  },
  {
    "id": 210001033,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Foster的报告还没出来，你口中的\"尸检调查信息\"根本不存在。连负责尸检的法医都说不出死者是男是女，你凭什么一口咬定那是我母亲？",
    "next": "210001034"
  },
  {
    "id": 210001034,
    "cnSpeaker": "莫里森",
    "cnWords": "我说的是初步调查信息，不是正式尸检报告！作为现场警官我有权——",
    "next": "210001035"
  },
  {
    "id": 210001035,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你有权什么？你的初步调查包括什么？死者的性别？年龄？体征？你哪样做了？",
    "next": "210001036"
  },
  {
    "id": 210001036,
    "cnSpeaker": "莫里森",
    "cnWords": "火灾现场一片狼藉，尸体严重烧焦，我只能根据环境推断——",
    "next": "210001037"
  },
  {
    "id": 210001037,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "所以你根本没有任何依据。你只是编了一个结论，然后搬出\"专业权威\"来唬我。",
    "next": "210001038"
  },
  {
    "id": 210001038,
    "cnSpeaker": "莫里森",
    "cnWords": "Brennan，你到底想说什么？你以为我为什么要这样对你？",
    "next": "210001039"
  },
  {
    "id": 210001039,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "",
    "next": "210001040/210001042/210001042",
    "script": "branches",
    "ParameterStr0": "蓝月亮酒吧。你栽赃陷害我，被我揭发了。",
    "ParameterInt0": 210001040,
    "ParameterStr1": "你一直看不惯私家侦探插手警方的案子。",
    "ParameterInt1": 210001042,
    "ParameterStr2": "你跟这场火灾有关，想封我的口。",
    "ParameterInt2": 210001042
  },
  {
    "id": 210001040,
    "cnSpeaker": "莫里森",
    "cnWords": "……你还记得那件事。",
    "next": "210001041"
  },
  {
    "id": 210001041,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "蓝月亮酒吧。你在案发现场迷晕了我，把我拖到死者旁边，想让我背杀人的黑锅。被我揭发之后，你被内部调查，声誉扫地。你恨我，对吧？",
    "next": "210001043"
  },
  {
    "id": 210001042,
    "cnSpeaker": "莫里森",
    "cnWords": "你想多了，Brennan。这跟什么\"看不惯\"无关——你心里清楚是什么。",
    "next": "210001043"
  },
  {
    "id": 210001043,
    "cnSpeaker": "莫里森",
    "cnWords": "……",
    "next": "210001044"
  },
  {
    "id": 210001044,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "所以当你在现场看到我母亲的鞋坊，你看到了一个机会。你告诉我\"应该就是她\"，看着我崩溃，看着我绝望。你享受我的痛苦，Morrison。",
    "next": "210001045"
  },
  {
    "id": 210001045,
    "cnSpeaker": "莫里森",
    "cnWords": "……是。我恨你，Brennan。你揭发了我栽赃陷害的事，毁了我在警局仅剩的一点体面。每个人都把我当罪犯看。",
    "next": "210001046"
  },
  {
    "id": 210001046,
    "cnSpeaker": "莫里森",
    "cnWords": "但我也确实不知道那具尸体到底是谁。烧成那样，谁看得出来？我只是觉得……如果按Margaret结案，快，省事，顺便让你也尝尝什么叫心死。",
    "next": "210001047"
  },
  {
    "id": 210001047,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……那我母亲在哪？！",
    "next": "210001048"
  },
  {
    "id": 210001048,
    "cnSpeaker": "莫里森",
    "cnWords": "你母亲在哪，我不知道。但是……火灾当天早上，我收到过一个匿名电话。",
    "next": "210001049"
  },
  {
    "id": 210001049,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "什么电话？",
    "next": "210001050"
  },
  {
    "id": 210001050,
    "cnSpeaker": "莫里森",
    "cnWords": "有人告诉我\"不要多管Margaret Brennan的事\"。我不知道是谁打的，但那个声音很冷静，不像是在开玩笑。",
    "next": "210001051"
  },
  {
    "id": 210001051,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "有人警告你不要管我母亲的事……你就照做了？",
    "next": "210001052"
  },
  {
    "id": 210001052,
    "cnSpeaker": "莫里森",
    "cnWords": "别用那种眼神看我。我是个怕麻烦的人，Brennan，这你应该清楚。一边是匿名电话要我别管，一边是我正好恨你恨得牙痒——两件事碰到一起，我乐得省事。",
    "next": "210001053"
  },
  {
    "id": 210001053,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "所以你明明知道有人在针对我母亲，你还故意误导我……",
    "next": "210001054"
  },
  {
    "id": 210001054,
    "cnSpeaker": "莫里森",
    "cnWords": "行了，别演了。你想知道那个死人是谁？",
    "next": "210001055"
  },
  {
    "id": 210001055,
    "cnSpeaker": "莫里森",
    "cnWords": "玄关那边烧得不严重。我在那儿找到了一个钱包，身份证件还能看清——Frank Kowalski，73岁，退休工人。今天早上他邻居来报案说他昨晚没回家。",
    "next": "210001056",
    "script": "get",
    "ParameterInt0": 2111
  },
  {
    "id": 210001056,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你早就知道他的身份……",
    "next": "210001057"
  },
  {
    "id": 210001057,
    "cnSpeaker": "莫里森",
    "cnWords": "一个七十三岁的老头子死在别人的鞋坊里。是意外火灾也好，失足跌倒也好，都是命案，都得结案。我不在乎他怎么死的——我只需要一个能写进报告的答案。",
    "next": "210001058"
  },
  {
    "id": 210001058,
    "cnSpeaker": "莫里森",
    "cnWords": "所以，Brennan。我给你一个交易。",
    "next": "210001059"
  },
  {
    "id": 210001059,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "什么交易。",
    "next": "210001060"
  },
  {
    "id": 210001060,
    "cnSpeaker": "莫里森",
    "cnWords": "你去查Frank Kowalski的死因。随便什么理由都行——意外火灾、失足跌倒、煤气中毒——给我一个能结案的答案，写进报告里。",
    "next": "210001061"
  },
  {
    "id": 210001061,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "然后呢？",
    "next": "210001062"
  },
  {
    "id": 210001062,
    "cnSpeaker": "莫里森",
    "cnWords": "然后我去查你母亲的下落。我好歹是南区的警探，芝加哥一半的线人都认识我。你一个私家侦探，想找人？做梦。",
    "next": "210001063"
  },
  {
    "id": 210001063,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "如果我不答应呢？",
    "next": "210001064"
  },
  {
    "id": 210001064,
    "cnSpeaker": "莫里森",
    "cnWords": "那我就继续按Margaret结案。命案拖上几个月很正常——表格填不完，证人找不到，你懂的。至于你母亲的失踪案？抱歉，我手头命案太多，顾不上。",
    "next": "210001065"
  },
  {
    "id": 210001065,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……",
    "next": "210001066"
  },
  {
    "id": 210001066,
    "cnSpeaker": "莫里森",
    "cnWords": "别装了，Brennan。你那点理想主义我看得透透的——你不会对一个死了的老头坐视不管。更何况你母亲还在某个地方等着被找到。",
    "next": "210001067"
  },
  {
    "id": 210001067,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……",
    "next": "210001068"
  },
  {
    "id": 210001068,
    "cnSpeaker": "莫里森",
    "cnWords": "聪明的选择。我要的是结案报告，其他的我不管。去吧。",
    "next": "210001069"
  },
  {
    "id": 210001069,
    "cnSpeaker": "莫里森",
    "cnWords": "理想主义者……",
    "script": "end"
  }
]