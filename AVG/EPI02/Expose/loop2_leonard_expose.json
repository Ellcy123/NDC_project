[
  {
    "id": 209100001,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Ross先生。我们需要再谈谈。",
    "next": "209100002"
  },
  {
    "id": 209100002,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "Brennan先生。又见面了。",
    "next": "209100003"
  },
  {
    "id": 209100003,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "这次不是聊天。关于Vinnie Moretti——你刚才说不认识。",
    "next": "209100004"
  },
  {
    "id": 209100004,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "我说了，这个名字我不熟悉。",
    "next": "209100005"
  },
  {
    "id": 209100005,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "Vinnie Moretti？我不认识这个人。",
    "script": "Lie",
    "ParameterStr0": "2051002,2061002",
    "ParameterInt0": 209100010,
    "ParameterInt1": 1
  },
  {
    "id": 209100010,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "我刚从Silver Moon酒吧过来。跟Vinnie Moretti聊了聊。",
    "next": "209100011"
  },
  {
    "id": 209100011,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "哦？那跟我有什么关系？",
    "next": "209100012"
  },
  {
    "id": 209100012,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "我给Vinnie看了你的照片。你知道他说了什么？",
    "next": "209100013"
  },
  {
    "id": 209100013,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "说什么？",
    "next": "209100014"
  },
  {
    "id": 209100014,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "\"我不认识什么Russo。\"",
    "next": "209100015"
  },
  {
    "id": 209100015,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……",
    "next": "209100016"
  },
  {
    "id": 209100016,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Leonard Russo。这是你的入职档案——Moore先生提供的。原名Russo，改名Ross。Vinnie认识的不是Leonard Ross——他认识的是Leonard Russo。",
    "next": "209100017"
  },
  {
    "id": 209100017,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……好吧。",
    "next": "209100018"
  },
  {
    "id": 209100018,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "我以前叫Leonard Russo。改名是为了工作——银行业，你懂的。一个意大利姓氏……不太方便。",
    "next": "209100019"
  },
  {
    "id": 209100019,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "所以你认识Vinnie。",
    "next": "209100020"
  },
  {
    "id": 209100020,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "认识。以前认识。很久以前的事了。但我们没有任何来往——改名之后，那些人、那些事，都跟我没关系了。",
    "next": "209100021"
  },
  {
    "id": 209100021,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "我们只是认识而已。没有任何来往。",
    "script": "Lie",
    "ParameterStr0": "2207,2208",
    "ParameterInt0": 209100025,
    "ParameterInt1": 1
  },
  {
    "id": 209100025,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "这是从你的客户O'Hara太太手里拿到的贷款钞票——崭新的连号二十美元。编号A73625900到914。",
    "next": "209100026"
  },
  {
    "id": 209100026,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "银行发放贷款使用新钞很正常……",
    "next": "209100027"
  },
  {
    "id": 209100027,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "905到908。中间少了四张。",
    "next": "209100028"
  },
  {
    "id": 209100028,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……",
    "next": "209100029"
  },
  {
    "id": 209100029,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "这三张，是Vinnie Moretti在Silver Moon酒吧花掉的。编号905、906、908。",
    "next": "209100030"
  },
  {
    "id": 209100030,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……巧合。",
    "next": "209100031"
  },
  {
    "id": 209100031,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "同一批连号新钞。从银行取出来的时候，你抽走了中间几张给了Vinnie。O'Hara拿到的是剩下的。这不是巧合，Ross先生——或者我该叫你Russo先生。",
    "next": "209100032"
  },
  {
    "id": 209100032,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……",
    "next": "209100033"
  },
  {
    "id": 209100033,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "好。我给过Vinnie钱。但那是——我借给他的。私人借款。跟银行业务没有关系。",
    "next": "209100034"
  },
  {
    "id": 209100034,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "那些钱是我借给Vinnie的。不是分成。",
    "script": "Lie",
    "ParameterStr0": "2111001,2213",
    "ParameterInt0": 209100038,
    "ParameterInt1": 1
  },
  {
    "id": 209100038,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "借给他的。好。那我问你——一个人借了朋友的钱，花的时候会怎么说？",
    "next": "209100039"
  },
  {
    "id": 209100039,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……",
    "next": "209100040"
  },
  {
    "id": 209100040,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "酒吧老板Tony告诉我，Vinnie每次花钱的时候说的是——\"今天又赚了一笔。\"",
    "next": "209100041"
  },
  {
    "id": 209100041,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "他随口说的……",
    "next": "209100042"
  },
  {
    "id": 209100042,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "\"赚了一笔\"。不是\"花朋友的钱\"。不是\"还人情\"。是赚。他在领工资，Russo。他在替你干活。",
    "next": "209100043"
  },
  {
    "id": 209100043,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "你在编造——",
    "next": "209100044"
  },
  {
    "id": 209100044,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "最后一页。\"L.R.给的地址有问题，下次问清楚。\" L.R.——Leonard Russo。你给他地址，他替你上门。",
    "next": "209100045"
  },
  {
    "id": 209100045,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……",
    "next": "209100046"
  },
  {
    "id": 209100046,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……",
    "next": "209100047"
  },
  {
    "id": 209100047,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "好。你赢了。",
    "next": "209100048"
  },
  {
    "id": 209100048,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "Vinnie……是我雇的。我给他名单，给他地址。他上门催收。事后——分钱。",
    "next": "209100049"
  },
  {
    "id": 209100049,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Frank也在名单上？",
    "next": "209100050"
  },
  {
    "id": 209100050,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "Frank Kowalski。他是——被特别关照的。欠得最多，也最不肯低头。",
    "next": "209100051"
  },
  {
    "id": 209100051,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……特别关照。一个七十三岁的退休工人，被\"特别关照\"。",
    "next": "209100052"
  },
  {
    "id": 209100052,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "但你能证明什么，Brennan？你有几张钞票，一个本子，一个酒吧老板的嘴。",
    "next": "209100053"
  },
  {
    "id": 209100053,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "够把你送进警局了。",
    "next": "209100054"
  },
  {
    "id": 209100054,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "没有法院令状，你进不了银行的档案室。Moore先生不会给你任何内部文件——利率结构、审批流程、客户名单。你什么都拿不到。",
    "next": "209100055"
  },
  {
    "id": 209100055,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "我最多被开除。Moore安然无恙。上面的人——你连他们的名字都不会听到。",
    "next": "209100056"
  },
  {
    "id": 209100056,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "上面的人？",
    "next": "209100057"
  },
  {
    "id": 209100057,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "你该走了。",
    "next": "209100058"
  },
  {
    "id": 209100058,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "我会带令状回来的，Russo。",
    "script": "end"
  }
]