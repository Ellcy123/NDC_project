    "cnSpeaker": "扎克·布伦南",
    "enSpeaker": "Zack Brennan",
    "talkDisplayIndex": 1,
    "cnWords": "你让Vinnie来善后。",
    "enWords": "You had Vinnie come to clean up.",
    "next": "260053",
    "script": "",
    "ParameterStr0": "",
    "ParameterStr1": "",
    "ParameterStr2": "",
