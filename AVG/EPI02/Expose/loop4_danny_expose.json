[
  {
    "id": 212100001,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Danny。坐下。我们谈谈Rose的事。",
    "next": "212100002"
  },
  {
    "id": 212100002,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "终于！你查清楚了？她是骗子对不对！",
    "next": "212100003"
  },
  {
    "id": 212100003,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你说Rose是\"最近才出现的\"。大半年前。",
    "next": "212100004"
  },
  {
    "id": 212100004,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "没错。大半年前我才第一次看到她。之前从来没见过。",
    "next": "212100005"
  },
  {
    "id": 212100005,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "Rose Martinez最近才勾引我叔叔！他老了判断力不行了！被她的甜言蜜语骗了！",
    "script": "Lie",
    "ParameterStr0": "2401,2402,2403,2404",
    "ParameterInt0": 212100010,
    "ParameterInt1": 1
  },
  {
    "id": 212100010,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Danny。我去了Margaret鞋坊的地下室。",
    "next": "212100011"
  },
  {
    "id": 212100011,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "地下室？那跟Rose有什么关系？",
    "next": "212100012"
  },
  {
    "id": 212100012,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "地下室里有一个房间。里面有一张旧沙发——扶手磨到发亮，坐垫凹陷严重。这种磨损需要至少三五年。",
    "next": "212100013"
  },
  {
    "id": 212100013,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "那是Margaret自己的东西！跟Rose没关系！",
    "next": "212100014"
  },
  {
    "id": 212100014,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "窗帘褪色严重，少说挂了三年以上。地板上有固定位置的深度磨痕——桌子脚、椅子脚，每一个都磨出了凹痕。Margaret在一楼做鞋，没理由长年使用地下室。",
    "next": "212100015"
  },
  {
    "id": 212100015,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "那……那也不能说明——",
    "next": "212100016"
  },
  {
    "id": 212100016,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "墙上挂着五张照片。第一张——1920年，公园野餐，两个人。第五张——1925年10月15日，同一个房间的合影。背面写着\"我们的第五个秋天\"。",
    "next": "212100017"
  },
  {
    "id": 212100017,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "五年，Danny。不是大半年。",
    "next": "212100018"
  },
  {
    "id": 212100018,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "……",
    "next": "212100019"
  },
  {
    "id": 212100019,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "我和Frank相爱五年了。我们每周都在那个房间见面。",
    "next": "212100020"
  },
  {
    "id": 212100020,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "好吧……就算他们认识久一点……那又怎样？她还是骗子！叔叔的贷款就是因为她！三千二百块！都是她害的！",
    "next": "212100021"
  },
  {
    "id": 212100021,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "Rose骗我叔叔贷款！三千二百美元的债都是她害的！她让叔叔借钱给她花！",
    "script": "Lie",
    "ParameterStr0": "2303,2409,2408",
    "ParameterInt0": 212100025,
    "ParameterInt1": 1
  },
  {
    "id": 212100025,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Danny。这是银行的贷款档案。备注栏——\"贷款用途：房屋维修\"。",
    "next": "212100026"
  },
  {
    "id": 212100026,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "房屋维修？那——那就是修地下室给她住的！还是为了她！",
    "next": "212100027"
  },
  {
    "id": 212100027,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Margaret租赁协议。1920年6月——\"免费借给Frank和Rose使用地下室\"。免费，Danny。",
    "next": "212100028"
  },
  {
    "id": 212100028,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Rose从来没有要过一分钱。是Margaret主动借的。五年。",
    "next": "212100029"
  },
  {
    "id": 212100029,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "那……那维修呢？六百块呢？",
    "next": "212100030"
  },
  {
    "id": 212100030,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "维修收据。窗户更换120，地板翻新180，墙面粉刷150，沙发修复80，杂项70。合计——600美元。付款人：Frank Kowalski。",
    "next": "212100031"
  },
  {
    "id": 212100031,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Frank主动贷款600块，全部用在修缮地下室。因为他想给Rose一个体面的约会环境。这是他自己的选择。",
    "next": "212100032"
  },
  {
    "id": 212100032,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "我劝过他别贷款……我说不需要新沙发……不需要修窗户……但他坚持。他说——\"Rose，你值得更好的。\"",
    "next": "212100033"
  },
  {
    "id": 212100033,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "那她图的就是遗产！遗嘱就是证据！他把房子给了她！一个外人！",
    "next": "212100034"
  },
  {
    "id": 212100034,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "Rose图遗产！遗嘱写得清清楚楚！一个墨西哥寡妇冲着房产来的！",
    "script": "Lie",
    "ParameterStr0": "2311,2416",
    "ParameterInt0": 212100040,
    "ParameterInt1": 1
  },
  {
    "id": 212100040,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Danny，你读过遗嘱吗？仔细读过？",
    "next": "212100041"
  },
  {
    "id": 212100041,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "当然！\"财产归Rose Martinez\"！白纸黑字！",
    "next": "212100042"
  },
  {
    "id": 212100042,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你漏看了一行。Frank亲笔写的附加条款——\"若Rose不愿接受，全部捐给工人互助会。\"",
    "next": "212100043"
  },
  {
    "id": 212100043,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "捐给工人互助会。不是给你。Frank写这句话的意思是——他尊重Rose的选择。如果Rose不要，他宁可捐掉也不留给你。",
    "next": "212100044"
  },
  {
    "id": 212100044,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "那……那她肯定不会拒绝！谁会拒绝一栋房子？！",
    "next": "212100045"
  },
  {
    "id": 212100045,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "她嘴上说得好听！口头不作数！等真要签文件了——她肯定反悔！",
    "next": "212100046"
  },
  {
    "id": 212100046,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "人性都是贪婪的！没人会拒绝几千美元的拆迁补偿！",
    "script": "end"
  }
]