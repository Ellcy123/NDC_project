  },
  {
    "id": 207100005,
    "cnSpeaker": "维尼·莫雷蒂",
    "cnWords": "两三个月没去过。跟我没关系。",
    "script": "Lie",
    "ParameterStr0": "2501,2112001,2081005",
    "ParameterInt0": 207100010,
    "ParameterInt1": 1
  },
  {
    "id": 207100010,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "这是在Margaret鞋坊废墟里找到的。Frank床铺旁边的地板上。",
    "next": "207100011"
  },
  {
    "id": 207100011,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "银色金属打火机。侧面刻着一个V。",
    "next": "207100012"
  },
  {
    "id": 207100012,
    "cnSpeaker": "维尼·莫雷蒂",
    "cnWords": "……可能很久以前落在那的。",
    "next": "207100013"
  },
  {
    "id": 207100013,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "很久以前？Tony不这么说。",
    "next": "207100014"
  },
  {
    "id": 207100014,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "\"Vinnie每天在我酒吧里用它点烟，上周还用它给一个姑娘点烟。\" 上周，Vinnie。不是两三个月前。",
    "next": "207100015"
  },
  {
    "id": 207100015,
    "cnSpeaker": "维尼·莫雷蒂",
    "cnWords": "Tony……那个多嘴的。",
    "next": "207100016"
  },
  {
    "id": 207100016,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "你自己刻的V字。你每天都在用。它不可能两三个月前就掉在鞋坊。",
    "next": "207100017"
  },
  {
    "id": 207100017,
    "cnSpeaker": "维尼·莫雷蒂",
    "cnWords": "……",
    "next": "207100018"
  },
  {
    "id": 207100018,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "不只是打火机。11月6号晚上九点多——有人看到一个块头很大的意大利男人从鞋坊匆忙离开。穿深色衣服，走得像在逃。",
    "next": "207100019"
  },
  {
    "id": 207100019,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "这个描述——你觉得像谁？",
    "next": "207100020"
  },
  {
    "id": 207100020,
    "cnSpeaker": "维尼·莫雷蒂",
    "cnWords": "……",
    "next": "207100021"
  },
  {
    "id": 207100021,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "打火机是你的。人也是你。Vinnie，11月6号晚上你去了Margaret鞋坊。",
    "next": "207100022"
  },
  {
    "id": 207100022,
    "cnSpeaker": "维尼·莫雷蒂",
    "cnWords": "……",
    "next": "207100023"
  },
  {
    "id": 207100023,
    "cnSpeaker": "维尼·莫雷蒂",
    "cnWords": "够了！！",
    "next": "207100024"
  },
  {
    "id": 207100024,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……",
    "next": "207100025"
  },
  {
    "id": 207100025,
    "cnSpeaker": "维尼·莫雷蒂",
    "cnWords": "是我！行了吧！",
    "next": "207100026"
  },
  {
    "id": 207100026,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "Vinnie——",
    "next": "207100027"
  },
  {
    "id": 207100027,
    "cnSpeaker": "维尼·莫雷蒂",
    "cnWords": "是我！11月6号晚上我去鞋坊找Frank催债！我透过窗户看到那个老头正在床上睡觉——然后我放了火！是我纵火杀的他！",
    "next": "207100028"
  },
  {
    "id": 207100028,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Vinnie，你为什么——",
    "next": "207100029"
  },
  {
    "id": 207100029,
    "cnSpeaker": "维尼·莫雷蒂",
    "cnWords": "别问了！就是我干的！报警！我现在就签字！",
    "next": "207100030"
  },
  {
    "id": 207100030,
    "cnSpeaker": "旁白",
    "cnWords": "Vinnie双手撑在桌上，胸口剧烈起伏。整个酒吧安静下来。",
