    "waitTime": 0,
    "IdSpeaker": "NPC101",
    "cnSpeaker": "Zack",
    "enSpeaker": "Zack Brennan",
    "Location": "",
    "cnAction": "",
    "cnWords": "\"那个抽屉里的东西和 Webb 有没有关系？\"",
    "enAction": "",
    "enWords": "",
    "next": "205104038",
    "script": "",
    "ParameterStr0": "",
    "ParameterStr1": "",
