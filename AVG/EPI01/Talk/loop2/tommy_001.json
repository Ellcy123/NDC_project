  {
    "id": 205104035,
    "step": 32,
    "speakType": 3,
    "waitTime": 0,
    "IdSpeaker": "NPC101",
    "cnSpeaker": "Zack",
    "enSpeaker": "Zack Brennan",
    "Location": "",
    "cnAction": "分支 D 入口",
    "cnWords": "\"刚才里面有什么？你动作那么快。\"",
    "enAction": "",
    "enWords": "",
    "next": "205104036",
    "script": "",
    "ParameterStr0": "",
    "ParameterStr1": "",
    "ParameterStr2": "",
    "ParameterInt0": 0,
