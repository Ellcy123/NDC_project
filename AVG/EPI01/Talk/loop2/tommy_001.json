    "IdSpeaker": "NPC101",
    "cnSpeaker": "Zack",
    "enSpeaker": "Zack Brennan",
    "Location": "",
    "cnAction": "",
    "cnWords": "\"今晚 Webb 的客人里，你认识什么人？\"",
    "enAction": "",
    "enWords": "",
    "next": "205104043",
    "script": "",
    "ParameterStr0": "",
    "ParameterStr1": "",
    "ParameterStr2": "",
    "ParameterInt0": 0,
