    "IdSpeaker": "NPC101",
    "cnSpeaker": "Zack",
    "enSpeaker": "Zack Brennan",
    "Location": "",
    "cnAction": "",
    "cnWords": "\"什么东西？\"",
    "enAction": "",
    "enWords": "",
    "next": "205104034",
    "script": "",
    "ParameterStr0": "",
    "ParameterStr1": "",
    "ParameterStr2": "",
    "ParameterInt0": 0,
