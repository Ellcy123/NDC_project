    "IdSpeaker": "NPC101",
    "cnSpeaker": "Zack",
    "enSpeaker": "Zack Brennan",
    "Location": "",
    "cnAction": "",
    "cnWords": "\"Morrison 跟你说过什么吗？\"",
    "enAction": "",
    "enWords": "",
    "next": "205104045",
