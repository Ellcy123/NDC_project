[
  {
    "id": 217002001,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "妈，感觉好些了吗？",
    "next": "217002002"
  },
  {
    "id": 217002002,
    "cnSpeaker": "玛格丽特",
    "cnWords": "好多了。……你是来做正事的吧。",
    "next": "217002003"
  },
  {
    "id": 217002003,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "我需要把你说的正式记录下来。11月6号那晚——从头说。",
    "next": "217002004"
  },
  {
    "id": 217002004,
    "cnSpeaker": "玛格丽特",
    "cnWords": "八点左右，我出门去街角杂货店买点东西。",
    "next": "217002005"
  },
  {
    "id": 217002005,
    "cnSpeaker": "玛格丽特",
    "cnWords": "八点二十左右往回走。快到鞋坊的时候，在街角看到一个人从鞋坊方向出来——走得很急。",
    "next": "217002006"
  },
  {
    "id": 217002006,
    "cnSpeaker": "玛格丽特",
    "cnWords": "戴眼镜、穿西装。走路踉踉跄跄的，好像看不清路。当时天暗，我只看到轮廓和眼镜的反光。",
    "next": "217002007"
  },
  {
    "id": 217002007,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "他朝哪个方向走的？",
    "next": "217002008"
  },
  {
    "id": 217002008,
    "cnSpeaker": "玛格丽特",
    "cnWords": "我没注意……我当时只想着快回家。",
    "next": "217002009"
  },
  {
    "id": 217002009,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "进门之后呢？",
    "next": "217002010"
  },
  {
    "id": 217002010,
    "cnSpeaker": "玛格丽特",
    "cnWords": "Frank……倒在店铺区的地上。头上流了好多血。拐杖掉在旁边。",
    "next": "217002011"
  },
  {
    "id": 217002011,
    "cnSpeaker": "玛格丽特",
    "cnWords": "我跑过去想检查他的伤。……刚蹲下来，后脑勺猛地一痛——什么都不知道了。",
    "next": "217002012"
  },
  {
    "id": 217002012,
    "cnSpeaker": "玛格丽特",
    "cnWords": "醒来的时候，我在一个很暗的仓库里。手脚都被绑着。……直到那个律师来救我。",
    "next": "217002013",
    "script": "get",
    "ParameterInt0": 2101001
  },
  {
    "id": 217002013,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "妈，那个戴眼镜的人——除了眼镜和西装，还有什么特征？",
    "next": "217002014"
  },
  {
    "id": 217002014,
    "cnSpeaker": "玛格丽特",
    "cnWords": "……身材中等，不算高大。走路的姿势……像是有教养的人。不像街上那些混混。",
    "next": "217002015"
  },
  {
    "id": 217002015,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……",
    "next": "217002016"
  },
  {
    "id": 217002016,
    "cnSpeaker": "玛格丽特",
    "cnWords": "Zack——你去过我的店了？",
    "next": "217002017"
  },
  {
    "id": 217002017,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "去过。仔细检查过了。",
    "next": "217002018"
  },
  {
    "id": 217002018,
    "cnSpeaker": "玛格丽特",
    "cnWords": "那你告诉我——柜台旁边那个烛台，是什么做的？",
    "next": "217002101/217002201/217002201",
    "script": "branches",
    "ParameterStr0": "黄铜的。三十厘米高，一直放在柜子左边。",
    "ParameterInt0": 217002101,
    "ParameterStr1": "铸铁的。挺沉的，一直放在窗台上。",
    "ParameterInt1": 217002201,
    "ParameterStr2": "锡做的。很轻，Frank用来照明。",
    "ParameterInt2": 217002201
  },
  {
    "id": 217002101,
    "cnSpeaker": "玛格丽特",
    "cnWords": "黄铜的……对。Frank说那个烛台是他父亲留下的。",
    "next": "217002102"
  },
  {
    "id": 217002102,
    "cnSpeaker": "玛格丽特",
    "cnWords": "你查到什么了？",
    "next": "217002103"
  },
  {
    "id": 217002103,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "妈——先休息。我会回来的。",
    "next": "217002300"
  },
  {
    "id": 217002201,
    "cnSpeaker": "玛格丽特",
    "cnWords": "……不对。你真的仔细看了吗？",
    "next": "217002300"
  },
  {
    "id": 217002300,
    "cnSpeaker": "玛格丽特",
    "cnWords": "小心那些人，Zack。他们能绑架我，就能伤害你。",
    "next": "217002301"
  },
  {
    "id": 217002301,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……我知道。",
    "script": "end"
  }
]