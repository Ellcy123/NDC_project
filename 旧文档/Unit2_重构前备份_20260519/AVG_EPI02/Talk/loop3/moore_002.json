  },
  {
    "id": 208002006,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Frank欠你们三千两百美元。你上次说是赌博债务。",
    "next": "208002007"
  },
  {
    "id": 208002007,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "贷款申请上写得很清楚。用途：偿还赌博债务。",
    "next": "208002008"
  },
  {
    "id": 208002008,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "那份申请是Frank自己签的吗？",
