    "cnWords": "",
    "next": "208002101/208002201",
    "script": "branches",
    "ParameterStr0": "Leonard跟你汇报催收的事吗？",
    "ParameterInt0": 208002101,
    "ParameterStr1": "Frank的贷款利率是多少？",
    "ParameterInt1": 208002201
  },
  {
    "id": 208002101,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "Leonard负责贷款业务。催收是他的工作范围——我不过问具体方式。",
    "next": "208002102"
  },
  {
    "id": 208002102,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "他雇了一个叫Vinnie Moretti的人暴力催收。你不知道？",
    "next": "208002103"
  },
  {
    "id": 208002103,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "员工在工作以外的行为，银行不承担责任。合同上也这么写的。",
    "next": "208002300"
  },
  {
    "id": 208002201,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "年化百分之七。合规利率。",
    "next": "208002202"
  },
  {
    "id": 208002202,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "六百块三年变三千二。百分之七做不到这个数字。",
    "next": "208002203"
  },
  {
    "id": 208002203,
    "cnSpeaker": "哈罗德·摩尔",
    "cnWords": "滞纳金、管理费、手续费。合同附件里都有。",
