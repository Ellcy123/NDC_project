[
  {
    "id": 231001001,
    "cnSpeaker": "旁白",
    "cnWords": "走廊尽头传来一阵快步声。一个穿深灰色三件套西装的男人走过来，手里拿着一份文件，步伐不急不缓，像是提前量好了距离。",
    "next": "231001002"
  },
  {
    "id": 231001002,
    "cnSpeaker": "米奇·麦克奈尔",
    "cnWords": "Zack？Zack Brennan？天哪，多少年了。",
    "next": "231001003"
  },
  {
    "id": 231001003,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……Mickey？Mickey Donnelly？",
    "next": "231001004"
  },
  {
    "id": 231001004,
    "cnSpeaker": "米奇·麦克奈尔",
    "cnWords": "本人。十二年了吧？你看起来——嗯，比当年沧桑了一点。",
    "next": "231001005"
  },
  {
    "id": 231001005,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你怎么在这儿？",
    "next": "231001006"
  },
  {
    "id": 231001006,
    "cnSpeaker": "米奇·麦克奈尔",
    "cnWords": "工作。我是律师了，Zack。刚好路过，听到你在申请银行搜查令——被驳回了？",
    "next": "231001007"
  },
  {
    "id": 231001007,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "你怎么知道？",
    "next": "231001008"
  },
  {
    "id": 231001008,
    "cnSpeaker": "米奇·麦克奈尔",
    "cnWords": "市政厅不大，消息传得快。湖滨信托银行——我正好在代理几个类似案子。掠夺性贷款，高利率，暴力催收。",
    "next": "231001009"
  },
  {
    "id": 231001009,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你有什么办法？",
    "next": "231001010"
  },
  {
    "id": 231001010,
    "cnSpeaker": "米奇·麦克奈尔",
    "cnWords": "传票。不需要搜查令——我以原告方律师的身份要求银行出示贷款档案。Frank Kowalski的案子，加上我手里的其他受害者证词，法院今天早上已经签了。",
    "next": "231001011"
  },
  {
    "id": 231001011,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "库克县巡回法院……搜查令。搜查范围：客户档案室、贷款部门办公室、相关员工办公区域。",
    "next": "231001012"
  },
  {
    "id": 231001012,
    "cnSpeaker": "米奇·麦克奈尔",
    "cnWords": "搜查令是附带的。你拿着去银行，法律上他们必须配合。",
    "next": "231001013",
    "script": "get",
    "ParameterInt0": 2304
  },
  {
    "id": 231001013,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……十二年没联系。突然出现，刚好有一份搜查令。",
    "next": "231001014"
  },
  {
    "id": 231001014,
    "cnSpeaker": "米奇·麦克奈尔",
    "cnWords": "缘分，老朋友。我也在查这家银行——正需要一个在现场调查的侦探。互相帮忙，怎么样？",
    "next": "231001015"
  },
  {
    "id": 231001015,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "搜查令是真的。法院签章、日期、范围都对。管他动机是什么，先用上。",
    "next": "231001016"
  },
  {
    "id": 231001016,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……好。我去银行。",
    "next": "231001017"
  },
  {
    "id": 231001017,
    "cnSpeaker": "米奇·麦克奈尔",
    "cnWords": "有什么发现告诉我。我在市政厅有办公室——三楼，尽头左转。",
    "next": "231001018"
  },
  {
    "id": 231001018,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……十二年。这也太巧了。",
    "script": "end"
  }
]