[
  {
    "id": 208004001,
    "cnSpeaker": "旁白",
    "cnWords": "银行贵宾室外的走廊。Zack握着遗嘱副本走出来，Emma靠在墙上等他。",
    "next": "208004002"
  },
  {
    "id": 208004002,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "谈得怎么样？",
    "next": "208004003"
  },
  {
    "id": 208004003,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Moore崩了。投资公司马甲、违法条款——全被拆穿。然后他给了我这个。",
    "next": "208004004"
  },
  {
    "id": 208004004,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "Frank的遗嘱？……财产归Rose Martinez。如果她不接受，捐给工人互助会。",
    "next": "208004005"
  },
  {
    "id": 208004005,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "Danny Kowalski——一个字都没提。Frank唯一的侄子，不在继承人里。",
    "next": "208004006"
  },
  {
    "id": 208004006,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Danny在我离开前堵着门，听到了遗嘱的事。",
    "next": "208004007"
  },
  {
    "id": 208004007,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "他什么反应？",
    "next": "208004008"
  },
  {
    "id": 208004008,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "他冲我喊了五分钟，大意是——Rose Martinez是个骗子，勾引了他叔叔，把他叔叔的钱全骗走了。原话里加了很多我不想重复的形容词。",
    "next": "208004009"
  },
  {
    "id": 208004009,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "……他用种族攻击了？",
    "next": "208004010"
  },
  {
    "id": 208004010,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "我需要知道Rose Martinez是谁。",
    "next": "208004011"
  },
  {
    "id": 208004011,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "遗嘱写了\"如与Rose Martinez结婚\"——说明Frank至少考虑过和她结婚。这个Rose对Frank来说不是随便的人。",
    "next": "208004012"
  },
  {
    "id": 208004012,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Danny说Rose是\"大半年前才出现的\"。如果这是真的，Frank确实可能被骗。但Danny的反应——太急了。",
    "next": "208004013"
  },
  {
    "id": 208004013,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "失业九个月，住在叔叔家里，突然听到叔叔把房子给了别人。他有足够的理由说谎。",
    "next": "208004014"
  },
  {
    "id": 208004014,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "我们有两条路可以走。",
    "next": "208004101/208004201",
    "script": "branches",
    "ParameterStr0": "先找Rose Martinez问清楚",
    "ParameterInt0": 208004101,
    "ParameterStr1": "先去Danny的房间看看他到底什么情况",
    "ParameterInt1": 208004201
  },
  {
    "id": 208004101,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Rose是遗嘱的核心。先听她怎么说。",
    "next": "208004102"
  },
  {
    "id": 208004102,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "我打听过——Rose在Margaret的鞋坊出现过。去那里碰碰运气。",
    "next": "208004103"
  },
  {
    "id": 208004103,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "对了，遗嘱上有一行手写小字——\"鞋坊地下室钥匙藏于入口门旁地毯之下\"。地下室一直锁着。现在有钥匙了。",
    "next": "208004300"
  },
  {
    "id": 208004201,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Danny失业之后一直住Frank家。看看他的房间，有没有什么能说明他的动机。",
    "next": "208004202"
  },
  {
    "id": 208004202,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "别忘了遗嘱上的手写小字——鞋坊地下室的钥匙在门口地毯下面。那个地下室锁了很久了。",
    "next": "208004300"
  },
  {
    "id": 208004300,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Rose Martinez、鞋坊地下室、Danny的房间。三个方向。",
    "next": "208004301"
  },
  {
    "id": 208004301,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "走吧。天快黑了。",
    "script": "end"
  }
]