[
  {
    "id": 241001001,
    "cnSpeaker": "旁白",
    "cnWords": "门外传来脚步声。",
    "next": "241001002"
  },
  {
    "id": 241001002,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "Danny。你错了。",
    "next": "241001003"
  },
  {
    "id": 241001003,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "你——你怎么——",
    "next": "241001004"
  },
  {
    "id": 241001004,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "我让Rose在外面等着，以防万一。看来是对的。",
    "next": "241001005"
  },
  {
    "id": 241001005,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "我从来不在意Frank的财产。",
    "next": "241001006"
  },
  {
    "id": 241001006,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "\"本人Rose Martinez，自愿放弃Frank Kowalski遗嘱中所列的全部财产继承权……\"",
    "next": "241001007"
  },
  {
    "id": 241001007,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "不……这不可能！你疯了吗？！",
    "next": "241001008"
  },
  {
    "id": 241001008,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "Frank给我最珍贵的礼物，是这五年的爱。房子、金钱——这些从来不重要。",
    "next": "241001009"
  },
  {
    "id": 241001009,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "……",
    "next": "241001010"
  },
  {
    "id": 241001010,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Rose签了。现在该谈谈你了。",
    "next": "241001011"
  },
  {
    "id": 241001011,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "我……我什么意思？我只是为叔叔——",
    "next": "241001012"
  },
  {
    "id": 241001012,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "今年二月的失业通知。信用卡账单——逾期60天，欠款105块50。当铺票据——手表和戒指都当了。还有一封写给Frank的借钱信——没寄出去。",
    "next": "241001013"
  },
  {
    "id": 241001013,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "那是……那是暂时的困难——",
    "next": "241001014"
  },
  {
    "id": 241001014,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "Danny，这栋房子在Miller集团的拆迁规划区。你刚才自己说了——\"几千美元的拆迁补偿\"。你嘴上说\"不知道什么拆迁\"——可你连补偿的数字都知道。",
    "next": "241001015"
  },
  {
    "id": 241001015,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "你说\"没人会拒绝几千美元\"——你说的是你自己吧？",
    "next": "241001016"
  },
  {
    "id": 241001016,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "我……那是我叔叔的房子！我是他的侄子！我有权——",
    "next": "241001017"
  },
  {
    "id": 241001017,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你有权什么？有权因为Rose是墨西哥裔就诬陷她？有权因为叔叔不给你留遗产就抹黑他的爱人？",
    "next": "241001018"
  },
  {
    "id": 241001018,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "Danny……我和Frank只是想安静地爱彼此。我们没有伤害任何人。",
    "next": "241001019"
  },
  {
    "id": 241001019,
    "cnSpeaker": "丹尼·科瓦尔斯基",
    "cnWords": "……",
    "next": "241001020"
  },
  {
    "id": 241001020,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Rose。Frank案发那天——你说他要做\"一件很冒险的事\"。你还知道什么？",
    "next": "241001021"
  },
  {
    "id": 241001021,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "Frank在家里藏了一个保险箱。他说里面有他调查了很久的东西。11月6号那天下午，他跟我说——\"今晚我要把这些东西带出去。\"",
    "next": "241001022"
  },
  {
    "id": 241001022,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "带去哪里？",
    "next": "241001023"
  },
  {
    "id": 241001023,
    "cnSpeaker": "罗斯·马丁内斯",
    "cnWords": "他没说。但他说——\"做完这件事，我们就自由了。\"",
    "next": "241001024"
  },
  {
    "id": 241001024,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "谢谢你，Rose。我会替Frank做完这件事。",
    "script": "end"
  }
]