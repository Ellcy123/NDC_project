[
  {
    "id": 207001001,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "这地方白天也营业？",
    "next": "207001002"
  },
  {
    "id": 207001002,
    "cnSpeaker": "托尼",
    "cnWords": "酒精不挑时间，朋友。喝点什么？",
    "next": "207001003"
  },
  {
    "id": 207001003,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "我不是来喝酒的。Zack Brennan，私家侦探。",
    "next": "207001004"
  },
  {
    "id": 207001004,
    "cnSpeaker": "托尼",
    "cnWords": "侦探。嗯。你找谁的麻烦？",
    "next": "207001005"
  },
  {
    "id": 207001005,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "不是找谁的麻烦。我在查一个叫Vinnie Moretti的人。听说他是这儿的常客。",
    "next": "207001006"
  },
  {
    "id": 207001006,
    "cnSpeaker": "托尼",
    "cnWords": "Vinnie……是啊，他来。经常来。",
    "next": "207001007"
  },
  {
    "id": 207001007,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "——",
    "next": "207001008"
  },
  {
    "id": 207001008,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "",
    "next": "207001101/207001201",
    "script": "branches",
    "ParameterStr0": "Vinnie平时在这儿干什么？",
    "ParameterInt0": 207001101,
    "ParameterStr1": "他花钱大方吗？",
    "ParameterInt1": 207001201
  },
  {
    "id": 207001101,
    "cnSpeaker": "托尼",
    "cnWords": "干什么？喝酒，吹牛。坐在角落里一个人喝，也不跟谁搭话。但每次结账的时候，把钱往柜台上一拍——",
    "next": "207001102"
  },
  {
    "id": 207001102,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "怎么了？",
    "next": "207001103"
  },
  {
    "id": 207001103,
    "cnSpeaker": "托尼",
    "cnWords": "崭新钞票。每次都是。你见过天天用新钞买酒的人吗？",
    "next": "207001104"
  },
  {
    "id": 207001104,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "多新？",
    "next": "207001105"
  },
  {
    "id": 207001105,
    "cnSpeaker": "托尼",
    "cnWords": "就跟刚从银行取出来似的。折痕都没有。而且他每次扔完钱就说——\"今天又赚了一笔。\"",
    "next": "207001106",
    "script": "get",
    "ParameterInt0": 2111001
  },
  {
    "id": 207001106,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "赚了一笔……他做什么生意？",
    "next": "207001107"
  },
  {
    "id": 207001107,
    "cnSpeaker": "托尼",
    "cnWords": "他从来不说。我也不问。在这行当里，问多了不长寿。",
    "next": "207001300"
  },
  {
    "id": 207001201,
    "cnSpeaker": "托尼",
    "cnWords": "大方？那倒不是。但他花的钱……怎么说呢。",
    "next": "207001202"
  },
  {
    "id": 207001202,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……",
    "next": "207001203"
  },
  {
    "id": 207001203,
    "cnSpeaker": "托尼",
    "cnWords": "每次掏出来的都是新钞。崭新的二十块。你在街上随便拉个人，口袋里的钞票哪有全新的？",
    "next": "207001204"
  },
  {
    "id": 207001204,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "他哪来这么多新钞？",
    "next": "207001205"
  },
  {
    "id": 207001205,
    "cnSpeaker": "托尼",
    "cnWords": "不知道。但他每次付完钱就笑嘻嘻地说——\"今天又赚了一笔。\"得意得很。",
    "next": "207001206",
    "script": "get",
    "ParameterInt0": 2111001
  },
  {
    "id": 207001206,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "赚了一笔。",
    "next": "207001207"
  },
  {
    "id": 207001207,
    "cnSpeaker": "托尼",
    "cnWords": "他的钱我照收。但我心里有数——这种钱来路不正。",
    "next": "207001300"
  },
  {
    "id": 207001300,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "他还说过别的什么吗？关于钱的。",
    "next": "207001301"
  },
  {
    "id": 207001301,
    "cnSpeaker": "托尼",
    "cnWords": "有一点我觉得奇怪——",
    "next": "207001302"
  },
  {
    "id": 207001302,
    "cnSpeaker": "托尼",
    "cnWords": "他每次说的都是\"赚钱\"、\"收钱\"。从来不说\"还债\"。你懂吗？",
    "next": "207001303",
    "script": "get",
    "ParameterInt0": 2111002
  },
  {
    "id": 207001303,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "赚钱、收钱——不是在花自己的钱，是在替别人跑腿。这是雇佣关系。",
    "next": "207001304"
  },
  {
    "id": 207001304,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你这报纸放了不少日子了。",
    "next": "207001305"
  },
  {
    "id": 207001305,
    "cnSpeaker": "托尼",
    "cnWords": "半年前的了。留着垫杯子用。",
    "next": "207001306"
  },
  {
    "id": 207001306,
    "cnSpeaker": "托尼",
    "cnWords": "侦探先生，你来我这酒吧查人，总得证明你不是随便哪个混饭吃的私家侦探吧。",
    "next": "207001307"
  },
  {
    "id": 207001307,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你想怎么证明？",
    "next": "207001308"
  },
  {
    "id": 207001308,
    "cnSpeaker": "托尼",
    "cnWords": "你进门看了一圈。那你说说——我这儿的招牌鸡尾酒叫什么？",
    "next": "207001309"
  },
  {
    "id": 207001309,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "",
    "next": "207001401/207001501/207001501",
    "script": "branches",
    "ParameterStr0": "Southside。",
    "ParameterInt0": 207001401,
    "ParameterStr1": "Manhattan。",
    "ParameterInt1": 207001501,
    "ParameterStr2": "Bee's Knees。",
    "ParameterInt2": 207001501
  },
  {
    "id": 207001401,
    "cnSpeaker": "托尼",
    "cnWords": "不错。你眼神挺好使。",
    "next": "207001402"
  },
  {
    "id": 207001402,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "配方卡上写得清清楚楚——Southside。这年头在芝加哥南区，连鸡尾酒都叫这个名字。",
    "next": "207001403"
  },
  {
    "id": 207001403,
    "cnSpeaker": "托尼",
    "cnWords": "行，你算有点本事。出了这扇门，今天的话我不认。但Vinnie那家伙——他在这儿的时候，我柜台底下总放着一根棒球棍。你自己掂量。",
    "next": "207001600"
  },
  {
    "id": 207001501,
    "cnSpeaker": "托尼",
    "cnWords": "不对。连配方卡都没看？",
    "next": "207001502"
  },
  {
    "id": 207001502,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……",
    "next": "207001600"
  },
  {
    "id": 207001600,
    "cnSpeaker": "托尼",
    "cnWords": "还有一件事——",
    "next": "207001601"
  },
  {
    "id": 207001601,
    "cnSpeaker": "托尼",
    "cnWords": "Vinnie有个小本子。黑皮的，口袋大小。他有时候在这儿翻，写写画画。我偷看过一眼——上面全是地址和日期。",
    "next": "207001602"
  },
  {
    "id": 207001602,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "谢了，Tony。",
    "next": "207001603"
  },
  {
    "id": 207001603,
    "cnSpeaker": "托尼",
    "cnWords": "出门左转。忘了我说过什么。",
    "script": "end"
  }
]