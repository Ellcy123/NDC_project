[
  {
    "id": 218100001,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Leonard Moore——搜查令。你住所的每一个角落，我们都要检查。",
    "next": "218100002"
  },
  {
    "id": 218100002,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……你们在浪费时间。",
    "next": "218100003"
  },
  {
    "id": 218100003,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "不介意我先问几个问题吧。",
    "next": "218100004"
  },
  {
    "id": 218100004,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "问。",
    "next": "218100005"
  },
  {
    "id": 218100005,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "我整晚在家，从来没有见过Frank，更没去过Margaret的鞋坊。",
    "script": "Lie",
    "ParameterStr0": "2608,2101001",
    "ParameterInt0": 218100100,
    "ParameterInt1": 1
  },
  {
    "id": 218100006,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Leonard，你知道我在鞋坊废墟的地板缝隙里发现了什么吗？",
    "next": "218100007"
  },
  {
    "id": 218100007,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "什么？",
    "next": "218100008"
  },
  {
    "id": 218100008,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "眼镜碎片。光学玻璃，有弧度——镜片碎片。卡在烛台下方的地板缝隙里。",
    "next": "218100009"
  },
  {
    "id": 218100009,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "眼镜碎片？那又怎么样。很多人都戴眼镜。",
    "next": "218100010"
  },
  {
    "id": 218100010,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "法医鉴定报告确认——Frank死于头部钝器击打。那个烛台就是凶器。",
    "next": "218100011"
  },
  {
    "id": 218100011,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "碎片卡在烛台底部缝隙里。说明凶手在打斗中眼镜摔碎了。",
    "next": "218100012"
  },
  {
    "id": 218100012,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "也许是Frank自己的——",
    "next": "218100013"
  },
  {
    "id": 218100013,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Frank不戴眼镜。",
    "next": "218100014"
  },
  {
    "id": 218100014,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "而且，我有目击证人。",
    "next": "218100015"
  },
  {
    "id": 218100015,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "\"11月6日晚八点二十左右，我在街角看到一个戴眼镜的西装男人从鞋坊方向匆匆离开。走路踉踉跄跄的，好像看不清路。\"",
    "next": "218100016"
  },
  {
    "id": 218100016,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "这是我母亲Margaret的证词。她回来的时候，看到Frank倒在地上，头上全是血。",
    "next": "218100017"
  },
  {
    "id": 218100017,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……那也不能证明是我。很多人都戴眼镜穿西装。",
    "next": "218100100"
  },
  {
    "id": 218100100,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "是吗。那我们来看看你的眼镜。",
    "next": "218100101"
  },
  {
    "id": 218100101,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "就算现场有碎片，也不能证明是我的。你没有证据。",
    "script": "Lie",
    "ParameterStr0": "2505",
    "ParameterInt0": 218100200,
    "ParameterInt1": 1
  },
  {
    "id": 218100102,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "你的眼镜——两只镜片颜色不一样。",
    "next": "218100103"
  },
  {
    "id": 218100103,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……什么？",
    "next": "218100104"
  },
  {
    "id": 218100104,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "右眼镜片透明，很新。左眼镜片偏黄——旧的。你最近补配了右眼镜片。",
    "next": "218100105"
  },
  {
    "id": 218100105,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "镜片变色很正常——",
    "next": "218100106"
  },
  {
    "id": 218100106,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "艾斯弗德光学眼镜店。客户：Leonard Moore。日期：1925年11月7号——更换右眼镜片，原镜片破损，加急当日取件。",
    "next": "218100107"
  },
  {
    "id": 218100107,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "案发第二天。右眼镜片。破损。加急。——现场碎片偏黄色，和你左眼的旧镜片颜色完全一致。",
    "next": "218100108"
  },
  {
    "id": 218100108,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……",
    "next": "218100109"
  },
  {
    "id": 218100109,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……好吧。是我的眼镜。",
    "next": "218100110"
  },
  {
    "id": 218100110,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "我那晚确实去了鞋坊。但我只是去拜访Frank，谈话中不小心摔坏了眼镜。仅此而已。",
    "next": "218100200"
  },
  {
    "id": 218100200,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "仅此而已？",
    "next": "218100201"
  },
  {
    "id": 218100201,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "我只是去拜访Frank，想劝他不要和银行作对。谈话中不小心摔坏了眼镜，但我绝对没有伤害他。",
    "script": "Lie",
    "ParameterStr0": "2101001,2601,2608",
    "ParameterInt0": 218100300,
    "ParameterInt1": 1
  },
  {
    "id": 218100202,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Leonard——我有件事要告诉你。",
    "next": "218100203"
  },
  {
    "id": 218100203,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "什么事？",
    "next": "218100204"
  },
  {
    "id": 218100204,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Vinnie Moretti已经认罪了。他承认纵火杀害了Frank。",
    "next": "218100205"
  },
  {
    "id": 218100205,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……Vinnie认罪了？那案子不就结了吗？",
    "next": "218100206"
  },
  {
    "id": 218100206,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "差不多。Vinnie承担了一切。",
    "next": "218100207"
  },
  {
    "id": 218100207,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "所以——",
    "next": "218100211/218100221",
    "script": "branches",
    "ParameterStr0": "\"即使那晚有人和Frank发生过争执……Vinnie也都承担了。你只需要告诉我真相。\"",
    "ParameterInt0": 218100211,
    "ParameterStr1": "\"你最好老实交代，否则我们会调查到底。\"",
    "ParameterInt1": 218100221
  },
  {
    "id": 218100211,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……",
    "next": "218100212"
  },
  {
    "id": 218100212,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "11月6号晚上，你和Frank之间到底发生了什么？",
    "next": "218100213"
  },
  {
    "id": 218100213,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……好吧。我承认。我和Frank那晚发生了争执。",
    "next": "218100230"
  },
  {
    "id": 218100221,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "你在威胁我？",
    "next": "218100222"
  },
  {
    "id": 218100222,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……不是那个意思。",
    "next": "218100230"
  },
  {
    "id": 218100230,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "我去劝Frank不要收集那些证据。他很固执……我们吵了起来。",
    "next": "218100231"
  },
  {
    "id": 218100231,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "我推了他，眼镜摔坏了。但我绝对没有用武器！",
    "next": "218100232"
  },
  {
    "id": 218100232,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "\"进门后看到Frank倒在地上，头上流了好多血。\"——这不像是\"推了他\"，Leonard。",
    "next": "218100233"
  },
  {
    "id": 218100233,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "这个烛台底座的凹痕，和Frank头骨的伤口完全吻合。你的眼镜碎片就卡在烛台底部。",
    "next": "218100234"
  },
  {
    "id": 218100234,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……",
    "next": "218100235"
  },
  {
    "id": 218100235,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "",
    "next": "218100241/218100251",
    "script": "branches",
    "ParameterStr0": "\"Leonard，Vinnie已经认罪了。你只需要告诉我真相。\"",
    "ParameterInt0": 218100241,
    "ParameterStr1": "\"证据确凿！你再不承认就要采取强制措施了！\"",
    "ParameterInt1": 218100251
  },
  {
    "id": 218100241,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "我……",
    "next": "218100260"
  },
  {
    "id": 218100251,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "你以为威胁对我有用？",
    "next": "218100260"
  },
  {
    "id": 218100260,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……",
    "next": "218100261"
  },
  {
    "id": 218100261,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "",
    "next": "218100271/218100281",
    "script": "branches",
    "ParameterStr0": "\"发生了什么，Leonard？\"",
    "ParameterInt0": 218100271,
    "ParameterStr1": "\"你最好现在就承认，否则后果自负！\"",
    "ParameterInt1": 218100281
  },
  {
    "id": 218100271,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……",
    "next": "218100290"
  },
  {
    "id": 218100281,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "你——",
    "next": "218100290"
  },
  {
    "id": 218100290,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "是！我承认！我用烛台打了他！",
    "next": "218100291"
  },
  {
    "id": 218100291,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "我去鞋坊找Frank——我想劝他把举报材料交出来！",
    "next": "218100292"
  },
  {
    "id": 218100292,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "他不听！他说他要去检察官那里！我很害怕——我花了十年才有现在的生活！",
    "next": "218100293"
  },
  {
    "id": 218100293,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "我们打了起来——我抓起烛台砸了他的头！",
    "next": "218100294"
  },
  {
    "id": 218100294,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "他倒在地上，头上流血，拐杖掉了，爬不起来！",
    "next": "218100295"
  },
  {
    "id": 218100295,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "但是侦探——我离开的时候他还活着！只是受伤！",
    "next": "218100296"
  },
  {
    "id": 218100296,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "Vinnie已经认罪了！是Vinnie后来烧死了他！我只是故意伤害，不是杀人！",
    "next": "218100300"
  },
  {
    "id": 218100300,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "……是吗。",
    "next": "218100301"
  },
  {
    "id": 218100301,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "我打伤了Frank，但Vinnie说这老家伙不听话，不如直接死了算了。然后他就放火了！真正的杀人犯是Vinnie！",
    "script": "Lie",
    "ParameterStr0": "2051004",
    "ParameterInt0": 218100400,
    "ParameterInt1": 1
  },
  {
    "id": 218100302,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Leonard，你确定——Vinnie到现场的时候，看到的是Frank受伤倒在地上？",
    "next": "218100303"
  },
  {
    "id": 218100303,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "当然！我刚说了！Frank倒在地上，头上流血！",
    "next": "218100304"
  },
  {
    "id": 218100304,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "那我们来看看Vinnie自己怎么说的。",
    "next": "218100305"
  },
  {
    "id": 218100305,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Vinnie的认罪证词——原话：\"我透过窗户看到那老头正在床上睡觉，然后我放火了。\"",
    "next": "218100306"
  },
  {
    "id": 218100306,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……什么？",
    "next": "218100307"
  },
  {
    "id": 218100307,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "\"在床上睡觉。\"——不是\"受伤倒在地上\"。不是\"拐杖掉了爬不起来\"。",
    "next": "218100308"
  },
  {
    "id": 218100308,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Vinnie说他看到Frank安静地躺在床上。",
    "next": "218100309"
  },
  {
    "id": 218100309,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "不……不可能……",
    "next": "218100310"
  },
  {
    "id": 218100310,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "如果真像你说的——Vinnie到场时Frank受伤倒在地上——Vinnie为什么要在认罪时说\"在床上睡觉\"？",
    "next": "218100311"
  },
  {
    "id": 218100311,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "答案只有一个。Vinnie到场时，Frank已经死了。",
    "next": "218100312"
  },
  {
    "id": 218100312,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Vinnie把尸体从地上搬到了床上。伪装成\"睡梦中死于火灾\"。",
    "next": "218100313"
  },
  {
    "id": 218100313,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "所以Vinnie认罪时说的是\"在床上睡觉\"——因为那是他自己布置的场景。",
    "next": "218100314"
  },
  {
    "id": 218100314,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Vinnie根本不知道你和Frank打过架。他不知道Frank受过伤。",
    "next": "218100315"
  },
  {
    "id": 218100315,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "因为Vinnie到场的时候，Frank已经死了。当时在场的，只有你。",
    "next": "218100316"
  },
  {
    "id": 218100316,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Leonard——你才是杀人凶手。",
    "next": "218100400"
  },
  {
    "id": 218100400,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……",
    "next": "218100401"
  },
  {
    "id": 218100401,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "……是我做的。",
    "next": "218100402"
  },
  {
    "id": 218100402,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "我用烛台砸了他……他当场就不呼吸了……我知道他死了……",
    "next": "218100403"
  },
  {
    "id": 218100403,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "我吓坏了……我花了十年才有今天的生活……我不能坐牢……",
    "next": "218100404"
  },
  {
    "id": 218100404,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "我打电话给Vinnie……我求他帮我处理……",
    "next": "218100405"
  },
  {
    "id": 218100405,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "我不知道他会把尸体搬到床上……我不知道他会认罪……",
    "next": "218100406"
  },
  {
    "id": 218100406,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "Vinnie他……为我做了这么多……",
    "next": "218100407"
  },
  {
    "id": 218100407,
    "cnSpeaker": "莱昂纳德·罗斯",
    "cnWords": "我真的不是故意的……我真的不是故意的……",
    "next": "218100408"
  },
  {
    "id": 218100408,
    "cnSpeaker": "艾玛·奥马利",
    "cnWords": "……",
    "next": "218100409"
  },
  {
    "id": 218100409,
    "cnSpeaker": "扎克·布伦南",
    "cnWords": "Leonard Russo。你因涉嫌谋杀Frank Kowalski被逮捕。",
    "script": "end"
  }
]