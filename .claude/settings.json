{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-dialogue.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-state.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-compact.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Agent",
      "Bash(ls -lh \"d:/NDC_project/AVG/对话配置工作及草稿/Loop\"*\"对话草稿\"*.md)",
      "Bash(sed 's/\\\\.md$//')",
      "Bash(sed 's/\\\\.json$//')",
      "Bash(xargs md5sum)",
      "Bash(python3 -c \":*)",
      "Bash(python3 -u -c \":*)",
      "Bash(ls -la \"d:\\\\NDC_project\\\\质量检查文档\"\" 2>/dev/null || ls -la \"d:/NDC_project/质量检查文档/ \")",
      "Bash(claude --version)",
      "Bash(echo $CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS)"
    ],
    "additionalDirectories": [
      "D:\\NDC_project\\AVG\\对话配置工作及草稿\\前置配置",
      "d:\\NDC_project\\.claude\\commands",
      "D:\\NDC_project\\docs\\游戏系统",
      "C:\\Users\\Ellcy\\.claude\\channels\\telegram"
    ]
  }
}
