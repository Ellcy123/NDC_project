    <script>
    // ===== Utilities =====
    function stripPrefix(id) {
        if (id == null) return '';
        id = String(id);
        if (id.startsWith('EV')) return id.slice(2);
        if (id.startsWith('SC')) return id.slice(2);
        if (id.startsWith('NPC')) return id.slice(3);
        return id;
    }

    function cn(field) {
        if (Array.isArray(field)) return field[0] || '';
        return field || '';
    }

    function truncate(str, len) {
        str = str || '';
        return str.length > len ? str.slice(0, len) + '...' : str;
    }

    function escapeHtml(str) {
        const div = document.createElement('div');
        div.textContent = str || '';
        return div.innerHTML;
    }

    function escapeHtmlWithBr(str) {
        return escapeHtml(str).replace(/\n/g, '<br>');
    }

    function copyText(text, el) {
        navigator.clipboard.writeText(text).then(() => {
            const orig = el.textContent;
            el.textContent = '已复制!';
            el.style.background = 'rgba(80,200,120,0.3)';
            setTimeout(() => { el.textContent = orig; el.style.background = ''; }, 800);
        });
    }

    // ===== Configuration =====
    const Config = {
        // 自动检测：localhost/127.0.0.1 = local，否则 = deploy
        get mode() {
            const h = location.hostname;
            return (h === 'localhost' || h === '127.0.0.1' || location.protocol === 'file:') ? 'local' : 'deploy';
        },
        get paths() {
            if (this.mode === 'deploy') {
                // Vercel: 从 NDC_project/ 部署, rewrite / → /preview_new2/index.html
                return {
                    tableData: '/preview_new2/data/table',
                    loopConfig: '/preview_new2/data',
                    assets: '/Assets/Resources',
                    avgData: '/AVG'
                };
            }
            // 本地: 从 D:\ 启动 server, 访问 /NDC_project/preview_new2/index.html
            return {
                tableData: '/NDC_project/preview_new2/data/table',
                loopConfig: '/NDC_project/preview_new2/data',
                assets: '/NDC/Assets/Resources',
                avgData: '/NDC_project/AVG'
            };
        },
        getAssetUrl(configPath) {
            if (!configPath) return '';
            return `${this.paths.assets}/${configPath.replace(/\\/g, '/')}.png`;
        }
    };

    // ===== App State =====
    const AppState = {
        currentUnit: 'Unit1',
        currentLoop: 'loop1',
        currentView: 'flow',

        allItems: [],
        allScenes: [],
        allNPCs: [],
        allTalks: [],

        itemsMap: new Map(),
        scenesMap: new Map(),
        npcsMap: new Map(),
        talksMap: new Map(),

        talkSummaries: {},
        sceneTalkSummaries: {},
        storyOverview: {},
        chapterConfigs: [],
        chapterConfigMap: new Map(),

        loopData: null,
        locationsData: null,
        collectedEvidences: new Set(),
        selectedEvidences: new Set(),
        currentPhase: null,
        currentSceneId: null,

        reset() {
            this.collectedEvidences.clear();
            this.selectedEvidences.clear();
            this.currentPhase = null;
            this.currentSceneId = null;
        }
    };

    // ===== Data Loader =====
    const DataLoader = {
        async loadJSON(path) {
            const resp = await fetch(path);
            if (!resp.ok) throw new Error(`HTTP ${resp.status}: ${path}`);
            const text = await resp.text();
            return JSON.parse(this.fixJson(text));
        },

        // 状态机修复游戏导出的非标准 JSON：
        // 1. 字符串内字面换行符 → 空格  (Describe 字段跨行)
        // 2. 未转义反斜杠 → \\          (Art\Scene 路径)
        // 3. 字符串内裸双引号 → \"       (中文引号用了ASCII双引号)
        fixJson(text) {
            let out = '';
            let inStr = false;
            for (let i = 0; i < text.length; i++) {
                const c = text.charAt(i);
                if (!inStr) {
                    out += c;
                    if (c === '"') inStr = true;
                    continue;
                }
                // 以下都在字符串内部
                if (c === '\\') {
                    const nx = text.charAt(i + 1);
                    if ('"\\\/bfnrt'.includes(nx)) {
                        out += c + nx; i++;           // 合法 2 字符转义
                    } else if (nx === 'u' && /^[0-9a-fA-F]{4}$/.test(text.substring(i + 2, i + 6))) {
                        out += text.substring(i, i + 6); i += 5; // 合法 \uXXXX
                    } else {
                        out += '\\\\';                // 修正非法反斜杠
                    }
                } else if (c === '"') {
                    // 判断是字符串结束引号还是内容引号
                    // 关键：跳过空白后检查下一个非空白字符是否为 JSON 结构符
                    const nx = text.charAt(i + 1);
                    if (nx === '' || ',:]}'.includes(nx)) {
                        out += c; inStr = false;      // 明确的结束引号
                    } else if (' \t\r\n'.includes(nx)) {
                        // 引号后是空白 → 向前看跳过空白
                        let j = i + 1;
                        while (j < text.length && ' \t\r\n'.includes(text.charAt(j))) j++;
                        const after = text.charAt(j);
                        if (after === '' || ',:]}'.includes(after)) {
                            out += c; inStr = false;  // 空白后是结构符 → 结束引号
                        } else {
                            out += '\\"';             // 空白后还是内容 → 内容引号
                        }
                    } else {
                        out += '\\"';                 // 后面直接是内容字符 → 内容引号
                    }
                } else if (c === '\n') {
                    out += '\\n';                     // 字符串内换行 → 保留为 \n
                } else if (c === '\r') {
                    // 忽略 CR（\r\n 中的 \r）
                } else {
                    out += c;
                }
            }
            return out;
        },

        async loadYAML(path) {
            const resp = await fetch(`${path}?t=${Date.now()}`);
            if (!resp.ok) throw new Error(`HTTP ${resp.status}: ${path}`);
            return jsyaml.load(await resp.text());
        },

        async loadTableData() {
            const base = Config.paths.tableData;
            const t = `?t=${Date.now()}`;

            const [items, scenes, npcs] = await Promise.all([
                this.loadJSON(`${base}/ItemStaticData.json${t}`),
                this.loadJSON(`${base}/SceneConfig.json${t}`),
                this.loadJSON(`${base}/NPCStaticData.json${t}`)
            ]);

            AppState.allItems = items;
            AppState.allScenes = scenes;
            AppState.allNPCs = npcs;

            AppState.itemsMap.clear();
            items.forEach(i => AppState.itemsMap.set(String(i.id), i));

            AppState.scenesMap.clear();
            scenes.forEach(s => AppState.scenesMap.set(String(s.sceneId), s));

            AppState.npcsMap.clear();
            npcs.forEach(n => AppState.npcsMap.set(String(n.id), n));

            console.log(`Table data loaded: ${items.length} items, ${scenes.length} scenes, ${npcs.length} NPCs`);
        },

        async loadLoopConfig(unit, loop) {
            try {
                const path = `${Config.paths.loopConfig}/${unit}/${loop}.yaml`;
                AppState.loopData = await this.loadYAML(path);
                console.log('Loop config loaded:', AppState.loopData?.title);
            } catch (e) {
                console.warn('Loop config not available:', e.message);
                AppState.loopData = null;
            }
            // Load locations hierarchy
            try {
                const locPath = `${Config.paths.loopConfig}/${unit}/locations.yaml`;
                AppState.locationsData = await this.loadYAML(locPath);
            } catch (e) {
                AppState.locationsData = null;
            }
        },

        async loadChapterConfig() {
            try {
                const base = Config.paths.tableData;
                const t = `?t=${Date.now()}`;
                const data = await this.loadJSON(`${base}/ChapterConfig.json${t}`);
                AppState.chapterConfigs = data;
                AppState.chapterConfigMap.clear();
                data.forEach(c => AppState.chapterConfigMap.set(String(c.id), c));
                console.log(`ChapterConfig loaded: ${data.length} entries`);
            } catch (e) {
                console.warn('ChapterConfig not available:', e.message);
                AppState.chapterConfigs = [];
            }
        },

        async loadTalkSummaries(unit) {
            AppState.talkSummaries = {};
            AppState.sceneTalkSummaries = {};
            try {
                const path = `${Config.paths.loopConfig}/${unit}/talk_summary.yaml`;
                const data = await this.loadYAML(path);
                if (!data) return;
                // 分离 scene_talks 和普通摘要
                Object.entries(data).forEach(([key, val]) => {
                    if (key === 'scene_talks' && typeof val === 'object') {
                        Object.entries(val).forEach(([sceneId, summary]) => {
                            AppState.sceneTalkSummaries[String(sceneId)] = summary;
                        });
                    } else {
                        AppState.talkSummaries[String(key)] = val;
                    }
                });
                console.log(`Talk summaries loaded: ${Object.keys(AppState.talkSummaries).length} entries, ${Object.keys(AppState.sceneTalkSummaries).length} scene overrides`);
            } catch (e) {
                console.warn('Talk summaries not available:', e.message);
            }
        },

        async loadStoryOverview(unit) {
            AppState.storyOverview = {};
            try {
                const path = `${Config.paths.loopConfig}/${unit}/story_overview.yaml`;
                const data = await this.loadYAML(path);
                if (data) {
                    Object.entries(data).forEach(([k, v]) => {
                        AppState.storyOverview[k] = v;
                    });
                }
            } catch (e) { /* silent */ }
        },

        // ===== AVG Talk 加载 =====

        // 发现目录下的 .json 文件：优先读 _manifest.json，回退到 HTTP 目录列表
        async listJsonFiles(dirUrl) {
            // 1. 尝试读取 deploy 时生成的清单文件
            try {
                const resp = await fetch(`${dirUrl}_manifest.json?t=${Date.now()}`);
                if (resp.ok) {
                    const files = await resp.json();
                    if (Array.isArray(files) && files.length > 0) return files;
                }
            } catch (e) { /* 清单不存在，回退 */ }

            // 2. 回退：解析 Python HTTP server 的目录列表 HTML
            try {
                const resp = await fetch(dirUrl);
                if (!resp.ok) return [];
                const html = await resp.text();
                const matches = [...html.matchAll(/href="([^"]+\.json)"/gi)];
                return matches.map(m => m[1]).filter(f => f !== '_manifest.json');
            } catch (e) { return []; }
        },

        // AVG 扁平格式 → 内部 Talk 格式
        convertAVGTalk(entry) {
            const npcId = (entry.IdSpeaker || '').replace(/^NPC/, '');
            const npcData = AppState.npcsMap.get(npcId);
            return {
                id: String(entry.id),
                step: String(entry.step || ''),
                speakType: entry.speakType,
                waitTime: String(entry.waitTime || 0),
                Speaker: {
                    id: npcId,
                    Name: [entry.cnSpeaker || '', entry.enSpeaker || ''],
                    role: npcData?.role || '',
                    Chapter: npcData?.Chapter || '',
                    IconSmall: npcData?.IconSmall || '',
                    IconLarge: npcData?.IconLarge || ''
                },
                Words: [entry.cnWords || '', entry.enWords || ''],
                next: entry.next ? String(entry.next) : '',
                script: entry.script || '',
                Parameters: this._buildParameters(entry),
                // AVG 独有字段
                cnAction: entry.cnAction || '',
                enAction: entry.enAction || '',
                Location: entry.Location || '',
                // 视频字段
                videoEpisode: entry.videoEpisode || '',
                videoLoop: entry.videoLoop || '',
                videoScene: entry.videoScene || '',
                videoId: entry.videoId ? String(entry.videoId) : ''
            };
        },

        _buildParameters(entry) {
            const params = [];
            for (let i = 0; i < 3; i++) {
                const str = entry[`ParameterStr${i}`] || '';
                const int = entry[`ParameterInt${i}`];
                if (str || int) {
                    params.push({ ParameterStr: str, ParameterInt: String(int || 0) });
                }
            }
            return params.length > 0 ? params : [{ ParameterInt: '0' }];
        },

        // 加载指定 loop 的所有 AVG Talk 文件
        async loadAVGTalks(loop) {
            const base = Config.paths.avgData;
            const episode = DataManager.chapter(AppState.currentUnit);
            const dirUrl = `${base}/${episode}/Talk/${loop}/`;

            AppState.talksMap.clear();
            AppState.allTalks = [];
            let totalLoaded = 0;

            try {
                const files = await this.listJsonFiles(dirUrl);
                if (files.length === 0) {
                    console.warn(`No AVG Talk files found in ${dirUrl}`);
                    return 0;
                }

                const results = await Promise.all(
                    files.map(async (filename) => {
                        try {
                            const resp = await fetch(`${dirUrl}${filename}?t=${Date.now()}`);
                            if (!resp.ok) return { filename, entries: [] };
                            return { filename, entries: await resp.json() };
                        } catch (e) {
                            console.warn(`Failed to load AVG Talk: ${filename}`, e.message);
                            return { filename, entries: [] };
                        }
                    })
                );

                const sceneName = (fn) => fn.replace(/\.json$/i, '');
                results.forEach(({ filename, entries }) => {
                    const vs = sceneName(filename);
                    entries.forEach(raw => {
                        const talk = this.convertAVGTalk(raw);
                        if (!talk.videoScene) talk.videoScene = vs;
                        AppState.talksMap.set(talk.id, talk);
                        AppState.allTalks.push(talk);
                        totalLoaded++;
                    });
                });

                console.log(`AVG Talk loaded: ${totalLoaded} entries from ${files.length} files (${loop})`);
            } catch (e) {
                console.warn('AVG Talk loading failed:', e.message);
            }
            return totalLoaded;
        },

        // 加载指定 loop 的 Expose 对话文件
        async loadAVGExpose(loop) {
            const base = Config.paths.avgData;
            const episode = DataManager.chapter(AppState.currentUnit);
            const dirUrl = `${base}/${episode}/Expose/`;
            const loopNum = loop.replace('loop', '');
            let totalLoaded = 0;

            try {
                const allFiles = await this.listJsonFiles(dirUrl);
                // 筛选当前 loop 的 expose 文件 (如 loop1_rosa.json)
                const loopFiles = allFiles.filter(f => f.startsWith(`loop${loopNum}_`));

                if (loopFiles.length === 0) {
                    console.warn(`No AVG Expose files found for ${loop}`);
                    return 0;
                }

                const results = await Promise.all(
                    loopFiles.map(async (filename) => {
                        try {
                            const resp = await fetch(`${dirUrl}${filename}?t=${Date.now()}`);
                            if (!resp.ok) return { filename, entries: [] };
                            return { filename, entries: await resp.json() };
                        } catch (e) {
                            console.warn(`Failed to load AVG Expose: ${filename}`, e.message);
                            return { filename, entries: [] };
                        }
                    })
                );

                const sceneName = (fn) => fn.replace(/\.json$/i, '');
                results.forEach(({ filename, entries }) => {
                    const vs = sceneName(filename);
                    entries.forEach(raw => {
                        const talk = this.convertAVGTalk(raw);
                        if (!talk.videoScene) talk.videoScene = vs;
                        AppState.talksMap.set(talk.id, talk);
                        AppState.allTalks.push(talk);
                        totalLoaded++;
                    });
                });

                console.log(`AVG Expose loaded: ${totalLoaded} entries from ${loopFiles.length} files (${loop})`);
            } catch (e) {
                console.warn('AVG Expose loading failed:', e.message);
            }
            return totalLoaded;
        }
    };

    // ===== Data Manager =====
    const DataManager = {
        getItem(id) {
            return AppState.itemsMap.get(stripPrefix(id)) || null;
        },

        getScene(id) {
            return AppState.scenesMap.get(stripPrefix(id)) || null;
        },

        getNPC(id) {
            return AppState.npcsMap.get(stripPrefix(id)) || null;
        },

        itemName(item) { return cn(item?.Name); },
        itemDesc(item) { return cn(item?.Describe); },
        itemShortDesc(item) { return cn(item?.ShortDescribe); },
        itemLocation(item) { return cn(item?.location); },

        typeName(type) {
            return { '0': '装饰', '1': '线索', '2': '环境', '3': '道具', '4': '笔记', '5': '门', '6': '可交互道具', '7': '内嵌道具' }[String(type)] || type || '?';
        },
        typeClass(type) {
            return { '1': 'type-clue', '2': 'type-envir', '3': 'type-item', '4': 'type-note' }[String(type)] || '';
        },

        chapter(unit) {
            if (unit === 'Unit3') return 'EPI03';
            if (unit === 'Unit8') return 'EPI08';
            if (unit === 'Unit9') return 'EPI09';
            return unit === 'Unit2' ? 'EPI02' : 'EPI01';
        },

        itemsByChapter(chapter) {
            return AppState.allItems.filter(i => i.Chapter === chapter);
        },

        // 反查：给定原料ID，找到哪个产物的combineParameter包含它
        findCombineProduct(ingredientId) {
            const id = stripPrefix(ingredientId);
            return AppState.allItems.find(i => Array.isArray(i.combineParameter) && i.combineParameter.includes(id));
        },

        // Scene ID prefix for a given unit+loop: Unit1/loop1 -> "11", Unit8/loop3 -> "83"
        loopPrefix(unit, loop) {
            let u = '1';
            if (unit === 'Unit3') u = '3';
            else if (unit === 'Unit2') u = '2';
            else if (unit === 'Unit8') u = '8';
            else if (unit === 'Unit9') u = '9';
            const l = loop.replace('loop', '');
            return `${u}${l}`;
        },

        scenesForLoop(unit, loop) {
            const prefix = this.loopPrefix(unit, loop);
            return AppState.allScenes.filter(s => String(s.sceneId).startsWith(prefix));
        },

        // Get evidence items from a scene's ItemIDs (skip IDs not in ItemStaticData)
        sceneEvidence(sceneId) {
            const scene = this.getScene(sceneId);
            if (!scene?.ItemIDs) return [];
            return scene.ItemIDs.map(id => this.getItem(id)).filter(Boolean);
        },

        sceneNPCs(sceneId) {
            const scene = this.getScene(sceneId);
            return scene?.NPCInfos || [];
        },

        // Get non-evidence ItemIDs (those not found in ItemStaticData)
        sceneOtherItems(sceneId) {
            const scene = this.getScene(sceneId);
            if (!scene?.ItemIDs) return [];
            return scene.ItemIDs.filter(id => !this.getItem(id));
        },

        // Find talk file (videoScene) where given NPC id is the primary non-Zack speaker
        // Used when SceneConfig.NPCInfos[i].TalkInfo.id is empty (Unit9 case)
        findTalkForNPC(npcId) {
            if (!npcId) return '';
            const target = `NPC${String(npcId)}`;
            for (const talk of AppState.allTalks) {
                if (talk.IdSpeaker === target && talk.videoScene) {
                    return talk.videoScene;
                }
            }
            return '';
        },

        getTalk(id) {
            if (id == null) return null;
            const key = String(id);
            const direct = AppState.talksMap.get(key);
            if (direct) return direct;
            // Unit8 uses videoScene names (e.g. "jimmy_001") as TalkInfo.id —
            // resolve to the AVG Talk entry with smallest step whose videoScene matches.
            if (!/^\d+$/.test(key)) {
                let first = null;
                for (const talk of AppState.talksMap.values()) {
                    if (talk.videoScene === key) {
                        const step = parseInt(talk.step) || 0;
                        if (!first || step < (parseInt(first.step) || 0)) first = talk;
                    }
                }
                return first || null;
            }
            return null;
        },

        getTalkSummary(talkId, sceneId) {
            if (sceneId && AppState.sceneTalkSummaries[String(sceneId)]) {
                return AppState.sceneTalkSummaries[String(sceneId)];
            }
            return AppState.talkSummaries[String(talkId)] || '';
        },

        getChapterConfig(unit, loop) {
            let unitNum = 1;
            if (unit === 'Unit3') unitNum = 3;
            else if (unit === 'Unit2') unitNum = 2;
            else if (unit === 'Unit8') unitNum = 8;
            else if (unit === 'Unit9') unitNum = 9;
            const loopNum = parseInt(loop.replace('loop', ''));
            const id = String(unitNum * 100 + loopNum);
            return AppState.chapterConfigMap.get(id) || null;
        },

        extractNpcKey(resPath) {
            if (!resPath) return '';
            const m = resPath.match(/_npc_([A-Za-z]+)\d*$/);
            return m ? m[1] : '';
        },

        // 从起始 Talk ID 遍历对话链，返回节点数组
        // 每个节点: { talk, branches: null | [{text, targetId}] }
        // 分支检测: script === "1" 且 Parameters 含 ParameterStr/ParameterInt
        buildDialogueChain(startId) {
            const chain = [];
            const visited = new Set();
            let currentId = String(startId);

            while (currentId && !visited.has(currentId)) {
                visited.add(currentId);
                const talk = this.getTalk(currentId);
                if (!talk) break;

                const node = { talk, branches: null };

                // 检测分支: script "1" 或 "branches" + Parameters 含 ParameterStr/ParameterInt
                if ((talk.script === '1' || talk.script === 'branches') && talk.Parameters && talk.Parameters.length > 0) {
                    const branchParams = talk.Parameters.filter(p => p.ParameterStr && p.ParameterInt);
                    if (branchParams.length > 0) {
                        node.branches = branchParams.map(p => ({
                            text: p.ParameterStr,
                            targetId: String(p.ParameterInt)
                        }));
                        chain.push(node);
                        break; // 分支处停止主链
                    }
                }

                if (!talk.next) {
                    // Lie (指证) entries: auto-follow ParameterInt0 jump target
                    const isLie = talk.script === 'Lie' || talk.script === 'lie';
                    const lieTarget = talk.Parameters?.[0]?.ParameterInt;
                    if (isLie && lieTarget && lieTarget !== '0') {
                        chain.push(node);
                        currentId = lieTarget;
                        continue;
                    }
                    // 无 next → 对话结束
                    chain.push(node);
                    break;
                }

                const nextStr = String(talk.next);
                if (nextStr.includes('/')) {
                    // 旧格式分支: next = "id1/id2/id3"
                    const branchIds = nextStr.split('/');
                    const params = talk.Parameters || [];
                    node.branches = branchIds.map((bid, i) => ({
                        text: params[i]?.ParameterStr || `选项 ${i + 1}`,
                        targetId: bid.trim()
                    }));
                    chain.push(node);
                    break;
                }

                chain.push(node);
                currentId = nextStr;
            }
            return chain;
        }
    };

