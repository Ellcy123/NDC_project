        render() {
            const chapter = DataManager.chapter(AppState.currentUnit);

            // Count stats for tab badges
            const items = DataManager.itemsByChapter(chapter);
            const evNoArt = items.filter(i => !i.ArtRequirement).length;

            const npcs = AppState.allNPCs.filter(n => n.Chapter === chapter);
            const npcNoArt = npcs.filter(n => !n.ArtRequirement).length;

            const chPrefix = chapter === 'EPI01' ? '1' : chapter === 'EPI02' ? '2' : chapter === 'EPI08' ? '8' : chapter === 'EPI09' ? '9' : '3';
            const rawScenes = AppState.allScenes.filter(s => s.sceneId && String(s.sceneId).startsWith(chPrefix));
            const mergedScenes = this._mergeScenes(rawScenes);
            const scNoArt = mergedScenes.filter(m => !m.ArtRequirement).length;

            // Tab bar
            let html = `<div class="art-tab-bar">`;
            html += `<div class="art-tab ${this.currentTab === 'evidence' ? 'active' : ''}" onclick="ArtOverviewView.switchTab('evidence')">
                证据需求 ${evNoArt > 0 ? `<span class="tab-badge">${evNoArt}</span>` : `<span class="tab-badge done">${items.length}</span>`}
            </div>`;
            html += `<div class="art-tab ${this.currentTab === 'npc' ? 'active' : ''}" onclick="ArtOverviewView.switchTab('npc')">
                人物需求 ${npcNoArt > 0 ? `<span class="tab-badge">${npcNoArt}</span>` : `<span class="tab-badge done">${npcs.length}</span>`}
            </div>`;
            html += `<div class="art-tab ${this.currentTab === 'scene' ? 'active' : ''}" onclick="ArtOverviewView.switchTab('scene')">
                场景需求 ${scNoArt > 0 ? `<span class="tab-badge">${scNoArt}</span>` : `<span class="tab-badge done">${mergedScenes.length}</span>`}
            </div>`;
            html += `</div>`;

