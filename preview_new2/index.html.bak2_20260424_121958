<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NDC Preview v4.0 (New Table)</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Noto+Serif+SC:wght@500;600&family=Noto+Sans+SC:wght@400;500&display=swap" rel="stylesheet">
    <script>
    // js-yaml: 根据环境选择路径
    (function(){
        var h = location.hostname;
        var isLocal = (h === 'localhost' || h === '127.0.0.1' || location.protocol === 'file:');
        var src = isLocal ? '/NDC_project/preview_new2/js-yaml.min.js' : '/preview_new2/js-yaml.min.js';
        document.write('<scr'+'ipt src="'+src+'"><\/scr'+'ipt>');
    })();
    </script>
    <style>
        /* ===== CSS Variables (noir palette, legacy names preserved) ===== */
        :root {
            --primary: #0a0a0a;
            --secondary: #121212;
            --card: #201d1a;
            --accent: #b84040;
            --highlight: #e8c678;
            --text-primary: #f0e6d2;
            --text-secondary: #d8cfbb;
            --text-muted: #968c78;
            --success: #6b8f5e;
            --warning: #c78a3a;
            --border: #2e2823;

            /* new noir tokens */
            --coal-3: #1a1818;
            --ink-2: #2a2623;
            --rule-2: #3a322b;
            --gold-2: #b89650;
            --parchment: #f0e6d2;
            --parch-mute: #c9bfa9;
            --text-faint: #60584c;
            --brick-2: #8a2e2e;
            --ok-2: #3f5a38;
            --miss: #b84040;
            --locked: #4a443d;
            --ff-serif: "Playfair Display", "Noto Serif SC", "Cormorant Garamond", Georgia, serif;
            --ff-sans: "Inter", "Noto Sans SC", ui-sans-serif, system-ui, -apple-system, sans-serif;
            --ff-mono: "JetBrains Mono", "IBM Plex Mono", ui-monospace, Menlo, monospace;
        }

        /* ===== Paper grain & vignette (fixed overlays, pointer-events: none) ===== */
        .grain {
            pointer-events: none;
            position: fixed; inset: 0; z-index: 9999;
            opacity: .06; mix-blend-mode: overlay;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='180' height='180'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='.92' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.9 0 0 0 0 0.85 0 0 0 0 0.7 0 0 0 .6 0'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
        }
        .vignette {
            pointer-events: none;
            position: fixed; inset: 0; z-index: 9998;
            background: radial-gradient(ellipse at center, transparent 55%, rgba(0,0,0,.45) 100%);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: var(--ff-sans);
            background: var(--primary);
            color: var(--text-secondary);
            line-height: 1.55;
            height: 100vh;
            overflow: hidden;
            -webkit-font-smoothing: antialiased;
            text-rendering: optimizeLegibility;
            font-size: 13px;
        }

        .app {
            display: flex;
            flex-direction: column;
            height: 100vh;
        }

        /* ===== Header (noir topbar) ===== */
        .header {
            background:
                linear-gradient(180deg, rgba(255,255,255,.02) 0%, rgba(0,0,0,.25) 100%),
                var(--secondary);
            padding: 0 1.25rem;
            height: 56px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: relative;
            flex-shrink: 0;
        }
        .header::after {
            content: ""; position: absolute; left: 0; right: 0; bottom: -1px; height: 1px;
            background: linear-gradient(90deg, transparent, var(--gold-2) 20%, var(--gold-2) 80%, transparent);
            opacity: .18;
        }

        .header-title {
            font-family: var(--ff-serif);
            font-size: 1rem;
            color: var(--parchment);
            font-weight: 600;
            letter-spacing: .04em;
        }

        /* ===== Brand block (left of header) ===== */
        .brand {
            display: flex; align-items: center; gap: 10px;
            min-width: 200px;
        }
        .brand-mark {
            width: 28px; height: 28px; border-radius: 2px;
            background: var(--primary); border: 1px solid var(--gold-2);
            display: grid; place-items: center;
            color: var(--highlight); font-family: var(--ff-serif); font-weight: 700;
            font-size: 14px; letter-spacing: .05em;
            box-shadow: 0 0 0 1px var(--secondary) inset;
            flex-shrink: 0;
        }
        .brand-text { line-height: 1.15; }
        .brand-name {
            font-family: var(--ff-serif); font-size: 15px;
            color: var(--parchment); letter-spacing: .04em;
        }
        .brand-sub {
            font-family: var(--ff-mono); font-size: 9.5px;
            color: var(--text-faint); letter-spacing: .18em; text-transform: uppercase;
            margin-top: 1px;
        }

        /* ===== Header center (unit/loop pickers + load) ===== */
        .header-center {
            flex: 1;
            display: flex; align-items: center; gap: 10px;
            justify-content: center;
        }
        .header-right {
            display: flex; gap: 4px; align-items: center;
            min-width: 200px; justify-content: flex-end;
        }

        /* select-group: UNIT label + <select> together in a framed pill */
        .select-group {
            display: inline-flex; align-items: center; gap: 8px;
            background: var(--coal-3); border: 1px solid var(--border); border-radius: 2px;
            height: 30px; padding: 0 8px 0 10px;
            transition: border-color .15s ease-out;
        }
        .select-group:hover { border-color: var(--gold-2); }
        .select-group:focus-within { border-color: var(--gold-2); }
        .select-group .select-label {
            font-family: var(--ff-mono); font-size: 9.5px;
            color: var(--gold-2); letter-spacing: .18em;
            flex-shrink: 0;
        }
        .select-group select {
            border: 0; background: transparent; height: 28px;
            padding: 0 22px 0 0;
            background-position: right 2px center;
        }
        .select-group select:hover, .select-group select:focus { border: 0; }

        /* Legacy .header-controls fallback (still referenced nowhere now, but safe) */
        .header-controls {
            display: flex;
            gap: 0.4rem;
            align-items: center;
        }

        /* primary/ghost button variants */
        .btn.primary {
            background: var(--highlight); color: var(--primary);
            border-color: var(--highlight);
            font-weight: 600;
        }
        .btn.primary:hover {
            background: var(--gold-2); color: var(--primary);
            border-color: var(--gold-2);
        }
        .btn.ghost {
            background: transparent; color: var(--text-secondary);
            border-color: transparent;
            text-decoration: none;
        }
        .btn.ghost:hover {
            color: var(--highlight); border-color: var(--border); background: var(--coal-3);
        }

        /* ===== Main Tabs (below header, above main) ===== */
        .main-tabs {
            display: flex; align-items: flex-end;
            padding: 0 20px;
            background: var(--secondary);
            border-bottom: 1px solid var(--border);
            flex-shrink: 0;
        }
        .main-tab {
            position: relative;
            padding: 12px 18px 10px;
            font-family: var(--ff-serif);
            font-size: 13px; letter-spacing: .04em;
            color: var(--text-muted); background: transparent;
            border: 0; cursor: pointer;
            transition: color .15s ease-out;
            text-decoration: none;
            display: inline-flex; align-items: baseline;
        }
        .main-tab:hover { color: var(--parchment); }
        .main-tab .tab-idx {
            font-family: var(--ff-mono); font-size: 10px;
            color: var(--gold-2); margin-right: 6px;
        }
        .main-tab.active { color: var(--parchment); }
        .main-tab.active::after {
            content: ""; position: absolute; left: 10px; right: 10px; bottom: -1px; height: 2px;
            background: var(--accent);
        }
        .tab-meta {
            margin-left: auto;
            font-family: var(--ff-mono); font-size: 10px;
            color: var(--text-faint);
            padding-bottom: 12px; letter-spacing: .08em;
        }

        select {
            background: var(--coal-3);
            color: var(--parchment);
            border: 1px solid var(--border);
            padding: 0 1.8rem 0 0.7rem;
            height: 30px;
            border-radius: 2px;
            cursor: pointer;
            font-family: var(--ff-sans);
            font-size: 12px;
            letter-spacing: .02em;
            appearance: none; -webkit-appearance: none;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='6' viewBox='0 0 10 6'><path d='M1 1l4 4 4-4' stroke='%23b89650' stroke-width='1.3' fill='none'/></svg>");
            background-repeat: no-repeat;
            background-position: right 10px center;
            transition: border-color .15s ease-out, background-color .15s ease-out;
        }
        select:hover, select:focus { border-color: var(--gold-2); outline: none; }
        select option { background: var(--secondary); color: var(--parchment); }

        .btn {
            background: transparent;
            color: var(--text-secondary);
            border: 1px solid var(--border);
            padding: 0 0.9rem;
            height: 30px;
            border-radius: 2px;
            cursor: pointer;
            font-family: var(--ff-mono);
            font-size: 11px;
            letter-spacing: .08em;
            transition: color .15s ease-out, border-color .15s ease-out, background .15s ease-out;
            display: inline-flex; align-items: center;
        }
        .btn:hover { color: var(--highlight); border-color: var(--gold-2); background: var(--coal-3); }
        .btn.active {
            color: var(--primary);
            background: var(--highlight);
            border-color: var(--highlight);
        }
        .btn.active:hover { background: var(--highlight); color: var(--primary); }

        /* ===== Main Layout ===== */
        .main {
            display: flex;
            flex: 1;
            overflow: hidden;
        }

        /* ===== Sidebar ===== */
        .sidebar {
            width: 260px;
            background: var(--secondary);
            border-right: 1px solid var(--border);
            overflow-y: auto;
            overflow-x: hidden;
            padding: 0.4rem 0 2rem;
            flex-shrink: 0;
        }
        .sidebar::-webkit-scrollbar { width: 6px; }
        .sidebar::-webkit-scrollbar-thumb { background: var(--rule-2); border-radius: 3px; }

        .sidebar-section {
            padding: 0.9rem 0.9rem 0.3rem;
            font-family: var(--ff-sans);
            font-weight: 600;
            font-size: 9.5px;
            color: var(--text-faint);
            text-transform: uppercase;
            letter-spacing: .22em;
            margin-top: 0.2rem;
            display: flex; align-items: center; gap: 8px;
        }
        .sidebar-section::before {
            content: ""; width: 4px; height: 4px; background: var(--gold-2); border-radius: 50%; opacity: .6;
            flex-shrink: 0;
        }
        .sidebar-section::after {
            content: ""; flex: 1; height: 1px; background: var(--border); opacity: .6;
        }

        .sidebar-item {
            position: relative;
            padding: 0.45rem 0.8rem 0.45rem 1rem;
            cursor: pointer;
            border-left: none;
            transition: background .15s ease-out, color .15s ease-out;
            font-size: 12.5px;
            color: var(--text-secondary);
            display: flex; align-items: center; gap: 8px;
        }
        .sidebar-item::before {
            content: ""; position: absolute; left: 0; top: 6px; bottom: 6px; width: 3px;
            background: var(--accent);
            transform: scaleY(0); transform-origin: top;
            transition: transform .2s ease-out;
        }
        .sidebar-item:hover { background: rgba(232,198,120,.04); }
        .sidebar-item:hover::before { transform: scaleY(1); }
        .sidebar-item.active {
            background: rgba(232,198,120,.07);
            color: var(--parchment);
        }
        .sidebar-item.active::before { transform: scaleY(1); background: var(--highlight); }

        .badge {
            display: inline-flex; align-items: center; gap: 3px;
            font-family: var(--ff-mono);
            font-size: 10px;
            letter-spacing: .02em;
            padding: 1px 5px;
            border-radius: 2px;
            background: var(--coal-3);
            color: var(--text-muted);
            border: 1px solid var(--border);
            min-width: 22px;
            justify-content: center;
            margin-left: 0.25rem;
        }
        .badge.npc {
            color: var(--success);
            border-color: color-mix(in srgb, var(--success) 40%, var(--border));
            background: color-mix(in srgb, var(--success) 6%, var(--coal-3));
        }

        /* ===== Content ===== */
        .content {
            flex: 1;
            overflow-y: auto;
            padding: 1.5rem;
        }

        /* ===== Evidence Table ===== */
        .evidence-table {
            width: 100%;
            border-collapse: collapse;
        }

        .evidence-table th {
            background: var(--secondary);
            padding: 0.6rem 0.8rem;
            text-align: left;
            border-bottom: 2px solid var(--accent);
            font-size: 0.8rem;
            color: var(--highlight);
            position: sticky;
            top: 0;
            z-index: 1;
        }

        .evidence-table td {
            padding: 0.5rem 0.8rem;
            border-bottom: 1px solid var(--border);
            font-size: 0.85rem;
            vertical-align: top;
        }

        .evidence-table tr:hover { background: rgba(184, 64, 64, 0.1); }

        .evidence-table .art-req { color: var(--highlight); font-weight: 500; }
        .evidence-table .art-req.empty { color: var(--warning); font-style: italic; }

        .id-col { width: 60px; color: var(--text-muted); }
        .type-col { width: 80px; }
        .name-col { width: 160px; font-weight: 500; }
        .location-col { width: 150px; color: var(--text-secondary); }
        .desc-col { max-width: 300px; }

        /* ===== Filter Bar ===== */
        .filter-bar {
            display: flex;
            gap: 0.5rem;
            align-items: center;
            margin-bottom: 1rem;
            padding: 0.5rem 0.75rem;
            background: var(--secondary);
            border-radius: 4px;
            flex-wrap: wrap;
        }

        .filter-bar label { color: var(--text-muted); font-size: 0.85rem; }

        .filter-bar input {
            background: var(--card);
            border: 1px solid var(--border);
            color: var(--text-primary);
            padding: 0.3rem 0.6rem;
            border-radius: 4px;
            font-size: 0.85rem;
            width: 200px;
        }

        .stats {
            color: var(--text-muted);
            font-size: 0.85rem;
            margin-left: auto;
        }
        .stats .has-art { color: var(--success); }
        .stats .no-art { color: var(--warning); }

        /* ===== Art Tab Bar ===== */
        .art-tab-bar {
            display: flex;
            gap: 0;
            border-bottom: 2px solid var(--border);
            margin-bottom: 0;
            background: var(--secondary);
            padding: 0 1rem;
            position: sticky;
            top: 0;
            z-index: 5;
        }
        .art-tab {
            padding: 0.6rem 1.2rem;
            cursor: pointer;
            font-size: 0.9rem;
            color: var(--text-muted);
            border-bottom: 2px solid transparent;
            margin-bottom: -2px;
            transition: color 0.2s, border-color 0.2s;
        }
        .art-tab:hover { color: var(--text-primary); }
        .art-tab.active {
            color: var(--highlight);
            border-bottom-color: var(--highlight);
            font-weight: 600;
        }
        .art-tab .tab-badge {
            display: inline-block;
            background: var(--warning);
            color: white;
            padding: 0 0.4rem;
            border-radius: 8px;
            font-size: 0.7rem;
            margin-left: 0.4rem;
            vertical-align: middle;
        }
        .art-tab .tab-badge.done {
            background: var(--success);
        }

        /* ===== Scene View ===== */
        .scene-title {
            font-size: 1.2rem;
            color: var(--highlight);
            margin-bottom: 0.5rem;
        }

        .scene-container {
            position: relative;
            border-radius: 8px;
            overflow: hidden;
            margin-bottom: 1rem;
            border: 1px solid var(--border);
            background: #000;
            min-height: 320px;
        }

        .scene-container .scene-bg {
            width: 100%;
            display: block;
            max-height: 400px;
            object-fit: cover;
        }

        .npc-on-scene {
            position: absolute;
            transform: translate(-50%, -80%);
            cursor: pointer;
            transition: filter 0.15s;
        }

        .npc-on-scene img {
            height: 120px;
            filter: drop-shadow(0 2px 6px rgba(0,0,0,0.8));
        }

        .npc-on-scene:hover img { filter: drop-shadow(0 2px 8px rgba(184,64,64,0.6)) brightness(1.1); }

        .npc-on-scene .npc-label {
            text-align: center;
            font-size: 0.7rem;
            color: var(--highlight);
            text-shadow: 0 1px 3px #000;
            margin-top: 0.15rem;
        }

        .scene-bg {
            width: 100%;
            max-height: 300px;
            object-fit: cover;
            border-radius: 8px;
            margin-bottom: 1rem;
            border: 1px solid var(--border);
        }

        .section-title {
            font-size: 1rem;
            color: var(--highlight);
            margin: 1.25rem 0 0.5rem;
            padding-bottom: 0.3rem;
            border-bottom: 1px solid var(--border);
        }

        /* ===== Evidence Cards ===== */
        .evidence-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 0.75rem;
        }

        .evidence-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 0.75rem;
            cursor: pointer;
            transition: all 0.15s;
        }

        .evidence-card:hover {
            border-color: var(--accent);
            transform: translateY(-1px);
        }

        .ev-name { font-weight: 600; margin-bottom: 0.3rem; }
        .ev-id { color: var(--text-muted); font-size: 0.75rem; }

        .ev-type {
            display: inline-block;
            background: var(--accent);
            color: white;
            padding: 0 0.4rem;
            border-radius: 4px;
            font-size: 0.7rem;
        }
        .ev-type.type-clue { background: #c0392b; }
        .ev-type.type-item { background: #2980b9; }
        .ev-type.type-envir { background: #7f8c8d; }
        .ev-type.type-note { background: #8e44ad; }

        .ev-desc {
            color: var(--text-secondary);
            font-size: 0.8rem;
            margin-top: 0.3rem;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .ev-art {
            font-size: 0.8rem;
            margin-top: 0.3rem;
            padding-top: 0.3rem;
            border-top: 1px solid var(--border);
        }
        .ev-art.filled { color: var(--highlight); }
        .ev-art.empty { color: var(--warning); }

        /* ===== NPC Cards ===== */
        .npc-card {
            background: var(--card);
            border: 1px solid var(--success);
            border-radius: 6px;
            padding: 0.75rem;
            margin-bottom: 0.5rem;
        }

        .npc-name { font-weight: 600; color: var(--success); }

        .npc-dialogue {
            color: var(--text-secondary);
            font-size: 0.85rem;
            margin-top: 0.3rem;
            font-style: italic;
        }

        .npc-meta {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-top: 0.3rem;
        }

        /* ===== Production Spec ===== */
        .prod-spec {
            margin-top: 0.5rem;
            padding-top: 0.5rem;
            border-top: 1px dashed var(--border);
            font-size: 0.8rem;
        }
        .prod-spec .spec-row {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            margin-bottom: 0.25rem;
            flex-wrap: wrap;
        }
        .prod-spec .spec-label {
            color: var(--text-muted);
            min-width: 5.5em;
            flex-shrink: 0;
        }
        .prod-spec .spec-summary {
            color: var(--text-secondary);
            font-size: 0.8rem;
            margin-bottom: 0.3rem;
            line-height: 1.4;
        }
        .copy-tag {
            font-family: monospace;
            background: var(--bg);
            padding: 2px 6px;
            border-radius: 3px;
            cursor: pointer;
            border: 1px solid var(--border);
            font-size: 0.78rem;
            color: var(--text);
        }
        .copy-tag:hover { border-color: var(--highlight); }

        /* ===== Modal ===== */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.7);
            z-index: 100;
            justify-content: center;
            align-items: center;
        }

        .modal-overlay.active { display: flex; }

        .modal {
            background: var(--secondary);
            border: 1px solid var(--accent);
            border-radius: 8px;
            padding: 1.5rem;
            max-width: 600px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
        }

        .modal-title {
            font-size: 1.1rem;
            color: var(--highlight);
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid var(--border);
        }

        .modal-close {
            float: right;
            background: none;
            border: none;
            color: var(--text-muted);
            font-size: 1.5rem;
            cursor: pointer;
            line-height: 1;
        }
        .modal-close:hover { color: var(--text-primary); }

        .modal p { margin-bottom: 0.5rem; font-size: 0.9rem; }
        .modal strong { color: var(--text-secondary); }

        .art-highlight {
            background: rgba(232, 198, 120, 0.1);
            border: 1px solid var(--highlight);
            border-radius: 4px;
            padding: 0.75rem;
            margin-top: 0.75rem;
        }

        .copy-tag {
            background: rgba(232, 198, 120, 0.15);
            color: var(--highlight);
            padding: 2px 8px;
            border-radius: 3px;
            cursor: pointer;
            font-family: monospace;
            transition: background 0.2s;
        }
        .copy-tag:hover { background: rgba(232, 198, 120, 0.3); }
        .derive-link {
            background: rgba(100, 180, 255, 0.1);
            border-left: 3px solid rgba(100, 180, 255, 0.6);
            padding: 6px 10px;
            margin: 6px 0;
            border-radius: 0 4px 4px 0;
            cursor: pointer;
            transition: background 0.2s;
        }
        .derive-link:hover { background: rgba(100, 180, 255, 0.25); }

