            if (this.currentTab === 'evidence') {
                html += this.renderEvidenceTab(items);
            } else if (this.currentTab === 'npc') {
                html += this.renderNPCTab(npcs);
            } else {
                html += this.renderSceneTab(rawScenes);
            }

            document.getElementById('content').innerHTML = html;
            UI.renderSidebar();
        },

        switchTab(tab) {
            this.currentTab = tab;
            this.filterText = '';
            this.showOnlyNoArt = false;
