        renderFlowSidebar(sidebar) {
            const loop = AppState.loopData;
            let html = '';

            if (!loop) {
                html = `<div class="sidebar-section">无循环数据</div>`;
                sidebar.innerHTML = html;
                return;
            }

            // Loop title, time & target
            html += `<div class="sidebar-section">${escapeHtml(loop.title || AppState.currentLoop)}</div>`;
            if (loop.time) {
                html += `<div style="padding: 0.15rem 1rem; font-size: 0.75rem; color: var(--highlight);">${escapeHtml(loop.time)}</div>`;
            }
            if (loop.target) {
                html += `<div style="padding: 0.3rem 1rem; font-size: 0.8rem; color: var(--text-muted);">${escapeHtml(loop.target)}</div>`;
            }

            // Opening
            if (loop.opening && loop.opening.length > 0) {
                html += `
                    <div class="sidebar-item ${AppState.currentPhase === 'opening' ? 'active' : ''}"
                         onclick="FlowView.showPhase('opening')">
                        <span class="phase-tag opening">开篇</span> (${loop.opening.length}场景)
                    </div>
                `;
            }

            // Scene list: support both old free_phase and new scenes{unlocked,locked,closed}
            // Unit9 yaml uses nested form { unlocked: { 地点A: [id...], 地点B: [id...] } }
            // Other units use flat form { unlocked: [id, id, ...] }; flatten if object.
            const flattenScenes = (raw) => {
                if (Array.isArray(raw)) return raw;
                if (raw && typeof raw === 'object') {
                    return Object.values(raw).flat();
                }
                return [];
            };
            if (loop.scenes) {
                const unlocked = flattenScenes(loop.scenes.unlocked);
                const locked = flattenScenes(loop.scenes.locked);
                const closed = flattenScenes(loop.scenes.closed);
                const locations = AppState.locationsData?.locations;

                // Helper: extract location code (last 2 digits) from scene ID
                const locCode = (sid) => String(sid).slice(-2);
                const padCode = (n) => String(n).padStart(2, '0');

                // Helper: find location group for a scene ID
                const findLocation = (sid) => {
                    if (!locations) return null;
                    const code = locCode(sid);
                    return locations.find(loc =>
                        padCode(loc.entry) === code ||
                        (loc.children || []).map(c => padCode(c)).includes(code)
                    );
                };

                // Helper: group items by location, preserving order
                const groupByLocation = (items, getId) => {
                    const groups = new Map(); // locName → items[]
                    const noGroup = [];
                    items.forEach(item => {
                        const sid = getId(item);
                        const loc = findLocation(sid);
                        if (loc) {
                            if (!groups.has(loc.name)) groups.set(loc.name, []);
                            groups.get(loc.name).push(item);
                        } else {
                            noGroup.push(item);
                        }
                    });
                    return { groups, noGroup };
                };

                // Render unlocked scenes grouped by location
