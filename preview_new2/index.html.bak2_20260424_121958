                    <p style="margin:0.75rem 0; color:var(--text-secondary);"><strong>目标：</strong>${escapeHtml(loop.target || '')}</p>
                    <div class="scene-container" style="min-height:280px; background:var(--card);"></div>
                    <div class="section-title">结尾场景 (${loop.ending.length})</div>
                `;
                loop.ending.forEach(item => {
                    const isObj = typeof item === 'object';
                    const sid = String(isObj ? item.id : item);
                    const scene = DataManager.getScene(sid);
                    const sceneName = (isObj && item.name) ? item.name : (scene?.sceneName || `场景 ${sid}`);
                    const bgUrl = scene ? Config.getAssetUrl(scene.backgroundImage) : '';
                    const talkFile = (isObj && item.talk) ? item.talk : '';

                    html += `<div class="npc-card" style="margin-bottom:1rem;">`;

                    if (bgUrl) {
                        html += `<img src="${bgUrl}" onerror="this.style.display='none'" style="width:100%; max-height:180px; object-fit:cover; border-radius:4px; margin-bottom:0.75rem;" alt="">`;
                    }

                    html += `<div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.5rem;">`;
                    html += `<span style="font-size:1.1rem; font-weight:600; color:var(--text-primary);">${escapeHtml(sceneName)}</span>`;
                    html += `<span style="color:var(--text-muted); font-size:0.85rem;">(${sid})</span>`;
                    html += `</div>`;

                    if (talkFile) {
                        const entries = AppState.allTalks.filter(t => t.videoScene === talkFile);
                        const firstId = entries.length > 0 ? entries[0].id : '';
                        html += `<div style="display:flex; align-items:center; gap:0.75rem; margin-top:0.5rem; flex-wrap:wrap;">`;
                        html += `<span class="copy-tag" onclick="copyText('${escapeHtml(talkFile)}', this)">📄 ${escapeHtml(talkFile)}.json</span>`;
                        if (entries.length > 0) {
                            html += `<span style="color:var(--text-muted); font-size:0.8rem;">${entries.length} 句 | 首句ID: ${firstId}</span>`;
                        } else {
                            html += `<span style="color:var(--warning); font-size:0.8rem;">(未加载)</span>`;
                        }
                        if (firstId) {
                            html += `<button class="btn" onclick="DialogController.startFromTalkId('${firstId}')" style="font-size:0.85rem; padding:0.3rem 0.8rem;">▶ 播放</button>`;
                        }
                        html += `</div>`;
                    }

                    html += `</div>`;
                });
                html += ``;
            }

            document.getElementById('content').innerHTML = html;
            UI.renderSidebar();
        }
    };

    // ===== Dialog Controller (one-line-at-a-time navigation) =====
    const DialogController = {
        _state: {
            chain: [],       // 当前线性对话链 [{talk, branches}]
            index: 0,        // 当前位置
            history: [],     // 分支历史栈，用于返回上一层
            avatarUrl: '',   // NPC 默认头像
            sceneId: '',
        },

        start(npcIdx, talkType) {
            const scene = DataManager.getScene(AppState.currentSceneId);
            const info = scene?.NPCInfos?.[npcIdx];
            if (!info) return;

            const talkId = talkType === 'loopTalk'
                ? (info.LoopTalkInfo?.id || '')
                : (info.TalkInfo?.id || DataManager.findTalkForNPC(info.NPC?.id) || '');
            if (!talkId) return;

            const resA = info.ResPath ? Config.getAssetUrl(info.ResPath) : '';
            const resB = info.ClickResPath ? Config.getAssetUrl(info.ClickResPath) : '';

            this._state = {
                chain: DataManager.buildDialogueChain(talkId),
                index: 0,
                history: [],
                avatarUrl: resA || resB,
                sceneId: AppState.currentSceneId,
                containerId: null,
            };

            if (this._state.chain.length === 0) {
                UI.updateStatus('该 NPC 无对话数据');
                return;
            }

            this._render();
        },

        // 从任意 Talk ID 开始对话（不依赖 NPCInfos）
        startFromTalkId(talkId, containerId) {
            if (!talkId) return;
            const chain = DataManager.buildDialogueChain(talkId);
            if (chain.length === 0) {
                UI.updateStatus('无对话数据');
                return;
            }
            const firstIcon = chain.find(n => n.talk.Speaker?.IconSmall)?.talk.Speaker?.IconSmall;
            this._state = {
                chain, index: 0, history: [],
                avatarUrl: firstIcon ? `${Config.paths.assets}/Art/NPC/Icon/${firstIcon}.png` : '',
                sceneId: '', containerId: containerId || null,
            };
            this._render();
        },

        _render() {
            const { chain, index, avatarUrl } = this._state;
            if (!chain.length) { this.close(); return; }

            const node = chain[index];
            const talk = node.talk;
            const speaker = cn(talk.Speaker?.Name) || talk.Speaker?.id || '?';
            const words = cn(talk.Words) || '';
            const action = talk.cnAction || '';
            const isLie = talk.script === 'Lie' || talk.script === 'lie';
            const lieEvidence = isLie ? (talk.Parameters?.[0]?.ParameterStr || '') : '';
            // 头像已整体移除（线上无美术）

            const isLast = (index === chain.length - 1);
            const hasBranches = isLast && node.branches && node.branches.length > 0;
            const isEnd = isLast && !node.branches;

            let controlsHtml;
            if (hasBranches) {
                controlsHtml = `<div class="dlg-branches">`;
                node.branches.forEach(b => {
                    controlsHtml += `<button class="branch-btn" onclick="DialogController.selectBranch('${b.targetId}')">${escapeHtml(b.text)}</button>`;
                });
                controlsHtml += `</div>`;
            } else {
                const canPrev = index > 0 || this._state.history.length > 0;
                controlsHtml = `<div class="dlg-controls">
                    <button class="btn" onclick="DialogController.prev()" ${canPrev ? '' : 'disabled'}>上一句</button>
                    ${isEnd
                        ? `<button class="btn" onclick="DialogController.close()">结束对话</button>`
                        : `<button class="btn" onclick="DialogController.next()">下一句</button>`
                    }
                </div>`;
            }

            // 头像全部关闭（线上无美术资源，头像大量 404）——对话框由 .dlg-body 铺满整行
            const boxHtml = `
                <div class="dialog-box">
                    <div class="dlg-body">
                        <div class="dlg-speaker">${escapeHtml(speaker)}</div>
                        ${action ? `<div style="font-size:0.8rem; color:var(--text-muted); font-style:italic; margin-bottom:0.2rem;">(${escapeHtml(action)})</div>` : ''}
                        <div class="dlg-text">${escapeHtml(words)}</div>
                        ${isLie ? `<div style="margin:0.3rem 0; padding:0.3rem 0.6rem; background:#6b2a2a; border:1px solid var(--accent); border-radius:4px; font-size:0.8rem; color:var(--highlight);">&#x1f3af; 指证点 | 证据: ${escapeHtml(lieEvidence)}</div>` : ''}
                        <div class="dlg-id">Talk #${talk.id || '?'} | ${index + 1}/${chain.length}</div>
                        ${controlsHtml}
                    </div>
                    <button class="dlg-close-btn" onclick="DialogController.close()" title="关闭">&times;</button>
                </div>
            `;

            let container = this._state.containerId
                ? document.getElementById(this._state.containerId)
                : document.querySelector('.scene-container');

            // Fallback: scene-container missing or collapsed (no background image)
            // 插入到 #content 内部作为首个子节点——避免被插成 .main flex 兄弟挤在 sidebar 旁
            if (!container || container.offsetHeight < 20) {
                let fb = document.getElementById('dlg-fallback-container');
                if (!fb) {
                    const contentEl = document.getElementById('content');
                    if (contentEl) {
                        contentEl.insertAdjacentHTML('afterbegin',
                            '<div id="dlg-fallback-container" style="position:relative; margin-bottom:1rem; border:1px solid var(--border); border-radius:8px; background:var(--card); padding:0.5rem;"></div>');
                        fb = document.getElementById('dlg-fallback-container');
                    }
                }
                container = fb;
                if (!container) return;
            }

            const oldBox = container.querySelector('.dialog-box');
            if (oldBox) oldBox.remove();
            container.insertAdjacentHTML('beforeend', boxHtml);
        },

        next() {
            const { chain, index } = this._state;
            if (index < chain.length - 1) {
                this._state.index++;
                this._render();
            }
        },

        prev() {
            if (this._state.index > 0) {
                this._state.index--;
                this._render();
            } else if (this._state.history.length > 0) {
                const prev = this._state.history.pop();
                this._state.chain = prev.chain;
                this._state.index = prev.index;
                this._render();
            }
        },

        selectBranch(targetId) {
            this._state.history.push({
                chain: this._state.chain,
                index: this._state.index
            });
            this._state.chain = DataManager.buildDialogueChain(targetId);
            this._state.index = 0;

            if (this._state.chain.length === 0) {
                UI.updateStatus('分支无后续对话');
                this.close();
                return;
            }
            this._render();
        },

        close() {
            const container = this._state.containerId
                ? document.getElementById(this._state.containerId)
                : (document.querySelector('.scene-container') || document.getElementById('dlg-fallback-container'));
            if (!container) return;
            const box = container.querySelector('.dialog-box');
            if (box) box.remove();
        }
    };

    // ===== Game Controller =====
    const GameController = {
        async load() {
            const unit = document.getElementById('unitSelect').value;
            const loop = document.getElementById('loopSelect').value;

            AppState.currentUnit = unit;
            AppState.currentLoop = loop;
            AppState.reset();

            UI.updateStatus('加载中...');

            try {
                // 检测是否为 file:// 协议
                if (location.protocol === 'file:') {
                    const msg = '当前使用 file:// 协议打开，浏览器会阻止加载本地文件。\n\n' +
                        '请用以下任一方式启动本地服务器：\n' +
                        '1. VS Code 安装 Live Server 插件，右键 index.html → Open with Live Server\n' +
                        '2. 命令行进入 preview_new2 目录，运行: python -m http.server 8080\n' +
                        '   然后访问 http://localhost:8080\n\n' +
                        '尝试继续加载...';
                    console.warn(msg);
                    UI.updateStatus('警告: file:// 协议可能导致加载失败，建议使用本地服务器');
                }

                console.log('Loading table data from:', Config.paths.tableData);
                await DataLoader.loadTableData();
                console.log('Table data loaded successfully');

                console.log('Loading loop config:', unit, loop);
                await Promise.all([
                    DataLoader.loadLoopConfig(unit, loop),
                    DataLoader.loadChapterConfig(),
                    DataLoader.loadTalkSummaries(unit),
                    DataLoader.loadStoryOverview(unit)
                ]);
                console.log('Loop config loaded:', AppState.loopData ? 'OK' : 'not found');

                // 加载 AVG Talk + Expose 数据（替代 Talk.json）
                console.log('Loading AVG Talk data:', loop);
                const talkCount = await DataLoader.loadAVGTalks(loop);
                const exposeCount = await DataLoader.loadAVGExpose(loop);
                console.log(`AVG data loaded: ${talkCount} talks, ${exposeCount} expose entries`);

                const chapter = DataManager.chapter(unit);
                const chapterItems = DataManager.itemsByChapter(chapter);
                const loopScenes = DataManager.scenesForLoop(unit, loop);
                const hasArt = chapterItems.filter(i => i.ArtRequirement).length;

                UI.updateStatus(
                    `${unit} ${loop} | ` +
                    `证据: ${chapterItems.length} (美术需求: ${hasArt}/${chapterItems.length}) | ` +
                    `场景: ${loopScenes.length} | ` +
                    `对话: ${talkCount} + 指证: ${exposeCount}`
                );

                this.switchView(AppState.currentView);
            } catch (e) {
                console.error('Load failed:', e);
                const errMsg = `加载失败: ${e.message}`;
                UI.updateStatus(errMsg);
                document.getElementById('content').innerHTML = `
                    <div style="color:var(--warning); padding:2rem; max-width:600px;">
                        <h3 style="margin-bottom:1rem;">加载失败</h3>
                        <p><strong>错误：</strong>${escapeHtml(e.message)}</p>
                        <p style="margin-top:1rem; color:var(--text-secondary);">
                            如果是网络错误 (Failed to fetch)，通常是因为用 file:// 协议直接打开了 HTML 文件。<br><br>
                            <strong>解决方法：</strong><br>
                            1. VS Code 安装 <strong>Live Server</strong> 插件 → 右键 index.html → Open with Live Server<br>
                            2. 或在 preview_new2 目录运行: <code style="background:var(--card);padding:0.2rem 0.4rem;border-radius:3px;">python -m http.server 8080</code><br>
                            然后访问 <code style="background:var(--card);padding:0.2rem 0.4rem;border-radius:3px;">http://localhost:8080</code>
                        </p>
                        <p style="margin-top:1rem; color:var(--text-muted);">
                            数据路径: ${escapeHtml(Config.paths.tableData)}<br>
                            当前协议: ${location.protocol}
                        </p>
                    </div>
                `;
            }
        },

        switchView(view) {
            AppState.currentView = view;

            document.getElementById('btnArt').classList.toggle('active', view === 'art');
            document.getElementById('btnFlow').classList.toggle('active', view === 'flow');

            if (view === 'art') {
                ArtOverviewView.render();
            } else {
                if (AppState.loopData?.opening) {
                    FlowView.showPhase('opening');
                } else {
                    document.getElementById('content').innerHTML =
                        '<p style="color:var(--text-muted); text-align:center; margin-top:20vh;">该循环暂无场景数据</p>';
                    UI.renderSidebar();
                }
            }

            UI.renderSidebar();
        }
    };

    // ===== Init =====
    document.addEventListener('DOMContentLoaded', () => {
        document.getElementById('btnArt').classList.add('active');
    });
    </script>
</body>
