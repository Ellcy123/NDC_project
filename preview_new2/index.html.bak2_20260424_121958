        // ---- Scene dedup helper: merge scenes by sceneNameEn ----
        _mergeScenes(allScenes) {
            const map = new Map(); // sceneNameEn → merged object
            allScenes.forEach(s => {
                const key = s.sceneNameEn || s.sceneName || String(s.sceneId);
                if (!map.has(key)) {
                    map.set(key, {
                        key,
                        sceneName: s.sceneName || '',
                        sceneNameEn: s.sceneNameEn || '',
                        backgroundImage: s.backgroundImage || '',
                        ArtRequirement: s.ArtRequirement || '',
                        loops: [],
                        npcMap: new Map() // npcNameEn → { info, resPathSet }
                    });
                }
                const m = map.get(key);
                // Collect loop number from sceneId (2nd digit)
                const loopNum = String(s.sceneId).length >= 2 ? String(s.sceneId)[1] : '?';
                if (!m.loops.includes(loopNum)) m.loops.push(loopNum);
                // Merge ArtRequirement (take first non-empty)
                if (!m.ArtRequirement && s.ArtRequirement) m.ArtRequirement = s.ArtRequirement;
                // Merge NPCInfos
                (s.NPCInfos || []).forEach(info => {
                    const npcKey = info.NPC?.Name?.[1] || cn(info.NPC?.Name) || String(info.id);
                    if (!m.npcMap.has(npcKey)) {
                        m.npcMap.set(npcKey, {
                            info,
                            resPaths: new Set(),
                            ArtRequirement: info.ArtRequirement || ''
                        });
                    }
                    const npcEntry = m.npcMap.get(npcKey);
                    if (info.ResPath) npcEntry.resPaths.add(info.ResPath.split('\\').pop());
                    if (info.ClickResPath) npcEntry.resPaths.add(info.ClickResPath.split('\\').pop());
                    if (!npcEntry.ArtRequirement && info.ArtRequirement) npcEntry.ArtRequirement = info.ArtRequirement;
                });
            });
            return Array.from(map.values());
        },

