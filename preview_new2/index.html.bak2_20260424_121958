                    const resList = Array.from(npcEntry.resPaths);
                    npcRows += `
                        <tr style="background: rgba(232,198,120,0.03); cursor:pointer;" onclick="UI.showNpcModal('${npcEntry.info?.NPC?.id || ''}')">
                            <td style="padding-left:1.5rem; color:var(--text-muted);">└</td>
                            <td class="name-col" style="color:var(--highlight);">${escapeHtml(npcName)}</td>
