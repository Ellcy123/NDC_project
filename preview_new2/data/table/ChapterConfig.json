          {
            "type": "3",
            "param": "3101001"
          }
        ],
        "text": "楼顶不只Thomas一个人——女性脚印与Thomas面对面站在护栏边"
      },
      {
        "id": "3002",
        "condition": [
          {
            "type": "1",
            "param": "3106"
          },
          {
            "type": "1",
            "param": "3101"
          }
        ],
        "text": "Thomas不是主动跳下的——护栏外侧灰尘无损，着地点仅0.8米"
      }
    ],
    "exposeNpcId": "301",
    "exposes": [
